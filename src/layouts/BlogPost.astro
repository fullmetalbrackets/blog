---
import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import TableOfContents from '@components/TableOfContents.astro';
import BlogPosting from "@components/BlogPosting.astro";
import ScrollProgress from "@components/ScrollProgress.astro";
import ReadingTime from "@components/ReadingTime.astro";
import WebMentions from "@components/WebMentions.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import HowToSchema from "@components/HowToSchema.astro";
import CodeblockCopy from "@components/CodeblockCopy.astro";
import HeadingCopy from "@components/HeadingCopy.astro";
import HCard from "@components/H-Card.astro";
import Lightbox from "@components/Lightbox.astro";
import type { BlogPostProps } from '../types';
import type { MarkdownHeading } from '@astrojs/markdown-remark';
import {
  BlueskyShareButton,
  ThreadsShareButton,
  TwitterShareButton,
  RedditShareButton,
  HackerNewsShareButton,
  SocialShare
} from "astro-social-share";
import Related from '@icons/related.svg';
import Comments from "@components/Comments.astro";
import { getRelatedPosts } from '@utils/collections';
import { GITHUB, DONATE, SITE_URL } from "@consts";

type Props = BlogPostProps & { headings: MarkdownHeading[]; readingTime: string };

const BUTTONS = [BlueskyShareButton, ThreadsShareButton, TwitterShareButton, RedditShareButton, HackerNewsShareButton];
const { title, description, pubDate, updatedDate, tags, headings, related, readingTime } = Astro.props;
const { slug } = Astro.params;
const selectedPosts = await getRelatedPosts(related ?? []);
---

<BaseLayout title={title} description={description} ogType="article" ogImage={`${SITE_URL}/og/${slug}.png`}>
  <link rel="stylesheet" href="/prism.css" slot="head" />
  <style scoped>
    h1 {
      margin-top: -0.1em;
      margin-bottom: 0.125em;
      line-height: 1.1;
      font-weight: 800;
    }
    hr {
      margin-top: 1em;
    }
    article {
      margin: 2.5em auto;
    }
    .description {
      margin: 1em auto 0 auto;
    }
    .info {
      display: flex;
      margin: 0.5em 0 -0.25em 0;
      padding: 0;
      place-items: center;
      gap: 0.5em;
      justify-content: left;
    }
    .readingtime {
      display: flex;
      place-items: center;
      margin: -0.375em 0 0 0;
    }
    .updated {
      display: flex;
      place-items: center;
      margin: 0;
      padding: 0;
    }
    .last-updated-on {
      display: inline-flex;
      color: var(--emphasis);
      font-family: var(--sub-font);
      font-size: 0.875em;
      font-weight: 500;
      margin-right: 0.25em;
    }
    .slot-content {
      margin: 0;
      padding: 0;
    }
    .midline {
      margin-bottom: 1.5em;
    }

    /* post footer */
    .edit-post {
      display: flex;
      justify-content: space-around;
      color: var(--primary);
      font-family: var(--sub-font);
      font-weight: 700;
      margin: 0 auto 1.5em auto;
    }
    .edit-post span {
      display: flex;
      margin: 0 auto;
    }
    .gh {
      width: 24px;
      height: 24px;
      margin: 0;
      padding: 0;
    }
    .edit {
      display: inline-flex;
      align-items: center;
      gap: 0.375em;
      background-color: var(--info);
      color: #000;
      border-radius: 0.25em;
      cursor: pointer;
      font-weight: 700;
      margin: 1em auto 0 auto;
      padding: 6px 10px;
      text-decoration: none;
      font-size: 0.85em;
      font-family: var(--sub-font);
      line-height: 1.5;
    }
    .edit:hover {
      background: var(--hover);
      color: #000;
      transition: all .15s ease-out;
      transform: none;
      box-shadow: none;
    }
    .edit img {
      display: inline;
      filter: brightness(0) saturate(100%);
      height: 24px;
      width: auto;
      margin: 0;
      border-radius: 0;
    }
    .footer-grid {
      display: flex;
      flex-wrap: wrap;
      width: 100%;
      font-family: var(--sub-font);
      font-weight: 700;
      margin: 0 auto 1.5em auto;
    }
    .footer-grid > div {
      flex: 0 0 50%;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75em;
      padding: 0.75em 0;
    }
    .coffee {
      color: var(--primary);
      cursor: default;
    }
    .coffee-btn {
      display: grid;
      background-color: var(--info);
      border-radius: 0.25em;
      font-family: var(--sub-font);
      color: var(--primary);
      grid-template-columns: auto;
      grid-template-rows: auto auto;
      cursor: pointer;
      margin-top: 0.25em;
      padding: 0;
    }
    .coffee-btn:hover {
      background: var(--hover);
      transition: all .15s ease-out;
    }
    .share {
      color: var(--primary);
      cursor: default;
    }
    .share span {
      margin-bottom: -0.25em;
    }
    .umami {
      color: var(--primary);
      cursor: default;
    }
    .stats {
      display: inline-flex;
      align-items: center;
      gap: 0.375em;
      background-color: var(--info);
      color: #000;
      border-radius: 0.25em;
      cursor: pointer;
      font-weight: 700;
      padding: 4px 10px;
      text-decoration: none;
      font-family: var(--sub-font);
      line-height: 1.5;
    }
    .stats:hover {
      background: var(--hover);
      color: #000;
      transition: all .15s ease-out;
      transform: none;
      box-shadow: none;
    }
    .stats-icon {
      display: inline-flex;
      place-items: center;
      filter: brightness(0) saturate(100%);
      height: 24px;
      width: auto;
      margin: 0;
      border-radius: 0;
    }
    .questions {
      color: var(--primary);
    }
    .questions > span {
      font-family: var(--sub-font);
      font-weight: 700;
      color: var(--primary);
    }
    .email {
      display: inline-flex;
      align-items: center;
      gap: 0.375em;
      text-align: center;
      background-color: var(--info);
      border-radius: 0.25em;
      cursor: pointer;
      font-weight: 700;
      text-decoration: none;
      font-family: var(--sub-font);
      line-height: 1.5;
      padding: 4px 10px 6px 10px;
      color: #000;
    }
    .email:hover {
      background: var(--hover);
      transition: all .15s ease-out;
      transform: none;
      box-shadow: none;
    }
    .email-icon {
      width: 25px;
      height: auto;
      margin: 0.1em 0 0 0;
    }
    .topic {
      font-size: 0.875em;
    }
    .endline {
      margin-top: 0.5em;
      margin-bottom: 1.5em;
    }

    /* blog nav */
    a .nav-btn {
      place-items: center;
    }
    .blog-nav {
      display: inline-flex;
      justify-content: space-between;
      font-size: 1.5em;
      margin: 0 auto 1em auto;
      padding: 0;
      width: 100%;
    }
    .nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.25em;
      background: var(--primary);
      color: #000;
      border-radius: 0.375em;
      font-size: 0.5em;
      font-weight: 700;
      padding: 0.4em 0.75em;
      text-decoration: none;
      cursor: pointer;
      transition: background-color .15s ease-out;
    }
    .nav-btn:hover {
      background-color: var(--secondary);
      color: #000;
      transform: none;
      box-shadow: none;
    }
    .nav-btn svg {
      fill: currentColor;
      flex-shrink: 0;
      width: 16px;
      height: 16px;
    }
    .nav-btn.back svg,
    .nav-btn.go-top svg {
      stroke: currentColor;
      stroke-width: 1.25;
    }
    .nav-btn.home svg {
      place-items: center;
      width: 20px;
      height: 20px;
    }
    .nav-btn span {
      place-items: center;
      padding-top: 2.5px;
    }

    /* related posts */
    .related {
      display: inline;
    }
    .related h3 {
      display: flex;
      place-items: center;
      font-size: 1.25em;
      color: var(--primary);
      margin: 1em 0 1em 0;
      border-top: transparent;
      border-left: transparent;
      border-right: transparent;
      border-bottom: thick dotted var(--border);
    }
    .related svg {
      filter: var(--toc);
      margin-left: -0.135em;
      margin-right: 0.1em;
    }
    .related ul {
      list-style-type: none;
      padding: 0;
    }
    .related li {
      border: 2px solid transparent;
      background-color: var(--blockquote);
      color: var(--emphasis);
      padding: 0.75em 1em 0.85em 1em;
      margin: 1em;
      border-radius: 0.25em;
    }
    .related li span {
      font-size: 1em;
      font-weight: 700;
      margin-bottom: 0;
      line-height: 1.2;
    }
    .related li p {
      color: var(--text);
      font-size: 0.875em;
      margin-top: 0.25em;
      margin-bottom: 0;
      line-height: 1.2;
    }
    .related li button {
      margin: 0 0.5em 0.25em 0;
    }
    .related li:hover {
      color: var(--hover);
      border: 2px solid var(--emphasis);
    }

    /* wide-screen sidebar */
    @media screen and (min-width: 2108px) {
      .blog-tags, .info, .updated {
        position: absolute;
        left: 2em;
        width: 35%;
        max-width: 35%;
      }
      .blog-tags {
        top: 4.55em;
      }
      .info {
        top: 6em;
      }
      .updated {
        top: 7.55em;
      }
    }

    /* mobile */
    @media screen and (max-width: 667px) {
      h1 {
        font-size: 1.35em;
      }
      article {
        margin: 1em 0.5em;
      }
      .tag button {
        margin: 0 0 0.25em 0;
        font-size: 14px;
      }
      .info {
        justify-content: space-between;
        margin-top: 0.5em;
      }
      .last-updated-on {
        font-size: 18px;
        place-items: center;
      }
      .updated {
        place-items: center;
      }
      .related li {
        font-size: 1em;
        line-height: 1.2;
        padding: 1em 1em 0.85em 1em;
        margin: 1em auto;
      }
      .related li p {
        margin-top: 0;
      }
      .related li button {
        margin: 0 0.25em 0.25em 0;
      }
      .edit-post {
        justify-content: space-around;
        align-content: center;
      }
      .edit-button::before {
        content: "\a";
        white-space: pre;
      }
      .edit {
        margin-left: 1.25em;
      }
      .footer-grid {
        margin-bottom: 0.5em;
      }
      .footer-grid > div {
        flex: 0 0 100%;
      }
    }

    /* hover effects */
    @media (hover: hover) {
      .blog-nav a:hover {
        box-shadow: -4px -4px 0 #000;
        transform: translate(4px, 4px);
        outline-offset: 1px;
      }
      .blog-nav a {
        text-overflow: ellipsis;
        transition: all 0.1s ease-out;
        cursor: pointer;
      }
    }
  </style>

  <slot name="astro-social-share-css">
    <style is:global>
      .astro-social-share {
        margin: 0 auto 2em auto;
        height: 24px;
        padding: 0.35em 0 0 0;
      }
      .astro-social-share svg {
        filter: var(--share);
        margin: 0 0.25em;
        width: 32px;
        height: 32px;
      }
      .astro-social-share svg:hover {
        filter: var(--svg-hover);
        transition: all .2s ease-out;
      }
    </style>
  </slot>

  <ScrollProgress />
  <BlogPosting slot="head" {...Astro.props} />
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${ SITE_URL }/` },
    { name: "Blog", url: `${ SITE_URL }/blog/` },
    { name: title, url: `${ SITE_URL }/blog/${slug}/` }
  ]} />
  <HowToSchema 
    title={title}
    description={description}
    slug={slug!}
    tags={tags}
    headings={headings}
    readingTime={readingTime}
  />
  <Lightbox />
  <CodeblockCopy />
  <HeadingCopy />

  <article class="h-entry" data-pagefind-body data-pub-date={pubDate.toISOString()}
    data-updated-date={updatedDate ? updatedDate.toISOString() : ''}>
    <h1 class="p-name">{title}</h1>
    <a class="u-url" href={`https://fullmetalbrackets.com/blog/${slug}/`} hidden>Permalink</a>
    <div class="blog-tags">
      <span class="tag" data-pagefind-ignore>
        {tags.map((tag) => (
          <a href={`/categories/${tag}/`} rel="prefetch-intent tag" data-umami-event="category-from-article">
            <button data-pagefind-filter="tag">{tag}</button>
          </a>
        ))}
      </span>
    </div>
    <div class="info">
      <span><FormattedDate class="dt-published" date={pubDate} /></span>
      <span class="readingtime"><ReadingTime time={readingTime} data-pagefind-ignore /></span>
    </div>
    <p class="updated">
      {updatedDate && (
        <span class="last-updated-on">Updated&nbsp;</span>
        <FormattedDate class="dt-updated" date={updatedDate} />
      )}
    </p>
    <hr />
    <p class="p-summary description">{description}</p>
    <TableOfContents headings={headings} />
    <div class="e-content slot-content">
      <slot>
        <p>
          If you're seeing this, something went wrong! Please try <em>reloading the page</em>.
        </p>
      </slot>
    </div>
    {selectedPosts.length > 0 && (
      <div class="related" data-pagefind-ignore>
        <h3><Related width={36} height={36}/> Related Posts</h3>
        <ul>
          {selectedPosts.map(post => (
            <a href={`/blog/${post.id}/`} rel="prefetch-intent" data-umami-event={`related-${post.id}`}>
              <li>
                <span>{post.data.title}</span>
                <div>
                  <span class="tag">
                    {post.data.tags.map((tag) => (
                      <button>{tag}</button>
                    ))}
                  </span>
                </div>
                <p>{post.data.description}</p>
              </li>
            </a>
          ))}
        </ul>
      </div>
    )}
  </article>

  <HCard />
  <hr class="midline" />

  <WebMentions />

  <Comments />

  <!-- Error / edit link -->
  <nav class="edit-post" aria-label="Edit post">
    <div>
      <span>Error in this article?</span>
      <span class="edit-button">
        <a
          class="edit"
          href={`${GITHUB}/blog/blob/main/src/content/blog/${slug}.md/`}
          target="_blank"
          rel="noopener noreferrer"
          data-umami-event={`edit-gh-${slug}`}
        >
          <img
            src="/assets/gh.svg"
            class="gh"
            loading="lazy"
            decoding="async"
            alt=""
            aria-hidden="true"
          />
          <span>Edit on GitHub</span>
        </a>
      </span>
    </div>
  </nav>

  <!-- Coffee / Share / Stats / Contact -->
  <nav class="footer-grid" aria-label="Support, share, and contact">
    <div class="coffee">
      <span>Was this article helpful?</span>
      <a href={DONATE} rel="noopener noreferrer">
        <img
          src="https://img.buymeacoffee.com/button-api/?slug=arieldiaz&font_family=Inter&coffee_colour=6F4E37"
          class="coffee-btn"
          alt="Buy Me A Coffee"
          title="Buy Me A Coffee"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
    <div class="share">
      <span>Want to share this article?</span>
      <SocialShare
        buttons={BUTTONS}
        description={description}
        title={title}
      />
    </div>
    <div class="umami">
      <span>Want to see article stats?</span>
      <a
        class="stats"
        href={`https://u.adiaz.fyi/share/TtTytHU8rJy0oEzN/?path=eq./blog/${slug}/`}
        target="_blank"
        rel="noopener noreferrer"
        data-umami-event={`umami-stats-${slug}`}
      >
        <img
          src="/assets/umami.svg"
          class="stats-icon"
          loading="lazy"
          decoding="async"
          alt=""
          aria-hidden="true"
        />
        <span class="topic">Umami</span>
      </a>
    </div>
    <div class="questions">
      <span>Have any questions?</span>
      <a
        class="email"
        href={`mailto:contact@fullmetalbrackets.com?subject=RE: ${title}`}
      >
        <img
          src="/assets/email.svg"
          class="email-icon"
          loading="lazy"
          decoding="async"
          alt=""
          aria-hidden="true"
        />
        <span class="topic">Email Me</span>
      </a>
    </div>
  </nav>

  <hr class="endline" />

  <nav class="blog-nav" aria-label="Post navigation">
    <a href="/blog/" rel="prefetch-intent" class="nav-btn back" aria-label="Back to Blog">
      <svg role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M14 7.5H3.439l4.29-4.387-.714-.699L1.55 8l5.465 5.586.714-.7L3.44 8.5h10.56v-1z" />
      </svg>
      <span>Blog</span>
    </a>
    <a href="/" rel="prefetch-intent" class="nav-btn home" aria-label="Go to Home">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
      </svg>
      <span>Home</span>
    </a>
    <a href="#top" class="nav-btn go-top" aria-label="Back to top">
      <span>Top</span>
      <svg role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M7.5 14V3.439l-4.387 4.29-.699-.714L8 1.55l5.586 5.465-.7.714L8.5 3.44V14h-1z" />
      </svg>
    </a>
  </nav>

  <script is:inline>
    document.querySelectorAll('blockquote').forEach((blockquote) => {
      const firstPara = blockquote.querySelector('p');
      if (!firstPara) return;

      const match = (firstPara.textContent ?? '').match(/^\[(\w+)\]\s*/);
      if (!match) return;

      blockquote.setAttribute('data-type', match[1]);
      blockquote.classList.add(`blockquote-${match[1]}`);

      const textNode = firstPara.firstChild;
      if (textNode?.nodeType === Node.TEXT_NODE && textNode.textContent) {
        textNode.textContent = textNode.textContent.replace(/^\[(\w+)\]\s*/, '');
      }
    });

    const article = document.querySelector('article');
    if (article) {
      const hr = article.querySelector('hr');
      const description = article.querySelector('.description');
      const tocElement = description?.nextElementSibling;
      const firstContentElement = tocElement?.nextElementSibling;

      if (hr && firstContentElement?.tagName === 'BLOCKQUOTE' &&
          firstContentElement.getAttribute('data-type') === 'warning') {
        hr.parentNode.insertBefore(firstContentElement, hr.nextSibling);
      }
    }
  </script>

  <script is:inline>
    const articleEl = document.querySelector('article');
    if (articleEl) {
      const pubDate = articleEl.dataset.pubDate;
      const updatedDate = articleEl.dataset.updatedDate;
      const relevantDate = updatedDate ? new Date(updatedDate) : new Date(pubDate);
      const now = new Date();
      const monthsDiff =
        (now.getFullYear() - relevantDate.getFullYear()) * 12 +
        (now.getMonth() - relevantDate.getMonth());

      if (monthsDiff >= 18) {
        const banner = document.createElement('blockquote');
        banner.setAttribute('data-type', 'warning');

        if (monthsDiff >= 24) {
          const years = Math.floor(monthsDiff / 12);
          const months = monthsDiff % 12;
          const timeString = months > 0 ? `${years} years, ${months} months` : `${years} years`;
          banner.innerHTML = `<p><strong>Heads up!</strong></p><p>This post hasn't been updated in <b>${timeString}</b> so please consider everything out of date!</p>`;
        } else {
          banner.innerHTML = `<p><strong>Heads up!</strong></p><p>This post hasn't been updated in <i>over 18 months</i> and some information may be outdated.</p>`;
        }

        articleEl.querySelector('hr')?.insertAdjacentElement('afterend', banner);
      }
    }
  </script>

  <script is:inline>
    if (window.matchMedia('(min-width: 2108px)').matches) {
      const toc = document.querySelector('.toc-container');
      const articleEl = document.querySelector('article');

      if (toc && articleEl) {
        const headings = articleEl.querySelectorAll('h2');
        const lastHeading = headings[headings.length - 1];

        if (lastHeading) {
          const observer = new IntersectionObserver(([entry]) => {
            const isVisible = entry.isIntersecting || entry.boundingClientRect.top > 0;
            toc.style.opacity = isVisible ? '1' : '0';
            toc.style.pointerEvents = isVisible ? 'auto' : 'none';
            toc.style.transition = 'opacity 0.3s ease';
          });
          observer.observe(lastHeading);
        }
      }
    }
  </script>
</BaseLayout>
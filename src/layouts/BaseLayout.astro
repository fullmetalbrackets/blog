---
import BaseHead from '@components/BaseHead.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import WebsiteSchema from '@components/WebsiteSchema.astro';
import { SITE_TITLE } from '@consts';

const { title, description, ogType, ogImage } = Astro.props.frontmatter || Astro.props;
const pageTitle = title === SITE_TITLE ? SITE_TITLE : `${title} | ${SITE_TITLE}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />

		<style is:inline>
			* {
				box-sizing: border-box;
			}
			*:before,
			*:after {
				box-sizing: inherit;
			}

			:root,
			html {
				--main: rgb(255, 255, 255);
				--text: rgb(32, 33, 36);
				--primary: rgb(0, 128, 128);
				--secondary: rgb(50, 140, 180);
				--tertiary: rgb(245, 250, 252);
				--dropdown: rgb(from var(--tertiary, var(--tertiary)) r g b / 0.75);
				--other: rgb(180, 40, 120);
				--other2: rgb(0, 128, 128);
				--accent: rgb(182, 193, 210);
				--border: rgba(182, 193, 210, 0.25);
				--border2: rgba(0, 130, 145, 0.25);
				--link: rgb(188, 122, 0);
				--bq-link: rgb(255, 75, 0);
				--hover: rgb(220, 90, 20);
				--tags: rgb(0, 128, 128);
				--emphasis: rgb(0, 0, 0);
				--name: rgb(0, 128, 128);
				--date: rgb(0, 128, 128);
				--form: rgb(32, 33, 36);
				--blockquote: rgb(250, 248, 245);
				--info: rgb(200, 140, 0);
				--info-text: rgb(100, 70, 0);
				--info-bg: rgb(from var(--info, var(--info)) r g b / 0.1);
				--inactive: rgb(164, 174, 188);
				--warning: rgb(255, 45, 50);
				--warning-text: rgb(180, 0, 0);
				--warning-bg: rgb(from var(--warning, var(--warning)) r g b / 0.08);
				--warning-link: rgb(0, 110, 130);
				--warning-hover: rgb(220, 90, 20);
				--code-bg: rgb(240, 242, 245);
				--code-bg-bq: rgb(235, 237, 240);
				--code-text: hsl(220, 13%, 18%);
				--foot-link: rgb(0, 128, 128);
				--foot-hover: rgb(220, 90, 20);
				/* SVG FILTERS */
				--svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--svg2: brightness(0) saturate(100%) invert(50%) sepia(21%) saturate(1315%) hue-rotate(153deg) brightness(93%) contrast(91%);
				--svg-hover: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--toc: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--ext: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--search: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--info-svg: brightness(0) saturate(100%) invert(77%) sepia(98%) saturate(1742%)
					hue-rotate(350deg) brightness(96%) contrast(95%);
				--share: brightness(0) saturate(100%) invert(74%) sepia(77%) saturate(474%)
					hue-rotate(356deg) brightness(104%) contrast(90%);
				--coffee-hover: brightness(0) saturate(100%) invert(45%) sepia(98%)
					saturate(1756%) hue-rotate(7deg) brightness(89%) contrast(92%);
				--time-svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--clock-svg: brightness(0) saturate(100%) invert(50%) sepia(21%) saturate(1315%) hue-rotate(153deg) brightness(93%) contrast(91%);
				--lifestream: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--controller: brightness(0) saturate(100%) invert(46%) sepia(12%)
					saturate(386%) hue-rotate(169deg) brightness(93%) contrast(92%);
				--foot-svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--foot-ext: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--game-platform: brightness(0) saturate(100%);
				scroll-behavior: smooth;
			}

			code[class*='language-'],
			pre[class*='language-'] {
				color-scheme: light;
			}

			@media (prefers-color-scheme: dark) {
				html:not(.light) {
					--main: rgb(32, 33, 36);
					--text: rgb(164, 174, 188);
					--primary: rgb(110, 198, 186);
					--secondary: rgb(95, 193, 232);
					--tertiary: rgb(12, 22, 32);
					--dropdown: rgb(from var(--tertiary, var(--tertiary)) r g b / 0.75);
					--other: rgb(255, 175, 225);
					--other2: rgb(255, 255, 255);
					--accent: rgb(51, 65, 85);
					--border: rgba(182, 193, 210, 0.25);
					--border2: rgb(90, 194, 175, 0.25);
					--link: rgb(255, 221, 0);
					--bq-link: rgb(255, 221, 0);
					--hover: rgb(249, 115, 22);
					--tags: rgb(255, 221, 0);
					--emphasis: rgb(255, 255, 255);
					--name: rgb(0, 158, 170);
					--date: rgb(110, 198, 186);
					--form: rgb(250, 250, 250);
					--blockquote: rgb(25, 22, 22);
					--info: rgb(255, 221, 0);
					--info-text: rgb(187, 188, 164);
					--info-bg: rgb(from var(--info, var(--info)) r g b / 0.05);
					--inactive: rgb(164, 174, 188);
					--warning: rgb(255, 45, 50);
					--warning-text: rgb(250, 200, 200);
					--warning-bg: rgb(from var(--warning, var(--warning)) r g b / 0.075);
					--warning-link: rgb(255, 221, 0);
					--warning-hover: rgb(249, 115, 22);
					--code-bg: rgb(40, 44, 52);
					--code-bg-bq: rgb(60, 60, 60);
					--code-text: rgb(255, 255, 255);
					--pagefind-ui-text: rgb(164, 174, 188);
					--pagefind-ui-background: rgb(51, 65, 85);
					/* SVG FILTERS */
					--svg: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
						brightness(148%) contrast(96%);
					--svg2: brightness(0) saturate(100%) invert(72%) sepia(10%) saturate(3204%)
						hue-rotate(169deg) brightness(104%) contrast(82%);
					--svg-hover: brightness(0) saturate(100%) invert(55%) sepia(24%)
						saturate(6501%) hue-rotate(352deg) brightness(101%) contrast(95%);
					--toc: brightness(0) saturate(100%) invert(68%) sepia(15%) saturate(1141%)
						hue-rotate(119deg) brightness(97%) contrast(92%);
					--ext: brightness(0) saturate(100%) invert(88%) sepia(9%) saturate(2244%)
						hue-rotate(108deg) brightness(82%) contrast(81%);
					--search: invert(57%) sepia(86%) saturate(3921%) hue-rotate(13deg)
						brightness(99%) contrast(100%);
					--info-svg: brightness(0) saturate(100%) invert(80%) sepia(82%) saturate(863%)
						hue-rotate(336deg) brightness(105%) contrast(90%);
					--share: brightness(0) saturate(100%) invert(77%) sepia(98%) saturate(1742%)
						hue-rotate(350deg) brightness(96%) contrast(95%);
					--coffee-hover: brightness(0) saturate(100%) invert(43%) sepia(96%)
						saturate(937%) hue-rotate(352deg) brightness(101%) contrast(95%);
					--time-svg: brightness(0) saturate(100%) invert(68%) sepia(15%)
						saturate(1141%) hue-rotate(119deg) brightness(97%) contrast(92%);
					--clock-svg: brightness(0) saturate(100%) invert(64%) sepia(80%)
						saturate(281%) hue-rotate(154deg) brightness(92%) contrast(98%);
					--lifestream: brightness(0) saturate(100%) invert(83%) sepia(27%)
						saturate(715%) hue-rotate(112deg) brightness(81%) contrast(86%);
					--controller: brightness(0) saturate(100%) invert(75%) sepia(15%)
						saturate(240%) hue-rotate(176deg) brightness(89%) contrast(91%);
					--foot-svg: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
						brightness(148%) contrast(96%);
					--foot-ext: brightness(0) saturate(100%) invert(88%) sepia(9%) saturate(2244%)
						hue-rotate(108deg) brightness(82%) contrast(81%);
					--game-platform: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
						brightness(148%) contrast(96%);
					--foot-link: rgb(255, 255, 255);
					--foot-hover: rgb(110, 198, 186);
				}

				code[class*='language-'],
				pre[class*='language-'] {
					color-scheme: dark;
				}
			}
			html.light {
				--main: rgb(255, 255, 255);
				--text: rgb(32, 33, 36);
				--primary: rgb(0, 128, 128);
				--secondary: rgb(50, 140, 180);
				--tertiary: rgb(245, 250, 252);
				--dropdown: rgb(from var(--tertiary, var(--tertiary)) r g b / 0.75);
				--other: rgb(180, 40, 120);
				--other2: rgb(0, 128, 128);
				--accent: rgb(182, 193, 210);
				--border: rgba(182, 193, 210, 0.25);
				--border2: rgba(0, 130, 145, 0.25);
				--link: rgb(188, 122, 0);
				--bq-link: rgb(255, 75, 0);
				--hover: rgb(220, 90, 20);
				--tags: rgb(0, 128, 128);
				--emphasis: rgb(0, 0, 0);
				--name: rgb(0, 128, 128);
				--date: rgb(0, 128, 128);
				--form: rgb(32, 33, 36);
				--blockquote: rgb(250, 248, 245);
				--info: rgb(200, 140, 0);
				--info-text: rgb(100, 70, 0);
				--info-bg: rgb(from var(--info, var(--info)) r g b / 0.1);
				--inactive: rgb(164, 174, 188);
				--warning: rgb(255, 45, 50);
				--warning-text: rgb(180, 0, 0);
				--warning-bg: rgb(from var(--warning, var(--warning)) r g b / 0.08);
				--warning-link: rgb(0, 110, 130);      /* dark cyan */
				--warning-hover: rgb(220, 90, 20);     /* orange */
				--code-bg: rgb(240, 242, 245);
				--code-bg-bq: rgb(235, 237, 240);
				--code-text: hsl(220, 13%, 18%);
				--foot-link: rgb(0, 128, 128);
				--foot-hover: rgb(220, 90, 20);
				/* SVG FILTERS */
				--svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--svg2: brightness(0) saturate(100%) invert(50%) sepia(21%) saturate(1315%) hue-rotate(153deg) brightness(93%) contrast(91%);
				--svg-hover: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--toc: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--ext: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--search: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--info-svg: brightness(0) saturate(100%) invert(77%) sepia(98%) saturate(1742%)
					hue-rotate(350deg) brightness(96%) contrast(95%);
				--share: brightness(0) saturate(100%) invert(74%) sepia(77%) saturate(474%)
					hue-rotate(356deg) brightness(104%) contrast(90%);
				--coffee-hover: brightness(0) saturate(100%) invert(45%) sepia(98%)
					saturate(1756%) hue-rotate(7deg) brightness(89%) contrast(92%);
				--time-svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--clock-svg: brightness(0) saturate(100%) invert(50%) sepia(21%) saturate(1315%) hue-rotate(153deg) brightness(93%) contrast(91%);
				--lifestream: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--controller: brightness(0) saturate(100%) invert(46%) sepia(12%)
					saturate(386%) hue-rotate(169deg) brightness(93%) contrast(92%);
				--foot-svg: brightness(0) saturate(100%) invert(27%) sepia(88%) saturate(2161%) hue-rotate(162deg) brightness(86%) contrast(101%);
				--foot-ext: brightness(0) saturate(100%) invert(43%) sepia(96%) saturate(2262%) hue-rotate(354deg) brightness(89%) contrast(93%);
				--game-platform: brightness(0) saturate(100%);
			}

			html.light code[class*='language-'],
			html.light pre[class*='language-'] {
				color-scheme: light;
			}

			html.dark {
				--main: rgb(32, 33, 36);
				--text: rgb(164, 174, 188);
				--primary: rgb(110, 198, 186);
				--secondary: rgb(95, 193, 232);
				--tertiary: rgb(0, 8, 16);
				--dropdown: rgb(from var(--tertiary, var(--tertiary)) r g b / 0.75);
				--other: rgb(255, 175, 225);
				--other2: rgb(255, 255, 255); 
				--accent: rgb(51, 65, 85);
				--border: rgba(182, 193, 210, 0.25);
				--border2: rgb(90, 194, 175, 0.25);
				--link: rgb(255, 221, 0);
				--bq-link: rgb(255, 221, 0);
				--hover: rgb(249, 115, 22);
				--tags: rgb(255, 221, 0);
				--emphasis: rgb(255, 255, 255);
				--name: rgb(0, 158, 170);
				--date: rgb(110, 198, 186);
				--form: rgb(250, 250, 250);
				--blockquote: rgb(25, 22, 22);
				--info: rgb(255, 221, 0);
				--info-text: rgb(187, 188, 164);
				--info-bg: rgb(from var(--info, var(--info)) r g b / 0.05);
				--inactive: rgb(164, 174, 188);
				--warning: rgb(255, 45, 50);
				--warning-text: rgb(250, 200, 200);
				--warning-bg: rgb(from var(--warning, var(--warning)) r g b / 0.075);
				--warning-link: rgb(255, 221, 0);
				--warning-hover: rgb(249, 115, 22);
				--code-bg: rgb(40, 44, 52);
				--code-bg-bq: rgb(60, 60, 60);
				--code-text: rgb(255, 255, 255);
				--pagefind-ui-text: rgb(164, 174, 188);
				--pagefind-ui-background: rgb(51, 65, 85);
				--svg: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
					brightness(148%) contrast(96%);
				--svg2: brightness(0) saturate(100%) invert(72%) sepia(10%) saturate(3204%)
					hue-rotate(169deg) brightness(104%) contrast(82%);
				--svg-hover: brightness(0) saturate(100%) invert(55%) sepia(24%)
					saturate(6501%) hue-rotate(352deg) brightness(101%) contrast(95%);
				--toc: brightness(0) saturate(100%) invert(68%) sepia(15%) saturate(1141%)
					hue-rotate(119deg) brightness(97%) contrast(92%);
				--ext: brightness(0) saturate(100%) invert(88%) sepia(9%) saturate(2244%)
					hue-rotate(108deg) brightness(82%) contrast(81%);
				--search: invert(57%) sepia(86%) saturate(3921%) hue-rotate(13deg)
					brightness(99%) contrast(100%);
				--info-svg: brightness(0) saturate(100%) invert(80%) sepia(82%) saturate(863%)
					hue-rotate(336deg) brightness(105%) contrast(90%);
				--share: brightness(0) saturate(100%) invert(77%) sepia(98%) saturate(1742%)
					hue-rotate(350deg) brightness(96%) contrast(95%);
				--coffee-hover: brightness(0) saturate(100%) invert(43%) sepia(96%)
					saturate(937%) hue-rotate(352deg) brightness(101%) contrast(95%);
				--time-svg: brightness(0) saturate(100%) invert(68%) sepia(15%) saturate(1141%)
					hue-rotate(119deg) brightness(97%) contrast(92%);
				--clock-svg: brightness(0) saturate(100%) invert(64%) sepia(80%) saturate(281%)
					hue-rotate(154deg) brightness(92%) contrast(98%);
				--lifestream: brightness(0) saturate(100%) invert(83%) sepia(27%)
					saturate(715%) hue-rotate(112deg) brightness(81%) contrast(86%);
				--controller: brightness(0) saturate(100%) invert(75%) sepia(15%)
					saturate(240%) hue-rotate(176deg) brightness(89%) contrast(91%);
				--foot-svg: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
					brightness(148%) contrast(96%);
				--foot-ext: brightness(0) saturate(100%) invert(88%) sepia(9%) saturate(2244%)
					hue-rotate(108deg) brightness(82%) contrast(81%);
				--game-platform: invert(93%) sepia(78%) saturate(2834%) hue-rotate(213deg)
					brightness(148%) contrast(96%);
				--foot-link: rgb(255, 255, 255);
				--foot-hover: rgb(110, 198, 186);
			}

			html.dark code[class*='language-'],
			html.dark pre[class*='language-'] {
				color-scheme: dark;
			}

			body {
				font-size: 24px;
				font-family: var(--main-font);
				line-height: 1.4;
				margin: auto;
				padding: 0;
				text-align: left;
				word-wrap: break-word;
				overflow-wrap: break-word;
				color: var(--text);
				background: var(--main);
				height: 100%;
				-moz-osx-font-smoothing: antialiased;
				-webkit-font-smoothing: antialiased;
				-webkit-tap-highlight-color: rgba(0, 0, 0, 0);
				font-variant-ligatures: no-common-ligatures;
				overflow-y: scroll;
				overflow-x: hidden;
				max-width: 100vw;
				min-height: 100dvh;
				display: grid;
				grid-template-rows: auto 1fr auto;
			}
			body > header,
			body > footer {
				width: 100%;
			}
			body > header,
			body > main,
			body > footer {
				min-width: 0;
				width: 100%;
			}
		</style>

		<script is:inline>
			const savedTheme = localStorage.getItem('theme');
			const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			
			if (savedTheme === 'dark') {
				document.documentElement.classList.add('dark');
			} else if (savedTheme === 'light') {
				document.documentElement.classList.add('light');
			} else if (systemPrefersDark) {
				document.documentElement.classList.add('dark');
			}
		</script>
		
		<BaseHead title={pageTitle} description={description} ogType={ogType} ogImage={ogImage} />
		<WebsiteSchema />
		<slot name="head" />
		
		<style>
			main {
				margin: 0 auto;
				padding: 0;
				animation: 0.25s fade-in;
			}
			@media screen and (max-width: 1292px) {
				main {
					padding: 0 0.25em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<slot>
				<p>
					If you're seeing this, something went wrong! Please try <em>reloading the page</em>.
				</p>
			</slot>
		</main>
		<Footer />

		<!-- Track outbound links w/ Umami -->
		<script is:inline type="text/javascript">
			(() => {
				const name = 'outbound-link-click';
				document.querySelectorAll('a').forEach(a => {
				if (a.host !== window.location.host && !a.getAttribute('data-umami-event')) {
					a.setAttribute('data-umami-event', name);
					a.setAttribute('data-umami-event-url', a.href);
				}
				});
			})();
		</script>
	</body>
</html>
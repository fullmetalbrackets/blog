---
import BaseLayout from "@layouts/BaseLayout.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CodeblockCopy from "@components/CodeblockCopy.astro";
import HeadingCopy from "@components/HeadingCopy.astro";
import { SITE_URL } from "@consts";

const { frontmatter } = Astro.props;
const showTop = frontmatter.showTop !== false;

const currentPath = Astro.url.pathname;

const crumbs = [
  { name: "Home", url: `${SITE_URL}` },
  { name: frontmatter.title, url: `${SITE_URL}${currentPath}` }
];

const schemaType = frontmatter.schemaType ?? "WebPage";

const schema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  "@id": `${SITE_URL}${currentPath}#page`,
  "name": frontmatter.title,
  "description": frontmatter.description,
  "url": `${SITE_URL}${currentPath}`,
  "inLanguage": "en-US",
  "isPartOf": {
    "@id": `${SITE_URL}/#website`
  },
  "author": {
    "@id": `${SITE_URL}/#person`
  }
};
---

<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
    margin: 1.175em auto 0 auto;
    line-height: 1.1;
    max-width: 1200px;
  }
  hr {
    margin-top: 0.75em;
  }
  .desc {
    margin-top: -0.1em;
    margin-bottom: 2em;
    font-size: 1em;
  }
  article {
    margin: 2em 0.5em;
    min-height: 80dvh;
  }
  .content {
    margin: 0 auto;
    max-width: 1000px;
  }
  .bottom-line {
    margin: 2em auto 1.5em auto;
  }
  .years {
    margin: 1em auto;
  }
  @media screen and (max-width: 667px) {
    article {
      margin-top: 0.85em;
      margin-right: 0.5em;
      margin-left: 0.5em;
    }
    h1 {
      margin: 0.75em 0 -0.125em 0;
    }
    .desc {
      margin-top: -0.05em;
      font-size: 18px;
    }
  }
</style>

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <BreadcrumbSchema slot="head" crumbs={crumbs} />
  <Fragment slot="head" set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  <link rel="stylesheet" href="/prism.css" slot="head" />
  <CodeblockCopy />
  <HeadingCopy />

  <article data-pagefind-body>
    <h1>{frontmatter.title}</h1>
    <hr />
    <p class="desc">
      {frontmatter.description}
    </p>
    <div class="content">
      <slot>
        <p>
          If you're seeing this, something went wrong! Please try <em
            >reloading the page</em
          >.
        </p>
      </slot>
    </div>
  </article>
    {showTop && 
      <hr class="bottom-line" />
      <BackToTop />
    }
  <script is:inline>
    document.querySelectorAll('blockquote').forEach((blockquote) => {
      const firstPara = blockquote.querySelector('p');
      if (firstPara) {
        const text = firstPara.textContent || '';
        const match = text.match(/^\[(\w+)\]\s*/);
        
        if (match) {
          const type = match[1];
          blockquote.setAttribute('data-type', type);
          blockquote.classList.add(`blockquote-${type}`);
          
          const textNode = firstPara.firstChild;
          if (textNode && textNode.nodeType === Node.TEXT_NODE && textNode.textContent) {
            textNode.textContent = textNode.textContent.replace(/^\[(\w+)\]\s*/, '');
          }
        }
      }
    });

    const article = document.querySelector('article');
    if (article) {
      const hr = article.querySelector('hr');
      const description = article.querySelector('.description');
      
      if (hr && description) {
        let tocElement = description.nextElementSibling;

        if (tocElement) {
          const firstContentElement = tocElement.nextElementSibling;

          if (firstContentElement && 
              firstContentElement.tagName === 'BLOCKQUOTE' &&
              firstContentElement.getAttribute('data-type') === 'warning') {
            hr.parentNode.insertBefore(firstContentElement, hr.nextSibling);
          }
        }
      }
    }
  </script>
</BaseLayout>

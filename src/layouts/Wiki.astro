---
import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import ScrollProgress from "@components/ScrollProgress.astro";
import WikiArticle from "@components/WikiArticle.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CodeblockCopy from "@components/CodeblockCopy.astro";
import HeadingCopy from "@components/HeadingCopy.astro";
import Related from '@icons/related.svg';
import { getRelatedPosts } from '@utils/collections';
import { SITE_URL } from "@consts";

const { title, description, tag, pubDate, updatedDate, related } = Astro.props;
const { slug } = Astro.params;
const selectedPosts = await getRelatedPosts(related ?? []);
const relatedLinks = selectedPosts.map(p => `${SITE_URL}/blog/${p.id}`);
---

<style>
  .wiki-article {
    margin: 1em 0.5em;
  }
  .wiki-title {
    margin: 1.15em 0 0.2em 0;
  }
  .wiki-hr {
    margin-top: 1em;
  }
  .wiki-article {
    margin-top: 2em;
  }
  .date {
    margin-top: 0.5em;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    align-items: center;
  }
  .last-updated-on {
    display: inline-flex;
    place-items: center;
    color: var(--emphasis);
    gap: 0.5em;
  }
  .last-updated-on span {
    font-size: 0.875em;
    font-family: var(--sub-font);
    font-weight: 700;
  }
  .tag {
    margin: -0.2em auto 0.3em auto;
  }
  .tag span {
    font-family: var(--sub-font);
    background-color: var(--info);
    color: #000;
    border: 0;
    border-radius: 0.25em;
    padding: 4px 8px;
    font-weight: 800;
    font-size: 0.75em;
  }
  .slot-content {
    margin: 0 auto;
    padding: 0;
    max-width: 1000px;
  }
  .bottom-line {
    margin: 2em auto 1.5em auto;
  }

  /* related posts  */
  .related {
    display: inline;
  }
  .related h3 {
    display: flex;
    place-items: center;
    font-size: 1.25em;
    color: var(--primary);
    margin: 1em 0 1em 0;
    border-top: transparent;
    border-left: transparent;
    border-right: transparent;
    border-bottom: thick dotted var(--border);
  }
  .related svg {
    filter: var(--toc);
    margin-left: -0.135em;
    margin-right: 0.1em;
  }
  .related ul {
    list-style-type: none;
    padding: 0;
  }
  .related li {
    border: 2px solid transparent;
    background-color: var(--blockquote);
    color: var(--emphasis);
    padding: 0.75em 1em 0.85em 1em;
    margin: 1em;
    border-radius: 0.5em;
  }
  .related li span {
    font-size: 1em;
    font-weight: 700;
    margin-bottom: 0;
    line-height: 1.2;
  }
  .related li p {
    color: var(--text);
    font-size: 0.875em;
    margin-top: 0.25em;
    margin-bottom: 0;
    line-height: 1.2;
  }
  .related li:hover {
    color: var(--hover);
    border: 2px solid var(--emphasis);
  }

  /*  wiki nav */

  a .nav-btn {
    place-items: center;
  }
  .wiki-nav {
    display: inline-flex;
    justify-content: space-between;
    font-size: 1.5em;
    margin: 0 auto 1em auto;
    padding: 0;
    width: 100%;
  }
  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    background: var(--primary);
    color: #000;
    border-radius: 0.375em;
    font-size: 0.5em;
    font-family: var(--sub-font);
    font-weight: 800;
    padding: 0.4em 0.75em;
    text-decoration: none;
    cursor: pointer;
    transition: background-color .15s ease-out;
  }
  .nav-btn:hover {
    background-color: var(--secondary);
    color: #000;
    transform: none;
    box-shadow: none;
  }
  .nav-btn svg {
    fill: currentColor;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }
  .nav-btn.back svg,
  .nav-btn.go-top svg {
    stroke: currentColor;
    stroke-width: 1.25;
  }
  .nav-btn.home svg {
    place-items: center;
    width: 20px;
    height: 20px;
  }
  .nav-btn span {
    place-items: center;
    padding-top: 2.5px;
  }


  /* wide-screen info & toc */
  @media screen and (min-width: 2108px) {
    .blog-tags, .info, .updated {
      position: absolute;
      left: 2em;
      width: 35%;
      max-width: 35%;
    }
    .blog-tags { top: 4.55em; }
    .info { top: 6em; }
    .updated { top: 7.55em; }
  }

  /* mobile info & toc */
  @media screen and (max-width: 667px) {
    .wiki-article {
      margin: 1em 0.5em;
    }
    .wiki-title {
      margin: 0;
    }
    .tag {
      margin: 0.5em auto;
    }
    .tag span {
      font-size: 14px;
    }
    .related li {
      font-size: 1em;
      line-height: 1.2;
      padding: 1em 1em 0.85em 1em;
      margin: 1em auto;
    }
    .related li p {
      margin-top: 0;
    }
    .hide {
      display: none;
    }
  }

  /* hover effects */
  @media (hover: hover) {
    .wiki-nav a:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      outline-offset: 1px;
    }
    .wiki-nav a {
      text-overflow: ellipsis;
      transition: all 0.1s ease-out;
      cursor: pointer;
    }
    .wiki-nav a:active,
    .wiki-nav a:focus {
      box-shadow: none;
      transform: translate(0px, 0px);
      background-color: var(--hover);
    }
  }
</style>

<BaseLayout title={title} description={description} ogType="article">
  <link rel="stylesheet" href="/prism.css" slot="head" />
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${ SITE_URL }/` },
    { name: "Wiki", url: `${ SITE_URL }/wiki` },
    { name: title, url: `${ SITE_URL }/wiki/${slug}` }
  ]} />
  <WikiArticle slot="head" title={title} description={description} slug={slug!} pubDate={pubDate} updatedDate={updatedDate} relatedLinks={relatedLinks} />
  <ScrollProgress />
  <CodeblockCopy />
  <HeadingCopy />

  <article class="h-entry wiki-article" data-pagefind-body>
    <h1 class="wiki-title">{title}</h1>
    <a class="u-url" href={`https://fullmetalbrackets.com/wiki/${slug}`} hidden>Permalink</a>
    <p class="tag" data-pagefind-ignore>
      <span data-pagefind-filter="tag">{tag}</span>
    </p>
    <div class="date">
      <FormattedDate date={pubDate} />
      {updatedDate && (
        <div class="last-updated-on">
          <span>Updated</span><FormattedDate date={updatedDate} />
        </div>
      )}
    </div>
    <hr class="wiki-hr" />
    <p>{description}</p>
    <div class="e-content slot-content">
      <slot>
        <p>
          If you're seeing this, something went wrong! Please try <em>reloading the page</em>.
        </p>
      </slot>
    </div>
    {selectedPosts.length > 0 && (
      <div class="related" data-pagefind-ignore>
        <h3><Related width={36} height={36} /> Related Blog Posts</h3>
        <ul>
          {selectedPosts.map(post => (
            <a href={`/blog/${post.id}`} rel="prefetch-intent" data-umami-event={`wiki-related-${post.id}`}>
              <li>
                <span>{post.data.title}</span>
                <p>{post.data.description}</p>
              </li>
            </a>
          ))}
        </ul>
      </div>
    )}
  </article>

  <hr class="bottom-line" />

  <nav class="wiki-nav" aria-label="Post navigation">
    <a href="/wiki" rel="prefetch-intent" class="nav-btn back" aria-label="Back to Wiki">
      <svg role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M14 7.5H3.439l4.29-4.387-.714-.699L1.55 8l5.465 5.586.714-.7L3.44 8.5h10.56v-1z" />
      </svg>
      <span>Wiki</span>
    </a>
    <a href="/" rel="prefetch-intent" class="nav-btn home" aria-label="Go to Home">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
      </svg>
      <span>Home</span>
    </a>
    <a href="#top" class="nav-btn go-top" aria-label="Back to top">
      <span>Top</span>
      <svg role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M7.5 14V3.439l-4.387 4.29-.699-.714L8 1.55l5.586 5.465-.7.714L8.5 3.44V14h-1z" />
      </svg>
    </a>
  </nav>

  <script is:inline>
    document.querySelectorAll('blockquote').forEach((blockquote) => {
      const firstPara = blockquote.querySelector('p');
      if (!firstPara) return;

      const match = (firstPara.textContent ?? '').match(/^\[(\w+)\]\s*/);
      if (!match) return;

      blockquote.setAttribute('data-type', match[1]);
      blockquote.classList.add(`blockquote-${match[1]}`);

      const textNode = firstPara.firstChild;
      if (textNode?.nodeType === Node.TEXT_NODE && textNode.textContent) {
        textNode.textContent = textNode.textContent.replace(/^\[(\w+)\]\s*/, '');
      }
    });
  </script>
</BaseLayout>

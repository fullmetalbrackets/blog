---
import { SITE_TITLE, SITE_URL, GITHUB, BLUESKY, MASTODON } from "@consts";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": SITE_TITLE,
  "url": SITE_URL,
  "author": {
    "@type": "Person",
    "name": "Ariel Diaz",
    "url": SITE_URL,
    "sameAs": [
      GITHUB,
      BLUESKY,
      MASTODON
    ]
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${ SITE_URL }/search/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, GITHUB, BLUESKY, MASTODON } from "@consts";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${SITE_URL}/#website`,
  "name": SITE_TITLE,
  "description": SITE_DESCRIPTION,
  "url": SITE_URL,
  "inLanguage": "en-US",
  "author": {
    "@id": `${SITE_URL}/#person`
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${SITE_URL}/search/?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
---
import Webmention from '@icons/webmention.svg';

const targetUrl = import.meta.env.DEV
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.href;
---

<section class="webmentions" aria-label="Webmentions">
  <h3><Webmention width={36} height={36} />ebmentions</h3>
  <div id="webmentions-container" data-target-url={targetUrl}>
    <p class="wm-loading">Loading mentions…</p>
  </div>
</section>

<div class="wm-submit">
  <form class="wm-form" id="wm-form">
    <label for="wm-source" class="wm-form-label">If you write a <a href="https://indieweb.org/responses" target="_blank" rel="noopener noreferrer">response</a> to this, submit your URL to let me know and have it appear here!</label>
    <div class="wm-form-row">
      <input
        type="url"
        id="wm-source"
        name="source"
        placeholder="https://your-site.com/your-post/"
        required
        class="wm-input"
      />
      <button type="submit" class="wm-submit-btn">Send</button>
    </div>
    <p class="wm-form-status" id="wm-status" aria-live="polite"></p>
  </form>
</div>

<style>
  h3 {
    display: flex;
    place-items: center;
    vertical-align: middle;
    font-size: 1.25em;
    color: var(--primary);
    margin: 0 0 1em 0;
    padding: 0;
    border-top: transparent;
    border-left: transparent;
    border-right: transparent;
    border-bottom: thick dotted var(--border);
  }
  h3 svg {
    display: flex;
    place-items: center;
    vertical-align: middle;
    filter: var(--toc);
    margin-bottom: 0.4em;
    margin-right: -0.15em;
  }
</style>

<style is:global>
  .webmentions {
    margin-top: 0;
  }
  .wm-heading {
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 1em;
  }

  /* states */
  .wm-loading,
  .wm-empty,
  .wm-error {
    font-family: var(--sub-font);
    font-style: italic;
    color: var(--text);
    opacity: 0.55;
    margin: 0;
    padding: 0.25em 0;
  }

  /* likes, boosts, replies)  */
  .wm-section {
    margin-bottom: 1em;
  }

  .wm-section:last-child {
    margin-bottom: 0;
  }

  .wm-section-label {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.8em;
    letter-spacing: 0.04em;
    color: var(--emphasis);
    opacity: 0.85;
    margin: 0 0 0.65em;
    padding: 0;
  }

  .wm-icon {
    font-style: normal;
    line-height: 1;
  }

  .wm-facepile {
    display: flex;
    flex-wrap: wrap;
    padding: 2px 0;
  }

  /* avatar  */
  .wm-avatar {
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    margin-left: -6px;
    transition: transform 0.15s ease;
    position: relative;
    z-index: 0;
    display: inline-block;
    line-height: 0;
  }

  .wm-avatar:first-child {
    margin-left: 0;
  }

  .wm-avatar:hover {
    transform: scale(1.2) translateY(-2px);
    z-index: 10;
  }

  .wm-avatar--sm {
    width: 60px;
    height: 60px;
    min-width: 60px;
    min-height: 60px;
  }

  .wm-avatar--md {
    width: 72px;
    height: 72px;
    min-width: 72px;
    min-height: 72px;
  }

  .wm-avatar--sm img,
  .wm-avatar--md img {
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    margin: 0;
  }

  /* Replies  */
  .wm-replies {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .wm-reply {
    display: flex;
    align-items: flex-start;
    gap: 0.75em;
  }

  .wm-reply .wm-avatar {
    margin-left: 0;
    border-color: transparent;
    flex-shrink: 0;
  }

  .wm-reply-body {
    flex: 1;
    border-radius: 0 0.5em 0.5em 0.5em;
    padding: 0 0.25em;
    min-width: 0;
  }

  .wm-reply-text {
    margin: 0 0 0.35em;
    line-height: 1.5;
    color: var(--text);
    word-break: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .wm-reply-meta {
    font-family: var(--sub-font);
    font-size: 0.8em;
    color: var(--link);
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .wm-reply-meta:hover {
    opacity: 1;
  }

  /* submission form  */
  .wm-submit {
    margin: 1em 0.5em 0 0.5em;
    padding-top: 1em;
    padding-bottom: 0.5em;
  }

  .wm-form-label {
    display: block;
    font-size: 0.75em;
    color: var(--emphasis);
    margin-bottom: 0.5em;
  }

  .wm-form-row {
    display: flex;
    gap: 0.5em;
  }

  .wm-input {
    flex: 1;
    background: var(--accent);
    color: var(--form);
    border-radius: 0.25em;
    padding: 4px 8px;
    width: auto;
    margin: 0;
    box-shadow: none;
  }

  .wm-input:focus {
    outline: none;
    box-shadow: 0 0 0 0.2rem var(--primary);
  }

  .wm-submit-btn {
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.8em;
    background: var(--info);
    color: #000;
    border: none;
    border-radius: 0.25em;
    padding: 4px 12px 3px 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease;
    place-items: center;
  }

  .wm-submit-btn:hover {
    background: var(--hover);
  }

  .wm-form-status {
    font-family: var(--sub-font);
    font-size: 0.8em;
    margin: 0.5em 0 0;
    min-height: 1.2em;
    opacity: 0.75;
  }

  @media screen and (max-width: 667px) {
    .webmentions {
      margin-top: 2.5em;
    }
  }
</style>

<script>
  import { loadWebmentions } from '@utils/webmentions';
  loadWebmentions();

  const form = document.getElementById('wm-form') as HTMLFormElement;
  const status = document.getElementById('wm-status') as HTMLParagraphElement;
  const targetUrl = (document.getElementById('webmentions-container') as HTMLElement)
    ?.dataset.targetUrl ?? window.location.href;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const source = (document.getElementById('wm-source') as HTMLInputElement).value.trim();
    if (!source) return;

    status.textContent = 'Sending...';

    try {
      const res = await fetch('https://webmention.io/fullmetalbrackets.com/webmention', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ source, target: targetUrl }),
      });

      if (res.ok) {
        status.textContent = '✓ Webmention submitted — thanks!';
        (form as HTMLFormElement).reset();
      } else {
        status.textContent = `Something went wrong (${res.status}). Check your URL and try again.`;
      }
    } catch {
      status.textContent = 'Could not submit — check your connection and try again.';
    }
  });
</script>
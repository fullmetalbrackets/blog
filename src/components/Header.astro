---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { Image } from 'astro:assets';
import Logo from '@img/assets/logo.avif';
import SearchOverlay from "./SearchOverlay.astro";
---

<style scoped>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--blockquote);
    margin: 0 auto;
    border-bottom: 1px solid var(--tertiary);
  }
  .skip-link {
    position: absolute;
    left: -9999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    z-index: 100;
  }
  .skip-link:focus {
    position: fixed;
    top: 0;
    left: 0;
    width: auto;
    height: auto;
    overflow: visible;
    background: var(--primary);
    color: var(--main);
    padding: 0.5em 1em;
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }
  nav {
    font-family: var(--sub-font);
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
    font-weight: 800;
    height: 1.75em;
  }
  nav a {
    color: var(--primary);
    text-decoration: none;
  }
  nav a:hover {
    color: var(--hover);
  }
  nav a.active:hover svg {
    animation: none;
  }
  nav a:focus-visible {
    outline: 2px solid var(--hover);
    outline-offset: 2px;
    border-radius: 2px;
  }
  nav a.active {
    color: var(--link);
  }
  .logo {
    display: flex;
    align-items: center;
    margin: 0 0 0 0.25em;
    padding: 0;
    font-weight: 900;
    color: var(--primary);
    background: linear-gradient(to right, var(--hover) 50%, var(--primary) 50%);
    background-size: 200% 100%;
    background-position: right;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: background-position 0.35s ease-in-out;
  }
  .logo:hover {
    background-position: left;
  }
  .logo img {
    margin: 0 0.25em 0 0;
    padding: 0;
    border: 0;
    transform: 0;
    transition: 0.25s ease-in;
  }
  .logo:hover img {
    animation: wiggle 0.25s ease-out;
  }
  .name {
    margin: 0;
    padding: 2px 0 0 0;
    font-size: 1.25em;
    color: var(--primary);
    border: 0;
  }
  .logo:hover .name {
    color: var(--hover);
    border: 0;
    transition: all .175s ease-out;
  }

  /* Desktop nav links */
  .nav-end {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.5em;
  }
  .nav-end svg {
    width: 20px;
    height: 20px;
  }
  .desktop-links {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }
  .desktop-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }
  .search {
    fill: var(--blockquote);
  }
  .nav-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: block;
  }

  /* Dropdown (desktop More menu) */
  .dropdown {
    position: relative;
    display: inline-block;
  }
  .dropdown-toggle {
    background: none;
    border: 2px solid transparent;
    color: var(--primary);
    cursor: pointer;
    font-family: var(--sub-font);
    font-size: 1em;
    font-weight: 800;
    padding: 0;
    margin-left: -0.1em;
  }
  .dropdown-toggle:active {
    color: var(--hover);
  }
  .dropdown-toggle:hover {
    color: var(--hover);
    transform: none;
    box-shadow: none;
  }
  .dropdown-toggle:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .dropdown-content {
    position: absolute;
    background-color: var(--dropdown);
    min-width: 180px;
    z-index: 1000;
    border-radius: 0 0 0.5em 0.5em;
    padding: 0;
    margin-top: 2px;
    margin-left: -0.5em;
    backdrop-filter: blur(0.2em);
    -webkit-backdrop-filter: blur(0.2em);
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s 0.25s;
    pointer-events: none;
    visibility: hidden;
    border-top: none;
    border-right: 1px solid var(--tertiary);
    border-left: 1px solid var(--tertiary);
    border-bottom: 1px solid var(--tertiary);
    max-height: calc(100vh - 4em);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: transparent transparent;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s 0.25s;
  }
  .dropdown-content::-webkit-scrollbar {
    width: 4px;
  }
  .dropdown-content::-webkit-scrollbar-thumb {
    background: transparent;
    border-radius: 2px;
    transition: background 0.5s ease;
  }
  .dropdown-content::-webkit-scrollbar-track {
    background: transparent;
  }
  .dropdown-content.scrollbar-visible {
    scrollbar-color: var(--border2) transparent;
  }
  .dropdown-content.scrollbar-visible::-webkit-scrollbar-thumb {
    background: var(--border2);
  }
  .dropdown-content a {
    color: var(--primary);
    padding: 0.25em;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4em;
    border: none;
  }
  .dropdown-content a:last-of-type {
    border-radius: 0 0 0.5em 0.5em;
  }
  .dropdown-content a:hover {
    background-color: rgb(from var(--accent, var(--accent)) r g b / 0.5);
    color: var(--hover);
    transition: none;
  }
  .dropdown-content a:hover:first-of-type {
    border-radius: 0;
  }
  .dropdown-content a:hover:last-of-type {
    border-radius: 0 0 0.5em 0.5em;
  }
  .dropdown.open .dropdown-content {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .dropdown.open .dropdown-toggle {
    color: var(--link);
  }
  .dropdown.open a.active {
    background-color: rgb(from var(--primary, var(--primary)) r g b / 0.1);
  }
  .dropdown.open a.active:hover {
    color: var(--link);
  }
  .chevron {
    display: inline-block;
    vertical-align: middle;
    transition: all .1s ease-in-out;
  }
  .chevron line {
    stroke-dasharray: 11;      /* length of the line (y: 15 → 4 = 11 units) */
    stroke-dashoffset: 11;     /* fully hidden by default */
    transition: stroke-dashoffset 0.1s ease-in-out;
  }
  .dropdown.open .chevron, .dropdown:hover .chevron {
    transform: translateY(4px);
  }
  .dropdown.open .chevron line, .dropdown:hover .chevron line {
    stroke-dashoffset: 0;
  }
  .nav-link svg {
    transition: 0.1s ease-in;
  }
  .nav-link:hover svg, .nav-link:focus svg, .nav-link:active svg, .dropdown-content a:hover svg {
    animation: wiggle 0.25s ease-out;
  }
  /* Mobile hamburger button */
  .hamburger {
    display: none;
    background: none;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: var(--primary);
  }
  .hamburger:hover {
    transform: none;
    box-shadow: none;
  }
  .hamburger:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .hamburger[aria-expanded="true"] {
    color: var(--link);
  }

  /* Mobile nav panel */
  .mobile-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    width: 50%;
    background: var(--dropdown);
    backdrop-filter: blur(0.2em);
    -webkit-backdrop-filter: blur(0.2em);
    border-bottom-right-radius: 0.5em;
    border-top: none;
    border-left: none;
    border-right: 1px solid var(--tertiary);
    border-bottom: 1px solid var(--tertiary);
    z-index: 49;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s 0.25s;
    pointer-events: none;
    visibility: hidden;
    padding: 0;
    scrollbar-width: thin;
    scrollbar-color: var(--tertiary) transparent;
    max-height: 70vh;
    overflow-y: auto;
    overflow: hidden;
    overscroll-behavior: contain;
  }
  .mobile-nav svg {
    width: 20px;
    height: 20px;
  }
  .mobile-nav a:active svg {
    transition: 0.125s ease-out;
    transform-origin: 50% 50%;
    transform: rotate(-25deg);
    color: var(--hover);
  }
  .mobile-nav a:active {
    transition: 0.125s ease-out;
    color: var(--hover);
  }
  .mobile-nav::-webkit-scrollbar {
    width: 4px;
  }
  .mobile-nav::-webkit-scrollbar-thumb {
    background: var(--border2);
    border-radius: 2px;
  }
  .mobile-nav::-webkit-scrollbar-track {
    background: transparent;
  }
  .mobile-nav.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .mobile-nav-grid {
    display: flex;
    flex-direction: column;
    gap: 1em;
    font-family: var(--sub-font);
    font-size: 0.75em;
    max-height: 70vh;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: thin;
    scrollbar-color: var(--border2) transparent;
    padding: 1em 1.25em 1.25em 1.25em;
  }
  .mobile-nav-grid::-webkit-scrollbar {
    width: 4px;
  }
  .mobile-nav-grid::-webkit-scrollbar-thumb {
    background: var(--border2);
    border-radius: 2px;
  }
  .mobile-nav-grid::-webkit-scrollbar-track {
    background: transparent;
  }
  .mobile-nav-grid.is-scrollable {
    overflow-y: scroll;
  }
  .mobile-nav-col h3 {
    font-size: 0.65em;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--primary);
    margin: 0 0 0.5em 0;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav-col {
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }
  .mobile-nav-col a {
    display: flex;
    align-items: center;
    gap: 0.4em;
    color: var(--emphasis);
    text-decoration: none;
    font-weight: 800;
  }
  .mobile-nav-col a:hover {
    color: var(--hover);
  }

  @media (hover: none) {
    .logo {
      transition: none;
      transform: none;
    }
    .logo:hover img {
      animation: none;
    }
    .nav-link a:hover,
    .nav-link a:active {
      color: var(--hover);
      transition: none;
      transform: none;
    }
  }

  @media screen and (max-width: 1024px) {
    .desktop-links {
      gap: 0.5em;
    }
  }
  
  @media screen and (max-width: 768px) {
    nav {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
    }
    .logo {
      justify-self: center;
    }
    .name {
      font-size: 0.875em;
    }
    .desktop-links {
      display: none;
    }
    .hamburger {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-right: 0;
      margin-right: -0.5em;
    }
    .mobile-nav {
      display: block;
    }
  }
</style>

<a href="#main-content" class="skip-link">Skip to main content</a>

<header>
  <nav aria-label="Main navigation">

    <!-- Mobile hamburger (left) -->
    <button class="hamburger" id="hamburger" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open navigation menu">
      <svg id="hamburger-svg" viewBox="0 0 44 44" width="32" height="32" fill="none">
        <path id="h1" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 14 L 38 14"/>
        <path id="h2" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 14 L 38 14"/>
        <path id="h3" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 22 L 38 22"/>
        <path id="h4" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 22 L 38 22"/>
        <path id="h5" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 30 L 38 30"/>
        <path id="h6" style="stroke:currentColor;stroke-width:2.5;stroke-linecap:round" d="M 6 30 L 38 30"/>
      </svg>
    </button>

    <!-- Logo + name -->
    <a href="/" rel="home" class="logo" aria-label="Fullmetalbrackets home">
      <Image src={Logo} alt="Logo" width={36} height={35} loading="eager" decoding="async" fetchpriority="high" />
      <span class="name" aria-label="home">Fullmetalbrackets</span>
    </a>

    <!-- Right side -->
    <div class="nav-end">

      <!-- Desktop links -->
      <div class="desktop-links">
        <HeaderLink href="/blog" rel="prefetch-intent archives" aria-label="Blog" class="nav-link blog-link" data-umami-event="nav-blog">
          <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><title>Blog</title><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Blog
        </HeaderLink>
        <HeaderLink href="/categories" rel="prefetch-intent" aria-label="Categories" class="nav-link" data-umami-event="nav-categories">
          <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Categories</title><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          Categories
        </HeaderLink>
        <div class="dropdown">
          <button class="dropdown-toggle" aria-expanded="false" aria-haspopup="true">
            More
            <svg class="chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>More</title>
            <polyline points="6 9 12 15 18 9"></polyline>
            <line x1="12" y1="15" x2="12" y2="4" />
          </svg>
          </button>
          <div class="dropdown-content">
            <HeaderLink href="/notes" rel="prefetch-intent" aria-label="Notes" data-umami-event="nav-notes">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Notes</title><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>
              Notes
            </HeaderLink>
            <HeaderLink href="/links" rel="prefetch-intent" aria-label="Links" data-umami-event="nav-links">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Links</title><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              Links
            </HeaderLink>
            <HeaderLink href="/blogroll" rel="prefetch-intent" aria-label="Blogroll" data-umami-event="nav-blogroll">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Blogroll</title><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
              Blogroll
            </HeaderLink>
            <HeaderLink href="/postroll" rel="prefetch-intent" aria-label="Postroll" data-umami-event="nav-postroll">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><title>Postroll</title><path d="M15,20A1,1 0 0,0 16,19V4H8A1,1 0 0,0 7,5V16H5V5A3,3 0 0,1 8,2H19A3,3 0 0,1 22,5V6H20V5A1,1 0 0,0 19,4A1,1 0 0,0 18,5V9L18,19A3,3 0 0,1 15,22H5A3,3 0 0,1 2,19V18H13A2,2 0 0,0 15,20M9,6H14V8H9V6M9,10H14V12H9V10M9,14H14V16H9V14Z" /></svg>
              Postroll
            </HeaderLink>
            <HeaderLink href="/lifestream" rel="prefetch-intent" aria-label="Lifestream" data-umami-event="nav-lifestream">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Lifestream</title><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Lifestream
            </HeaderLink>
            <HeaderLink href="/wiki" rel="prefetch-intent" aria-label="Wiki" data-umami-event="nav-wiki">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Wiki</title><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              Wiki
            </HeaderLink>
            <HeaderLink href="/now" rel="prefetch-intent" aria-label="Now" data-umami-event="nav-now">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Now</title><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Now
            </HeaderLink>
            <HeaderLink href="/all" rel="prefetch-intent" aria-label="All" data-umami-event="nav-all">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><title>All</title><path d="M18.6,6.62C17.16,6.62 15.8,7.18 14.83,8.15L7.8,14.39C7.16,15.03 6.31,15.38 5.4,15.38C3.53,15.38 2,13.87 2,12C2,10.13 3.53,8.62 5.4,8.62C6.31,8.62 7.16,8.97 7.84,9.65L8.97,10.65L10.5,9.31L9.22,8.2C8.2,7.18 6.84,6.62 5.4,6.62C2.42,6.62 0,9.04 0,12C0,14.96 2.42,17.38 5.4,17.38C6.84,17.38 8.2,16.82 9.17,15.85L16.2,9.61C16.84,8.97 17.69,8.62 18.6,8.62C20.47,8.62 22,10.13 22,12C22,13.87 20.47,15.38 18.6,15.38C17.7,15.38 16.84,15.03 16.16,14.35L15,13.34L13.5,14.68L14.78,15.8C15.8,16.81 17.15,17.37 18.6,17.37C21.58,17.37 24,14.96 24,12C24,9 21.58,6.62 18.6,6.62Z" /></svg>
              All
            </HeaderLink>
            <HeaderLink href="/self-hosted" rel="prefetch-intent" aria-label="Self-hosted" data-umami-event="nav-self-hosted">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Self-hosted</title><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
              Self-hosted
            </HeaderLink>
            <HeaderLink href="/games" rel="prefetch-intent" aria-label="Games" data-umami-event="nav-games">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Games</title><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><line x1="15" y1="13" x2="15.01" y2="13"/><line x1="18" y1="11" x2="18.01" y2="11"/></svg>
              Games
            </HeaderLink>
            <HeaderLink href="/uses" rel="prefetch-intent" aria-label="Uses" data-umami-event="nav-uses">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Uses</title><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              Uses
            </HeaderLink>
            <HeaderLink href="/verify" rel="prefetch-intent" aria-label="Verify" data-umami-event="nav-verify">
              <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>Verify</title><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              Verify

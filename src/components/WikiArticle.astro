---
import { SITE_URL } from "@consts";

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  updatedDate?: Date;
  relatedLinks?: string[];
}

const { title, description, slug, pubDate, updatedDate, relatedLinks } = Astro.props;

const pageUrl = `${SITE_URL}/wiki/${slug}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${pageUrl}#article`,
  "isPartOf": {
    "@type": "CollectionPage",
    "@id": `${SITE_URL}/wiki/#collection`
  },
  "headline": title,
  "description": description,
  "inLanguage": "en-US",
  "url": pageUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "author": {
    "@id": `${SITE_URL}/#person`
  },
  "publisher": {
    "@id": `${SITE_URL}/#person`
  },
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
  ...(relatedLinks && relatedLinks.length > 0 && { "relatedLink": relatedLinks }),
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
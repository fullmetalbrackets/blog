---
import { SITE_URL } from "@consts";

interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;

const pageUrl = `${SITE_URL}/wiki/${slug}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${pageUrl}#article`,
  "headline": title,
  "description": description,
  "inLanguage": "en-US",
  "url": pageUrl,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageUrl
  },
  "author": {
    "@id": `${SITE_URL}/#person`
  },
  "publisher": {
    "@id": `${SITE_URL}/#person`
  }
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
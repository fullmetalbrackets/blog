---
const today = new Date();
import Umami from '@icons/umami.svg';
import RSS from '@icons/rss.svg';
import JSON from '@icons/jsonfeed.svg';
import Email from '@icons/email.svg';
import Mastodon from '@icons/mastodon.svg';
import Bluesky from '@icons/bsky.svg';
import GitHub from '@icons/gh.svg';
import BuyMeCoffee from '@icons/bmc.svg';
import Random from '@icons/random.svg';
import LeftArrow from '@icons/arrow-left.svg';
import RightArrow from '@icons/arrow-right.svg';
import Proven from '@icons/proven.svg';
import { GITHUB, MASTODON, BLUESKY, DONATE } from '@consts';
---

<style>
  footer {
    background: var(--blockquote);
    margin: 0 auto;
    padding: 1.25em auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1em;
  }

  /* social icons  */
  .icons {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5em;
    margin: 1.25em auto 0 auto;
    padding: 0;
  }
  .icons a:hover {
    filter: var(--ext);
  }
  .icons svg {
    filter: var(--svg);
    border-radius: 0;
    transition: 0.25s ease-in-out;
  }
  .icons a:hover svg {
    animation: wiggle 0.25s ease-in-out;
  }
  svg.json {
    margin-bottom: 4px;
  }
  @media (hover: none) {
      .icons a:hover svg {
          animation: none;
      }
  }

  /* webrings container */
  .webrings-container {
    display: flex;
    justify-content: space-evenly;
    gap: 1em;
    align-items: flex-start;
    max-width: 480px;
    width: 100%;
  }
  h3.webrings-heading {
    font-size: 0.56em;
    font-family: var(--sub-font);    
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--foot-header);
    margin: 0 0 -1.25em 0;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
  }
  .webring {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    font-family: var(--sub-font);
    font-weight: 800;
    font-size: 0.75em;
  }
  .ring-title {
    color: var(--other2);
    text-decoration: none;
  }
  .ring-title:hover {
    color: var(--hover);
    transition: none;
  }
  .ring-buttons {
    display: flex;
    gap: 0.5em;
    margin-top: 0.5em;
    align-items: center;
    justify-content: center;
  }
  .ring-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    filter: var(--foot-svg);
    transition: filter 0.2s ease;
  }
  .ring-arrow:hover {
    filter: var(--foot-ext);
  }
  svg.random {
    transition: all .1s ease-in-out;
  }
  svg.random:hover {
    animation: wiggle 0.25s ease-in-out;
  }
  svg.right, svg.left {
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  svg.right:hover {
    filter: var(--foot-ext);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(5px);
  }
  svg.left:hover {
    filter: var(--foot-ext);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(-5px);
  }

  /* nav columns */
  h3 {
    font-family: var(--sub-font);
    font-size: 0.56em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--foot-header);
    margin: 0.2em auto -1.25em auto;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
  }
  .nav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.8em;
    width: 100%;
    box-sizing: border-box;
    max-width: 480px;
  }
  .nav-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.25em;
  }
  .nav-col h3 {
    font-size: 0.7em;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--foot-header);
    margin: 0 0 0.4em 0;
    padding-bottom: 0.3em;
    border-bottom: 1px solid var(--border);
  }
  .nav-col a {
    color: var(--foot-link);
    text-decoration: none;
    line-height: 1.4;
  }
  .nav-col a:hover {
    color: var(--hover);
    transition: none;
  }

  /* badges */
  .badges {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1em;
    flex-wrap: wrap;
  }
  .badges img {
    transition: 0.15s ease-in-out;
  }
  .badges img:hover {
    transform: scale(1.1);
    transition: 0.15s ease-in-out;
  }
  .proof {
    transition: 0.15s ease-in-out;
    filter: currentColor;
  }
  .proof:hover {
    transform: scale(1.25);
    transition: 0.15s ease-in-out;
  }

  /* legal */
  .bottom {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75em;
    font-size: 0.65em;
    max-width: 720px;
  }
  p.privacy {
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.65em;
    margin: -1em auto 0 auto;
    padding: 0;
  }

  /* mobile  */
  @media screen and (max-width: 667px) {
    .icons {
      gap: 0.7em;
      margin: 0 auto;
    }
    .bottom {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.4em;
    }
    .bottom .copyright {
      flex: 0 0 100%;
      text-align: center;
    }
    .dot {
      display: none;
    }
    .reserved {
      display: block;
      line-break: auto;
    }
    .webrings-container {
      gap: 1em;
    }
  }
</style>

<footer>
  <div class="icons">
    <a href="https://u.adiaz.fyi/share/TtTytHU8rJy0oEzN" target="_blank" rel="noopener noreferrer" data-umami-event="footer-umami">
      <Umami height={24} width={24} />
    </a>
    <a href="/rss.xml" target="_blank" rel="noopener noreferrer" data-umami-event="footer-rss">
      <RSS height={20} width={20} />
    </a>
    <a href="/feed.json" target="_blank" rel="noopender noreferrer" data-umami-event="footer-json">
      <JSON height={24} width={24} class="json" />
    </a>
    <a href="mailto:contact@fullmetalbrackets.com" data-umami-event="footer-mail">
      <Email height={28} width={28} />
    </a>
    <a href={MASTODON} rel="me noopener noreferrer" target="_blank" data-umami-event="footer-social">
      <Mastodon height={25} width={25} />
    </a>
    <a href={BLUESKY} rel="me atproto noopener noreferrer" target="_blank" data-umami-event="footer-bsky">
      <Bluesky height={25} width={25} />
    </a>
    <a href={GITHUB} rel="me noopener noreferrer" target="_blank" data-umami-event="footer-github">
      <GitHub height={25} width={25} />
    </a>
    <a href={DONATE} rel="noopener noreferrer" target="_blank" data-umami-event="footer-coffee">
      <BuyMeCoffee height={25} width={25} />
    </a>
  </div>

  <h3>Site Navigation</h3>
  <nav class="nav-grid" aria-label="Site navigation">
    <div class="nav-col">
      <a href="/blog" data-umami-event="footer-blog">Blog</a>
      <a href="/links" data-umami-event="footer-links">Links</a>
      <a href="/blogroll" data-umami-event="footer-blogroll">Blogroll</a>
      <a href="/postroll" data-umami-event="footer-postroll">Postroll</a>
      <a href="/notes" data-umami-event="footer-notes">Notes</a>
      <a href="/all" data-umami-event="footer-all">All</a>
    </div>
    <div class="nav-col">
      <a href="/now" data-umami-event="footer-now">Now</a>
      <a href="/wiki" data-umami-event="footer-wiki">Wiki</a>
      <a href="/lifestream" data-umami-event="footer-lifestream">Lifestream</a>
      <a href="/self-hosted" data-umami-event="footer-selfhosted">Self-hosted</a>
      <a href="/games" data-umami-event="footer-games">Games</a>
      <a href="/uses" data-umami-event="footer-uses">Uses</a>
    </div>
    <div class="nav-col">
      <a href="/stats" data-umami-event="footer-stats">Stats</a>
      <a href="/verify" data-umami-event="footer-verify">Verify</a>
      <a href="/colophon" data-umami-event="footer-colophon">Colophon</a>
      <a href="/changelog" data-umami-event="footer-changelog">Changelog</a>
      <a href="/explore" data-umami-event="footer-explore">Explore</a>
      <a href="/style" data-umami-event="footer-style">Style</a>
    </div>
  </nav>

  <h3 class="webrings-heading">Webrings</h3>
  <div class="webrings-container">
    <div class="webring">
      <a href="https://xn--sr8hvo.ws" target="_blank" rel="noopener noreferrer" class="ring-title">IndieWeb</a>
      <div class="ring-buttons">
        <a href="https://xn--sr8hvo.ws/previous" rel="previous" aria-label="Previous site"><LeftArrow height={24} width={24} class="ring-arrow left" /></a>
        <a href="https://xn--sr8hvo.ws/random" aria-label="Random site"><Random height={24} width={24} class="ring-arrow random" /></a>
        <a href="https://xn--sr8hvo.ws/next" rel="next" aria-label="Next site"><RightArrow height={24} width={24} class="ring-arrow right" /></a>
      </div>
    </div>

    <div class="webring">
      <a href="https://fediring.net" target="_blank" rel="noopener noreferrer" class="ring-title">Fediring</a>
      <div class="ring-buttons">
        <a href="https://fediring.net/previous?host=fullmetalbrackets.com" rel="previous" aria-label="Previous site"><LeftArrow height={24} width={24} class="ring-arrow left" /></a>
        <a href="https://fediring.net/random?host=fullmetalbrackets.com" aria-label="Random site"><Random height={24} width={24} class="ring-arrow random" /></a>
        <a href="https://fediring.net/next?host=fullmetalbrackets.com" rel="next" aria-label="Next site"><RightArrow height={24} width={24} class="ring-arrow right" /></a>
      </div>
    </div>

    <div class="webring">
      <a href="https://webri.ng/webring/cssjoy/" target="_blank" rel="noopener noreferrer" class="ring-title">CSS Joy</a>
      <div class="ring-buttons">
        <a href="https://webri.ng/webring/cssjoy/previous?via=https://fullmetalbrackets.com" rel="previous" aria-label="Previous site"><LeftArrow height={24} width={24} class="ring-arrow left" /></a>
        <a href="https://webri.ng/webring/cssjoy/random?via=https://fullmetalbrackets.com" aria-label="Random site"><Random height={24} width={24} class="ring-arrow random" /></a>
        <a href="https://webri.ng/webring/cssjoy/next?via=https://fullmetalbrackets.com" rel="next" aria-label="Next site"><RightArrow height={24} width={24} class="ring-arrow right" /></a>
      </div>
    </div>
  </div>

  <div class="badges">
    <a href="https://proven.lol/1a7300" target="_blank" rel="noopener noreferrer" data-umami-event="proof">
      <Proven height={32} width={32} class="proof" />
    </a>
    <a href="https://notbyai.fyi/" target="_blank" rel="noopener noreferrer" data-umami-event="notbyai">
      <picture>
        <source srcset="/assets/Written-By-a-Human-Not-By-AI-Badge-white.png" media="(prefers-color-scheme: light)">
        <source srcset="/assets/Written-By-a-Human-Not-By-AI-Badge-black.png" media="(prefers-color-scheme: dark)">
        <img src="/assets/Written-By-a-Human-Not-By-AI-Badge-white.png" alt="Written by a human, not AI" width="131" height="82" loading="lazy" decoding="async">
      </picture>
    </a>
    <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" data-umami-event="astro">
      <img src="/assets/built-with-astro.svg" alt="Built with Astro" width="192" height="32" loading="lazy" decoding="async">
    </a>
  </div>

  <div class="bottom">
    <span>Content: <a rel="license" href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" data-umami-event="footer-cc-by-nc-sa-4.0">CC BY-NC-SA 4.0</a></span>
    <span>·</span>
    <span>Code: <a href="https://mit-license.org" target="_blank" rel="noopener noreferrer" data-umami-event="footer-mit-license">MIT</a></span>
    <span class="dot">·</span>
    <span class="copyright">&copy; 2021-{today.getFullYear()} Ariel Diaz. <span class="reserved">Some rights reserved.</span></span>
  </div>
  <p class="privacy">
    <a href="/privacy" data-umami-event="footer-privacy">Privacy Policy</a>
  </p>
</footer>
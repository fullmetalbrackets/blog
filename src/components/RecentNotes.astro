---
import FormattedDate from "./FormattedDate.astro";
import More from '@icons/arrow-right.svg';
import { Image } from 'astro:assets';
import { YouTube } from 'astro-embed';
import { getSortedNotes } from '@utils/collections';

interface Props {
  limit?: number;
}

const { limit = 3 } = Astro.props;
const recentNotes = (await getSortedNotes()).slice(0, limit);
---

<section class="h-feed">
  <h2 class="p-name">Recent Notes</h2>
  <ul class="container">
    {recentNotes.map((note) => {
      const ytMatch = note.data.content?.match(
        /youtube\.com\/watch\?v=([a-zA-Z0-9_-]+)/
      );
      const ytId = ytMatch?.[1] ?? null;

      const imageUrl = note.data.image?.url ?? null;
      const altMatch = note.data.content?.match(/<img[^>]*alt="([^"]*)"[^>]*>/);
      const imageAlt = altMatch?.[1] ?? '';

      // Strip YouTube anchor links and standalone img tags —
      // we render both manually below so they're properly sized
      const cleanContent = note.data.content
        ?.replace(/<a[^>]*youtube\.com\/watch[^>]*>.*?<\/a>/g, '')
        ?.replace(/<img[^>]*>/g, '')
        .trim();

      const hasOnlyMedia = !cleanContent && (ytId || imageUrl);

      return (
        <li class="h-entry">
          <a
            class="u-uid u-url note-link"
            href={note.data.url}
            target="_blank"
            rel="noopener noreferrer"
            data-umami-event="recent-notes"
          >
            {ytId && (
              <div class="note-embed">
                <YouTube id={ytId} />
              </div>
            )}
            {!ytId && imageUrl && (
              <Image src={imageUrl} alt={imageAlt} class="note-image" inferSize={true} />
            )}
            {cleanContent && (
              <p class="note-content e-content" set:html={cleanContent} />
            )}
            <FormattedDate class="dt-published" date={new Date(note.data.published)} monthFormat="short" />
          </a>
        </li>
      );
    })}
  </ul>
  <span class="more">
    <a href="/notes/" rel="prefetch-intent archives" data-umami-event="home-notes">All Notes <More height={24} width={24} /></a>
  </span>
</section>

<style scoped>
  section {
    margin: 0 auto;
    padding: 0;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  ul {
    background-color: var(--blockquote);
    border-radius: 0.5em;
    margin: 0 auto;
    padding: 1.5em 1.5em 2.3em 1.5em;
  }
  li {
    display: inline-flex;
    flex-direction: column;
    margin: 0 auto;
    padding: 0;
    font-weight: bold;
    line-height: 1.1;
    padding-bottom: 1em;
  }
  li:last-of-type {
    padding-bottom: 0;
  }
  li a, li a:visited {
    color: var(--emphasis);
  }
  li a:hover {
    color: var(--hover);
  }

  /* Images */
  .note-image {
    width: 71%;
    height: auto;
    display: block;
    border-radius: 0.375em;
    margin-bottom: 0.25em;
  }

  /* YouTube embed wrapper — constrains the lite-youtube web component */
  .note-embed {
    width: 100%;
    border-radius: 0.375em;
    overflow: hidden;
    margin-bottom: 0.5em;
  }
  .note-embed :global(lite-youtube) {
    width: 100% !important;
    max-width: 100% !important;
    border-radius: 0.375em;
  }

  .more {
    display: flex;
    font-family: var(--sub-font);
    font-weight: 900;
    justify-content: end;
    margin-top: -2em;
    margin-right: 0.25em;
    padding: 0.25em;
  }
  .more svg {
    display: inline-flex;
    place-content: center;
    margin: 4px 0 -3px 0;
    padding: 0;
    filter: var(--svg2);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .more a {
    color: var(--secondary);
  }
  .more a:hover {
    color: var(--foot-link);
    transform: 0.2;
  }
  .more a:hover svg {
    filter: var(--foot-svg);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(4px);
  }

  @media screen and (max-width: 667px) {
    ul {
      padding: 1em 1em 2em 1em;
    }
    .note-image {
      width: 100%;
    }
    .more {
      margin-top: -2em;
    }
  }
</style>

<style is:global>
  li p {
    margin: 0;
    border-bottom: 4px dotted transparent;
  }
  li time {
    margin-bottom: 0.5em;
  }
</style>
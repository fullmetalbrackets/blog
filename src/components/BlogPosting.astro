---
import { SITE_URL } from '@consts';
import type { BlogData } from '../types';
type Props = BlogData & { slug: string };

const { title, description, pubDate, updatedDate, tags, slug } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${SITE_URL}/blog/${slug}/#blogposting`,
  "url": `${SITE_URL}/blog/${slug}`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}/blog/${slug}`
  },
  "headline": title,
  "description": description,
  "keywords": tags,
  "inLanguage": "en-US",
  "image": `${SITE_URL}/og/${slug}.png`,
  "author": {
    "@id": `${SITE_URL}/#person`
  },
  "publisher": {
    "@id": `${SITE_URL}/#person`
  },
  "datePublished": pubDate.toISOString(),
  ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
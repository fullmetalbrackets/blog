---
import type { BlogData } from '../types';
type Props = BlogData;

const { title, description, pubDate, updatedDate, tags } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "keywords": tags,
  "author": {
    "@type": "Person",
    "name": "Ariel Diaz",
    "url": "https://fullmetalbrackets.com"
  },
  "datePublished": pubDate.toISOString().substring(0, 10),
  ...(updatedDate && { "dateModified": updatedDate.toISOString().substring(0, 10) }),
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
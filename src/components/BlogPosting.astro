---
import { SITE_URL, AUTHOR } from '@consts';
import type { BlogData } from '../types';
type Props = BlogData & { slug: string; relatedLinks?: string[] };

const { title, description, pubDate, updatedDate, tags, slug, relatedLinks } =
  Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${SITE_URL}/blog/${slug}/#blogposting`,
  isPartOf: {
    '@type': 'Blog',
    '@id': `${SITE_URL}/blog/#collection`,
  },
  url: `${SITE_URL}/blog/${slug}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_URL}/blog/${slug}`,
  },
  headline: title,
  description: description,
  keywords: tags,
  inLanguage: 'en-US',
  image: `${SITE_URL}/og/${slug}.png`,
  author: {
    '@type': 'Person',
    '@id': `${SITE_URL}/#person`,
    name: AUTHOR,
  },
  publisher: {
    '@type': 'Person',
    '@id': `${SITE_URL}/#person`,
    name: AUTHOR,
  },
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  ...(relatedLinks && relatedLinks.length > 0 && { relatedLink: relatedLinks }),
};
---

<Fragment
  set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`}
/>

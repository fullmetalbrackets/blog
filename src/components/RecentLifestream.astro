---
import { getLifestream } from '@utils/collections';
import { Image } from 'astro:assets';
import FormattedDate from '@components/FormattedDate.astro';
import GameIcon from '@icons/game.svg';
import BookIcon from '@icons/book.svg';
import MovieIcon from '@icons/movie.svg';
import TVShowIcon from '@icons/tvshow.svg';
import More from '@icons/arrow-right.svg';

interface Props {
  limit?: number;
}

const { limit = 4 } = Astro.props;
const entries = (await getLifestream()).slice(0, limit);
---

<section class="h-feed">
  <h2 class="p-name">Recent Activity</h2>
    <div class="ls-grid">
      {entries.map((entry, i) => (
        <a class="card h-entry" href={`/lifestream/${entry.id}`} data-type={entry.data.type} data-umami-event={`recent-${entry.id}`}>
          <span class="p-name sr-only">{entry.data.title}</span>
          <Image
            class="u-photo"
            src={entry.data.image}
            alt={entry.data.title}
            widths={[200, 400, 600]}
            sizes="(max-width: 400px) 100vw, (max-width: 1024px) 50vw, 25vw"
            loading="lazy"
            decoding="async"
          />
          <span class="card-badge">
            {entry.data.type === 'game'   && <GameIcon   width={24} height={24} />}
            {entry.data.type === 'book'   && <BookIcon   width={24} height={24} />}
            {entry.data.type === 'movie'  && <MovieIcon  width={24} height={24} />}
            {entry.data.type === 'tvshow' && <TVShowIcon width={24} height={24} />}
          </span>
          <div class="card-overlay">
            <span class="date"><FormattedDate class="dt-published" date={entry.data.updatedDate ?? entry.data.pubDate} monthFormat="numeric" /></span>
          </div>
        </a>
      ))}
    </div>
    <span class="more">
        <a href="/lifestream/" rel="prefetch-intent archives">All Activity <More height={24} width={24} /></a>
    </span>
</section>

<style>
  section {
    margin: 0 auto;
    padding: 0 0 1em 0;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .ls-grid {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 0.6rem;
    max-width: auto;
    margin: 0 auto;
    background-color: var(--blockquote);
    border-radius: 0.5em;
    padding: 1.5em;
    padding-bottom: 3em;
  }
  .card {
    position: relative;
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--accent);
  }
  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
    margin: 0;
    max-width: 100%;
  }

  @media (hover: hover) {
    .card:hover {
      transform: scale(1.04);
    }
    .card:hover .card-overlay {
      opacity: 1;
    }
  }

  .card-badge {
    position: absolute;
    top: 0.3rem;
    left: 0.3rem;
    background: rgba(0, 0, 0, 0.65);
    border-radius: 0.2em;
    padding: 0.2em 0.25em;
    backdrop-filter: blur(4px);
    line-height: 1;
    display: flex;
    align-items: center;
  }

  /* badge icon: always white since it's over the image */
  .card-badge :global(svg) {
    filter: brightness(0) invert(1);
    display: block;
  }

  .card-vibe {
    position: absolute;
    bottom: 0.3rem;
    right: 0.3rem;
    font-size: 0.55em;
    border-radius: 0.2em;
    padding: 0.15em 0.35em;
    backdrop-filter: blur(4px);
    line-height: 1;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 0.5rem 0.4rem;
    opacity: 0;
    transition: opacity all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .card-overlay :global(time) {
    color: #fff;
    font-size: 0.45em;
  }

  .card-overlay :global(svg) {
    filter: brightness(0) invert(1);
    width: 16px;
    height: 16px;
  }

  .date {
    background: rgba(0, 0, 0, 0.65);
    border-radius: 0.2em;
    padding: 0.05em 0.325em 0 0.325em;
  }

  .more {
    display: flex;
    place-items: center;
    font-family: var(--sub-font);
    font-weight: 900;
    justify-content: end;
    margin: -2em 0.25em 0 0;
    padding: 0.25em;
  }
  .more svg {
    display: inline-flex;
    place-content: center;
    margin: 4px 0 -3px 0;
    padding: 0;
    filter: var(--svg2);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .more a {
    color: var(--secondary);
  }
  .more a:hover {
    color: var(--foot-link);
    transform: 0.2;
  }
  .more a:hover svg {
    filter: var(--foot-svg);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(4px);
  }
  
  @media (max-width: 1024px) { 
    .ls-grid { 
      grid-template-columns: repeat(2, 1fr);
      padding: 1em 1em 2.2em 1em; 
      gap: 1em;
    }
  }
  @media (max-width: 667px) {
    .desc, p {
      font-size: 18px;
    }
    .filters {
      margin: 1em auto;
      gap: 0.5em;
    }
  }
  @media (max-width: 640px) { 
    .ls-grid { 
      grid-template-columns: 1fr; 
      padding: 1em 1em 2.2em 1em; 
      gap: 1em;
    }
  }
</style>
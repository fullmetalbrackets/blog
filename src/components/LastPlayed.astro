---
import { Image } from 'astro:assets';
import LocalTime from "@components/LocalTime.astro";
import lastPlayed from '@data/last-played.json';

const { title, artist, album, year, albumArt, lastPlayed: playedAt } = lastPlayed;

const playedDate = new Date(playedAt);
---

<style scoped>
  section {
    margin: 1.25em auto 0.25em auto;
    padding: 0;
  }
  section:hover .art {
    transform: scale(1.1);
    transition: 0.15s ease-in-out;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .container {
    background-color: var(--blockquote);
    border-radius: 0.5em;
    margin: 0.5em auto 0 auto;
    padding: 1.5em 1.5em 0.85em 1.5em;
  }
  .track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1em;
    padding-bottom: 0.5em;
    border-bottom: 4px dotted transparent;
  }
  .art {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    object-fit: cover;
    display: block;
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .art-placeholder {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    border-radius: 0.25em;
    background: var(--border);
    opacity: 0.2;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2em;
  }
  .info {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    min-width: 0;
  }
  .song-title {
    font-weight: 900;
    color: var(--emphasis);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    overflow-wrap: break-word
  }
  .artist {
    font-size: 0.925em;
    line-height: 1.2;
    color: var(--secondary);
    overflow-wrap: break-word
  }
  .album {
    font-size: 0.85em;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    overflow-wrap: break-word
  }
  @media screen and (max-width: 667px) {
    section {
      margin: 1em auto 0 auto;
    }
    .container {
      padding: 1em 1em 0.25em 1em;
      font-size: 0.75em;
    }
    .art {
      width: 100px;
      height: 100px;
    }
    .art-placeholder {
      width: 100px;
      height: 100px;
    }
  }
</style>

<section>
  <div id="last-played" />
  <h2>Last Played</h2>
  <div class="container">
    <div class="track">
      {albumArt
        ? <Image class="art" src={albumArt} alt={`${album} cover`} width={72} height={72} loading="lazy" decoding="async" />
        : <div class="art-placeholder" aria-hidden="true">♪</div>
      }
      <div class="info">
        <span class="song-title">{title}</span>
        <span class="artist">{artist}</span>
        <span class="album">{album}{year ? ` (${year})` : ''}</span>
        <span class="date"><LocalTime date={playedDate} class="meta" /></span>
      </div>
    </div>
  </div>
</section>
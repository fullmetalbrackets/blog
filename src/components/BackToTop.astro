<style scoped>
    .page-nav {
      display: inline-flex;
      justify-content: space-between;
      font-size: 1.5em;
      margin: 0 auto 1em auto;
      padding: 0;
      width: 100%;
    }
    .nav-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.25em;
      background: var(--primary);
      color: #000;
      border-radius: 0.375em;
      font-size: 0.5em;
      font-weight: 700;
      padding: 0.4em 0.75em;
      text-decoration: none;
      cursor: pointer;
      transition: background-color .15s ease-out;
    }
    .nav-btn:hover {
      background-color: var(--secondary);
      color: #000;
      transform: none;
      box-shadow: none;
    }
    .nav-btn svg {
      fill: currentColor;
      flex-shrink: 0;
      width: 16px;
      height: 16px;
    }
    .home svg {
      width: 20px;
      height: 20px;
      margin-right: 0.25em;
    }
    .top svg {
      width: 16px;
      height: 16px;
      margin-left: 0.25em;
      stroke: currentColor;
      stroke-width: 1.25;
    }
    .nav-btn span {
      place-items: center;
      padding-top: 2.5px;
    }
    /* hover effects */
    @media (hover: hover) {
      .page-nav a:hover {
        box-shadow: -4px -4px 0 #000;
        transform: translate(4px, 4px);
        outline-offset: 1px;
      }
      .page-nav a {
        text-overflow: ellipsis;
        transition: all 0.1s ease-out;
        cursor: pointer;
      }
    }
    @media screen and (max-width: 1190px) {
        .nav-btn {
            margin-right: 0.25em;
        }
    }
</style>

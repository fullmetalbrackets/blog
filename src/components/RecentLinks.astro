---
import { getSortedLinks } from "@utils/collections";
import FormattedDate from "@components/FormattedDate.astro";
import More from '@icons/arrow-right.svg';

const links = await getSortedLinks();
---

<style scoped>
  section {
    margin: 0 auto;
    padding: 0;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .container {
    background-color: var(--blockquote);
    border-radius: 0.5em;
    margin: 0.5em auto 0 auto;
    padding: 1.5em 1.5em 0.5em 1.5em;
  }
  .info {
    display: flex;
    place-items: center;
    margin: 0.1em 0 0 0;
    padding: 0;
  }
  .info button {
    margin-right: 0.85em;
    font-size: 0.75em;
  }
  .list {
    display: flex;
    flex-direction: column;
    margin: 0 auto 0.25em auto;
    padding-bottom: 0.875em;
  }
  .link-url {
    color: var(--emphasis);
    font-weight: bold;
    line-height: 1.2;
  }
  .link-url:hover {
    color: var(--hover);
  }
  .link-tag {
    font-family: var(--sub-font);
    background-color: var(--info);
    color: #000;
    border: 0;
    border-radius: 0.25em;
    padding: 4px 8px;
    font-weight: 700;
    font-size: 0.625em;
    display: inline-block;
    transition: all 0.2s ease;
  }
  .more {
    display: flex;
    font-family: var(--sub-font);
    font-weight: 900;
    justify-content: end;
    margin: -0.5em -1.25em -0.5em 0;
    padding: 0.25em;
  }
  .more svg {
    display: inline-flex;
    place-content: center;
    margin: 4px 0 -3px 0;
    padding: 0;
    filter: var(--svg2);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .more a {
    color: var(--secondary);
  }
  .more a:hover {
    color: var(--foot-link);
    transform: 0.2;
  }
  .more a:hover svg {
    filter: var(--foot-svg);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(4px);
  }
  
  @media (hover: hover) {
    .list:has(.link-url:hover) .link-tag {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      outline-offset: 1px;
    }
  }
  
  @media screen and (max-width: 667px) {
    a.active {
      border-bottom: 1px dotted transparent;
    }
    .container {
      padding: 0.75em 1em 0.35em 1em;
    }
    .link-url {
      font-size: 0.875em;
    }
    .more {
      margin: -0.25em 0 0 0;
      padding: 0;
    }
    .info button {
      font-size: 14px;
    }
  }
</style>

<section class="h-feed">
  <h2 class="p-name">Recent Links</h2>
  <div class="container">
    {
      links.slice(0, 5).map((link) => (
        <div class="h-entry list">
          <a href={link.data.url} target="_blank" class="u-bookmark-of link-url" data-umami-event={`recent-link-${link.data.title}`}>
          <span class="p-name">
            {link.data.title}
          </span>
            <span class="info"><button>{link.data.tag}</button><FormattedDate class="dt-published" date={link.data.pubDate} />&nbsp;
          </span>
          </a>
        </div>
      ))
    }
    <span class="more">
      <a href="/links" rel="prefetch-intent archives" data-umami-event="home-links">All Links <More height={24} width={24} /></a>
    </span>
  </div>
</section>
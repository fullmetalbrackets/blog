---
import FormattedDate from './FormattedDate.astro';
import More from '@icons/arrow-right.svg';
import ReadingTime from '@components/ReadingTime.astro';
import { getPostsWithReadingTime } from '@utils/collections';
import popularSlugs from '@data/popular.json';
const { class: className, simple = false } = Astro.props;

interface Props {
  class?: string;
  simple?: boolean;
}

const allPosts = await getPostsWithReadingTime();
const selectedPosts = popularSlugs
  .slice(0, 5)
  .map((slug) => allPosts.find((post) => post.id === slug))
  .filter((post): post is NonNullable<typeof post> => post !== undefined);
---

<style scoped>
  section {
    margin: 0 auto;
    padding: 0;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  p {
    margin: 0;
  }
  span {
    line-height: 1.3;
  }
  .info {
    display: flex;
    place-items: center;
    margin: 0;
    padding: 0;
    gap: 0.25em;
  }
  .reading {
    margin: 0;
  }
  .tag {
    display: flex;
    place-items: center;
    margin: 0.25em 0;
  }
  .desc {
    line-height: 1.4;
  }
  .container {
    background-color: var(--blockquote);
    border-radius: 0.5em;
    margin: 0.5em auto 0 auto;
    padding-top: 1.5em;
    padding-left: 1.5em;
    padding-right: 1.5em;
  }
  .list {
    display: inline-flex;
    flex-direction: column;
    margin: 0 auto 1em auto;
    padding-bottom: 0.5em;
    line-height: 1.3;
    border-bottom: 4px dotted transparent;
  }
  .posts-title {
    display: inline-flex;
    flex-direction: row;
    margin: 0 auto;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .pop-index {
    padding-bottom: 0.75em;
  }
  .pop-404 {
    padding-bottom: 0;
  }
  .list--simple {
    margin: 0;
    border-bottom: 0;
  }
  .list--simple:last-of-type {
    margin-bottom: 1em;
  }
  .list--simple:hover {
    border-bottom: 0;
  }
  .posts-title--simple {
    font-size: 0.85em;
    margin-bottom: 0;
    font-weight: 400;
  }
  .footer {
    display: flex;
    justify-content: space-between;
    place-items: center;
    margin: 0.5em 0 -0.5em 0;
    padding: 0;
  }
  .has-tooltip {
    margin: 0 -1em 0.35em -1em;
    padding: 0;
  }
  .more {
    display: inline-flex;
    font-family: var(--sub-font);
    font-weight: 800;
    justify-content: end;
    margin: 0 -1em 0 0;
    padding: 0;
  }
  .more svg {
    display: inline-flex;
    place-content: center;
    margin: 4px 0 -3px 0;
    padding: 0;
    filter: var(--svg2);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .more a {
    color: var(--secondary);
  }
  .more a:hover {
    color: var(--foot-link);
  }
  .more a:hover svg {
    filter: var(--foot-svg);
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateX(4px);
  }
  @media (hover: hover) {
    .list:hover {
      padding-bottom: 0.5em;
      border-bottom: 4px dotted var(--hover);
      transition: all 0.25s ease-out;
    }
    .list:hover .posts-title {
      color: var(--hover);
      transition: all 0.25s ease-out;
    }
    .list:hover .btn {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      transition: all 0.1s ease-out;
      outline-offset: 1px;
    }
    .list:hover {
      padding-bottom: 0.5em;
      border-bottom: 4px dotted var(--hover);
      transition: all 0.25s ease-out;
    }
    .list--simple {
      margin-bottom: 0.5em;
      padding-bottom: 0;
      border-bottom: 0;
    }
    .list--simple:hover {
      padding-bottom: 0;
      border-bottom: 0;
    }
  }
  @media screen and (max-width: 667px) {
    main {
      margin: 0 10px;
    }
    .info {
      display: block;
      margin: 0.5em 0 0.25em 0;
    }
    .tag {
      display: block;
      margin: 0.1em 0 -0.2em 0;
    }
    .tag > .btn {
      margin-bottom: 0.2em;
    }
    .list {
      transition: none;
      border-bottom: 0;
      margin: 0 0 0.5em 0;
    }
    .list:last-of-type {
      margin: 0.25em;
    }
    .list:hover,
    .list:hover .posts-title {
      transition: none;
      border-bottom: 0;
    }
    .container {
      padding: 0.6em 1em 0 1em;
    }
    .posts-title {
      font-size: 0.875em;
    }
    .footer {
      margin: 0;
    }
    .has-tooltip {
      margin: 0 0 0 -0.5em;
      padding: 0 0 0.6em 0;
    }
    .more {
      margin: 0 -0.5em 0.25em 0;
    }
  }
</style>

<section class="h-feed">
  <div id="popular"></div>
  {!simple && <h2 class="p-name">Popular Posts</h2>}
  <div class={`container ${className ?? ''}`}>
    {
      selectedPosts.map((post) => (
        <div class:list={['h-entry list', { 'list--simple': simple }]}>
          <a
            class="u-url"
            href={`/blog/${post.id}`}
            rel="prefetch-intent"
            data-umami-event={`popular-${post.id}`}
          >
            <p
              class:list={[
                'p-name posts-title',
                { 'posts-title--simple': simple },
              ]}
            >
              {post.data.title}
            </p>
            {!simple && (
              <span class="tag">
                {post.data.tags.map((tag) => (
                  <span class="btn">{tag}</span>
                ))}
              </span>
            )}
            <p class="info">
              <FormattedDate
                class="dt-published"
                date={post.data.pubDate}
                monthFormat="short"
              />
              &nbsp;
              {!simple && (
                <span class="reading">
                  <ReadingTime time={post.readingTime} />
                </span>
              )}
            </p>
          </a>
        </div>
      ))
    }
    {
      !simple && (
        <div class="footer">
          <div class="has-tooltip">
            <button class="info-button" aria-label="Information">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                <line x1="12" y1="17" x2="12.01" y2="17" />
              </svg>
              <span class="tooltip">
                The most-read posts over the last 30 days, updated every Monday.
              </span>
            </button>
          </div>
          <span class="more">
            <a
              href="/blog/popular"
              rel="prefetch-intent archives"
              data-umami-event="home-popular"
            >
              More Popular Posts <More height={24} width={24} />
            </a>
          </span>
        </div>
      )
    }
  </div>
</section>

---
import FormattedDate from "./FormattedDate.astro";
import ReadingTime from "@components/ReadingTime.astro";
import { getPostsWithReadingTime } from '@utils/collections';
import popularSlugs from '@data/popular.json';
const { class: className, simple = false } = Astro.props;

interface Props {
  class?: string;
  simple?: boolean;
}

const allPosts = await getPostsWithReadingTime();
const selectedPosts = allPosts.filter(post => popularSlugs.includes(post.id));
---

<style scoped>
  section {
    margin: 0 auto;
    padding: 0;
  }
  h2 {
    margin-bottom: 0.3em;
    font-family: var(--sub-font);
    font-weight: 900;
  }
  p {
    margin: 0;
  }
  span {
    line-height: 1.3;
  }
  .info {
    display: flex;
    place-items: center;
    margin: 0;
    padding: 0;
    gap: 0.25em;
  }
  .reading {
    margin: 0;
  }
  .tag {
    display: flex;
    place-items: center;
    margin: 0.25em 0;
  }
  .tag button {
    background: var(--info);
    cursor: pointer;
  }
  button {
    background: var(--info);
    margin-right: 0.325em;
    cursor: pointer;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .desc {
    line-height: 1.4;
  }
  .container {
    background-color: var(--blockquote);
    border-radius: 0.5em;
    margin: 0.5em auto 0 auto;
    padding-top: 1.5em;
    padding-left: 1.5em;
    padding-right: 1.5em;
  }
  .list {
    display: inline-flex;
    flex-direction: column;
    margin: 0 auto 1em auto;
    padding-bottom: 0.5em;
    line-height: 1.3;
    border-bottom: 4px dotted transparent;
  }
  .list:hover {
    padding-bottom: 0.5em;
    border-bottom: 4px dotted var(--hover);
    transition: all .25s ease-out;
  }
  .list:hover .posts-title {
    color: var(--hover);    
    transition: all .25s ease-out;
  }
  .posts-title {
    display: inline-flex;
    flex-direction: row;
    margin: 0 auto;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .pop-index {
    padding-bottom: 2.35em;
  }
  .pop-404 {
    padding-bottom: 0;
  }
  .list--simple {
    margin: 0;
    border-bottom: 0;
  }
  .list--simple:last-of-type {
    margin-bottom: 1em;
  }
  .list--simple:hover {
    border-bottom: 0;
  }
  .posts-title--simple {
    font-size: 0.85em;
    margin-bottom: 0;
    font-weight: 400;
  }
  @media (hover: hover) {
    a:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    a:hover button {
      outline-offset: 1px;
    }
  }
  @media (hover: none) {
    a:hover button {
      background-color: var(--hover);
    }
  }
  @media screen and (max-width: 667px) {
    main {
      margin: 0 10px;
    }
    ul {
      padding: 1em 0.75em 0.5em 0.75em;
      width: 100%;
      margin: 0;
    }
    .info {
      display: block;
      margin: 0.5em 0 0.25em 0;
    }
    .tag {
      display: block;
      margin: 0.1em 0 0 0;
    }
    .tag button {
      margin: 0 0.45em 0 0;
      font-size: 14px;
    }
    .list {
      transition: none;
      border-bottom: 0;
      margin: 0 0 0.5em 0;
    }
    .list:last-of-type {
      margin: 0.25em;
    }
    .list:hover, .list:hover .posts-title {
      transition: none;
      border-bottom: 0;
    }
    .container {
      padding: 0.6em 1em 0 1em;
    }
    .posts-title {
      font-size: 0.875em;
    }
    .more {
      margin: 0;
      padding: 0;
    }
  }
</style>

<section class="h-feed">
  <div id="popular" />
  {!simple && <h2 class="p-name">Popular Posts</h2>}
  <div class={`container ${className ?? ''}`}>
    {selectedPosts.map(post => (
      <div class:list={["h-entry list", { "list--simple": simple }]}>
        <a class="u-url" href={`/blog/${post.id}`} rel="prefetch-intent" data-umami-event={`popular-${post.id}`}>
          <p class:list={["p-name posts-title", { "posts-title--simple": simple }]}>
            {post.data.title}
          </p>
          {!simple && (
            <span class="tag">
              {post.data.tags.map((tag) => (
                <button>{tag}</button>
              ))}
            </span>
          )}
            <p class="info">
              <FormattedDate class="dt-published" date={post.data.pubDate} monthFormat="short" />&nbsp;
            {!simple && (
              <span class="reading"><ReadingTime time={post.readingTime} /></span>
            )}
          </p>
        </a>
      </div>
    ))}
  </div>
</section>
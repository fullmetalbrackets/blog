---
import type { MarkdownHeading } from '@astrojs/markdown-remark';
import TOC from '@icons/toc.svg';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((heading) => heading.depth <= 2);
---

<style>
  .toc-heading {
    display: flex;
    place-items: center;
    border-color: var(--border2);
  }
  .toc-heading svg {
    filter: var(--toc);
    margin-left: -0.1em;
    margin-right: 0.1em;
  }
  .toc-heading a {
    display: flex;
    place-items: center;
    color: var(--primary);
  }
  .toc-heading a:hover {
    color: var(--secondary);
  }
  .toc-heading a:hover svg {
    filter: var(--svg2);
  }
  .toc-list {
    position: relative;
  }
  .toc-list li a {
    color: var(--emphasis);
    margin: 0;
  }
  .toc-indicator {
    display: none;
  }
  @media screen and (min-width: 2108px) {
    .toc-indicator {
      display: block;
      position: absolute;
      left: 0;
      background: var(--border2);
      border-left: 3px solid var(--primary);
      border-radius: 0.25em;
      min-width: 100%;
      transition: top 0.2s ease, height 0.2s ease, opacity 0.2s ease;
      opacity: 0;
      z-index: 0;
    }
    .toc-container {
      position: fixed;
      top: 2.75em;
      right: 2em;
      width: 20%;
      max-width: 20%;
      font-size: 0.85em;
    }
    .toc-top-btn {
      position: sticky;
    }
  }
  @media screen and (max-width: 667px) {
    .toc-list {
      font-size: 0.75em;
    }
  }
</style>

<nav class="toc-container" aria-label="Table of contents">
  <h2 class="toc-heading">
    <a href="#top">
      <TOC width={36} height={36} />Table of Contents
    </a>
  </h2>
  <ol class="toc-list" id="toc-list">
    <div class="toc-indicator" id="toc-indicator" aria-hidden="true"></div>
    {filteredHeadings.map((heading) => (
      <li>
        <a href={`#${heading.slug}`} data-heading={heading.slug}>
          {heading.text}
        </a>
      </li>
    ))}
  </ol>
</nav>

<script>
  function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('#toc-list a[data-heading]');
    const indicator = document.getElementById('toc-indicator');
    if (!links.length || !indicator) return;

    function moveIndicator(link: HTMLAnchorElement) {
      const li = link.parentElement!;
      indicator!.style.top = `${li.offsetTop}px`;
      indicator!.style.height = `${li.offsetHeight}px`;
      indicator!.style.opacity = '1';
    }

    const headingEls = Array.from(links).map(link =>
      document.getElementById(link.dataset.heading!)
    ).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver(
  () => {
    const scrollY = window.scrollY;

    const active = headingEls.reduce<HTMLElement | null>((closest, el) => {
      const top = el.getBoundingClientRect().top + scrollY;
      if (top <= scrollY + 80) {
        return !closest || top > (closest.getBoundingClientRect().top + scrollY)
          ? el
          : closest;
      }
      return closest;
    }, null);

    if (!active) return;

    const activeLink = document.querySelector<HTMLAnchorElement>(
      `#toc-list a[data-heading="${active.id}"]`
      );
      if (activeLink) moveIndicator(activeLink);
      },
      { rootMargin: '-10% 0px -20% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  }

  document.addEventListener('DOMContentLoaded', initTOC);
  document.addEventListener('astro:page-load', initTOC);
</script>
---
import type { MarkdownHeading } from '@astrojs/markdown-remark';
import TOC from '@icons/toc.svg';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((heading) => heading.depth <= 2);
---

<style>
  .toc-container {
    max-width: 1000px;
    margin: 0 auto;
  }
  .toc-heading {
    display: flex;
    place-items: center;
    vertical-align: middle;
    border-color: var(--border2);
  }
  .toc-heading svg {
    filter: var(--toc);
    margin-left: -0.1em;
    margin-right: 0.1em;
    width: 40px;
    height: 40px;
    margin-bottom: 4px;
  }
  .toc-heading a {
    display: flex;
    place-items: center;
    color: var(--primary);
  }
  .toc-heading a:hover, .toc-list li a:hover {
    color: var(--secondary);
  }
  .toc-heading a:hover svg {
    filter: var(--svg2);
  }
  .toc-list {
    position: relative;
    margin-left: -0.25em;
    word-break: normal;
  }
  .toc-list li a {
    color: var(--emphasis);
    margin: 0;
  }
  .toc-indicator {
    display: none;
  }
  .toc-fade {
    display: none;
  }
  @media screen and (min-width: 2060px) {
    .toc-container {
      position: fixed;
      top: 2.75em;
      right: -37.15em;
      width: 56%;
      max-width: 56%;
      font-size: 0.825em;
    }
    .toc-heading svg {
      margin-bottom: 2px;
      width: 36px;
      height: 36px;
    }
    .toc-scroll {
      position: relative;
      max-height: calc(100vh - 8em);
      overflow-y: auto;
      scrollbar-width: none;
    }
    .toc-scroll:hover {
      scrollbar-width: thin;
      scrollbar-color: var(--border2) transparent;
    }
    .toc-scroll::-webkit-scrollbar {
      width: 4px;
    }
    .toc-scroll:not(:hover)::-webkit-scrollbar {
      display: none;
    }
    .toc-indicator {
      display: block;
      position: absolute;
      background: var(--border2);
      border-left: 2px solid var(--primary);
      border-radius: 0.25em;
      max-width: 40%;
      transition: top 0.2s ease, height 0.2s ease, width 0.2s ease, opacity 0.2s ease;
      opacity: 0;
      z-index: 0;
    }
    .toc-top-btn {
      position: sticky;
    }
    .toc-heading {
      border-bottom: 4px dotted transparent;
    }
    .toc-list {
      margin-top: 0.1em;
      max-width: 40%;
    }
    .toc-fade {
      display: block;
      position: sticky;
      bottom: 0;
      height: 3em;
      margin-top: -3em;
      background: linear-gradient(to bottom, transparent, var(--main));
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .toc-fade.hidden {
      opacity: 0;
    }
  }
  @media screen and (max-width: 2059px) {
    .toc-heading a {
      pointer-events: none;
      display: flex;
      place-items: center;
      color: var(--primary);
    }
  }

  @media screen and (max-width: 667px) {
    .toc-list {
      font-size: 0.75em;
    }
    .toc-heading svg {
      width: 32px;
      height: 32px;
    }
    .toc-heading a {
      pointer-events: none;
      display: flex;
      place-items: center;
      color: var(--primary);
    }
  }
</style>

<nav class="toc-container" aria-label="Table of contents">
  <h2 class="toc-heading">
    <a href="#top">
      <TOC width={36} height={36} />Table of Contents
    </a>
  </h2>
  <div class="toc-scroll" id="toc-scroll">
    <div class="toc-indicator" id="toc-indicator" aria-hidden="true"></div>
    <ol class="toc-list" id="toc-list">
      {filteredHeadings.map((heading) => (
        <li>
          <a href={`#${heading.slug}`} data-heading={heading.slug}>
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
    <div class="toc-fade" id="toc-fade" aria-hidden="true"></div>
  </div>
</nav>

<script>
  function initTOC() {
    const tocScroll = document.getElementById('toc-scroll') as HTMLElement;
    const tocList = document.getElementById('toc-list');
    const indicator = document.getElementById('toc-indicator');
    const fade = document.getElementById('toc-fade');
    if (!tocScroll || !tocList || !indicator) return;

    const links = Array.from(
      tocList.querySelectorAll<HTMLAnchorElement>('a[data-heading]')
    );
    if (!links.length) return;

    const headingEls = links
      .map((link) => document.getElementById(link.dataset.heading!))
      .filter((el): el is HTMLElement => el !== null);

    let headingTops: number[] = [];

    function cacheOffsets() {
      const scrollY = window.scrollY;
      headingTops = headingEls.map(
        (el) => el.getBoundingClientRect().top + scrollY
      );
    }

    function updateFade() {
      if (!fade) return;
      const { scrollTop, scrollHeight, clientHeight } = tocScroll;
      const isOverflowing = scrollHeight > clientHeight;
      const atBottom = scrollTop + clientHeight >= scrollHeight - 4;
      fade.classList.toggle('hidden', !isOverflowing || atBottom);
    }

    function scrollTocToLink(link: HTMLAnchorElement) {
      const li = link.parentElement!;
      const liTop = li.offsetTop;
      const liBottom = liTop + li.offsetHeight;
      const { scrollTop, clientHeight } = tocScroll;

      if (liTop < scrollTop) {
        tocScroll.scrollTo({ top: liTop, behavior: 'smooth' });
      } else if (liBottom > scrollTop + clientHeight) {
        tocScroll.scrollTo({ top: liBottom - clientHeight, behavior: 'smooth' });
      }
    }

    function moveIndicator(link: HTMLAnchorElement) {
      const li = link.parentElement!;
      indicator!.style.top = `${tocList!.offsetTop + li.offsetTop}px`;
      indicator!.style.height = `${li.offsetHeight}px`;
      indicator!.style.width = `${link.offsetLeft + link.offsetWidth + 12}px`;
      indicator!.style.opacity = '1';
      scrollTocToLink(link);
    }

    function hideIndicator() {
      indicator!.style.opacity = '0';
    }

    const THRESHOLD = 100;

    function updateActive() {
      const scrollY = window.scrollY;
      let activeIndex = -1;

      for (let i = 0; i < headingTops.length; i++) {
        if (headingTops[i] <= scrollY + THRESHOLD) {
          activeIndex = i;
        } else {
          break;
        }
      }

      if (activeIndex === -1) {
        hideIndicator();
        return;
      }

      moveIndicator(links[activeIndex]);
    }

    let resizeTimer: ReturnType<typeof setTimeout>;
    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        cacheOffsets();
        updateActive();
        updateFade();
      }, 100);
    }

    cacheOffsets();
    updateActive();
    updateFade();

    window.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });
    tocScroll.addEventListener('scroll', updateFade, { passive: true });

    return () => {
      window.removeEventListener('scroll', updateActive);
      window.removeEventListener('resize', onResize);
      tocScroll.removeEventListener('scroll', updateFade);
      clearTimeout(resizeTimer);
    };
  }

  let cleanup: (() => void) | undefined;

  function setup() {
    cleanup?.();
    cleanup = initTOC();
  }

  document.addEventListener('DOMContentLoaded', setup);
  document.addEventListener('astro:page-load', setup);
</script>
---
import type { MarkdownHeading } from '@astrojs/markdown-remark';
import TOC from '@icons/toc.svg';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const filteredHeadings = headings.filter((heading) => heading.depth <= 2);
---

<style>
  .toc-container {
    max-width: 1000px;
    margin: 0 auto;
  }
  .toc-heading {
    display: flex;
    place-items: center;
    border-color: var(--border2);
  }
  .toc-heading svg {
    filter: var(--toc);
    margin-left: -0.1em;
    margin-right: 0.1em;
  }
  .toc-heading a {
    display: flex;
    place-items: center;
    color: var(--primary);
  }
  .toc-heading a:hover {
    color: var(--secondary);
  }
  .toc-heading a:hover svg {
    filter: var(--svg2);
  }
  .toc-list {
    position: relative;
  }
  .toc-list li a {
    color: var(--emphasis);
    margin: 0;
  }
  .toc-indicator {
    display: none;
  }
  @media screen and (min-width: 2060px) {
    .toc-indicator {
      display: block;
      position: absolute;
      right: 2em;
      left: 0;
      background: var(--border2);
      border-left: 3px solid var(--primary);
      border-radius: 0.25em;
      max-width: 35%;
      transition: top 0.2s ease, height 0.2s ease, opacity 0.2s ease;
      opacity: 0;
      z-index: 0;
    }
    .toc-container {
      position: fixed;
      top: 2.75em;
      left: calc(50% + 88ch / 2 + 2em);
      width: 56%;
      max-width: 56%;
      font-size: 0.85em;
    }
    .toc-top-btn {
      position: sticky;
    }
    .toc-heading {
      border-bottom: 4px dotted transparent;
    }
    .toc-list {
      margin-top: 0.1em;
    }
  }
  @media screen and (max-width: 667px) {
    .toc-list {
      font-size: 0.75em;
    }
  }
</style>

<nav class="toc-container" aria-label="Table of contents">
  <h2 class="toc-heading">
    <a href="#top">
      <TOC width={36} height={36} />Table of Contents
    </a>
  </h2>
  <div class="toc-indicator" id="toc-indicator" aria-hidden="true"></div>
  <ol class="toc-list" id="toc-list">
    {filteredHeadings.map((heading) => (
      <li>
        <a href={`#${heading.slug}`} data-heading={heading.slug}>
          {heading.text}
        </a>
      </li>
    ))}
  </ol>
</nav>

<script>
  function initTOC() {
    const tocList = document.getElementById('toc-list');
    const indicator = document.getElementById('toc-indicator');
    if (!tocList || !indicator) return;

    const links = Array.from(
      tocList.querySelectorAll<HTMLAnchorElement>('a[data-heading]')
    );
    if (!links.length) return;

    const headingEls = links
      .map((link) => document.getElementById(link.dataset.heading!))
      .filter((el): el is HTMLElement => el !== null);

    // Absolute offsets, cached and refreshed on resize
    let headingTops: number[] = [];

    function cacheOffsets() {
      const scrollY = window.scrollY;
      headingTops = headingEls.map(
        (el) => el.getBoundingClientRect().top + scrollY
      );
    }

    function moveIndicator(link: HTMLAnchorElement) {
      const li = link.parentElement!;
      indicator!.style.top = `${tocList!.offsetTop + li.offsetTop}px`;
      indicator!.style.height = `${li.offsetHeight}px`;
      indicator!.style.opacity = '1';
    }

    function hideIndicator() {
      indicator!.style.opacity = '0';
    }

    const THRESHOLD = 100; // px — how far past a heading before it becomes active

    function updateActive() {
      const scrollY = window.scrollY;
      let activeIndex = -1;

      for (let i = 0; i < headingTops.length; i++) {
        if (headingTops[i] <= scrollY + THRESHOLD) {
          activeIndex = i;
        } else {
          break;
        }
      }

      if (activeIndex === -1) {
        // Above the first heading — nothing should be active
        hideIndicator();
        return;
      }

      moveIndicator(links[activeIndex]);
    }

    // Debounce resize so cacheOffsets isn't called 60×/sec during a resize drag
    let resizeTimer: ReturnType<typeof setTimeout>;
    function onResize() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        cacheOffsets();
        updateActive();
      }, 100);
    }

    cacheOffsets();
    updateActive();

    window.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', onResize, { passive: true });

    // Return a cleanup function so re-initialisation on astro:page-load doesn't stack up duplicate listeners
    return () => {
      window.removeEventListener('scroll', updateActive);
      window.removeEventListener('resize', onResize);
      clearTimeout(resizeTimer);
    };
  }

  let cleanup: (() => void) | undefined;

  function setup() {
    cleanup?.();
    cleanup = initTOC();
  }

  document.addEventListener('DOMContentLoaded', setup);
  document.addEventListener('astro:page-load', setup);
</script>
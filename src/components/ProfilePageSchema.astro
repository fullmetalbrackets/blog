---
import { SITE_URL, GITHUB, BLUESKY, MASTODON, REDDIT, THREADS } from "@consts";

const schema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "@id": `${SITE_URL}/#profilepage`,
  "name": "Ariel Diaz",
  "description": "Personal website and tech blog by Ariel Diaz, covering self-hosting, Linux, networking, and home labs.",
  "url": SITE_URL,
  "inLanguage": "en-US",
  "mainEntity": {
    "@type": "Person",
    "@id": `${SITE_URL}/#person`,
    "name": "Ariel Diaz",
    "image": `${SITE_URL}/assets/avatar.png`,
    "url": SITE_URL,
    "knowsAbout": [
      "Self-hosting",
      "Linux",
      "Docker",
      "Tailscale",
      "Pi-hole",
      "AdGuard Home"
    ],
    "sameAs": [
      GITHUB,
      BLUESKY,
      MASTODON,
      REDDIT,
      THREADS
    ]
  }
};
---

<Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
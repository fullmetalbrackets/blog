---
import "@styles/global.css";
import FallbackImage from '../img/assets/preview.png'
import { SITE_TITLE, GITHUB, MASTODON } from '../consts';
import { Font } from 'astro:assets';
import type { BaseHeadProps } from '../types';
import { ClientRouter } from 'astro:transitions';

type Props = BaseHeadProps;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage, ogType = "website", ogImage } = Astro.props;
---

<!-- Global Metadata -->
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="apple-mobile-web-app-title" content="Fullmetal" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#008291" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage ?? new URL(image.src, Astro.url)} />
<meta property="og:image:width" content={String(image.width)} />
<meta property="og:image:height" content={String(image.height)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage ?? new URL(image.src, Astro.url)} />

<!-- Fonts -->
<Font cssVariable="--sub-font" preload />
<Font cssVariable="--main-font" preload />
<Font cssVariable="--code-font" />

<ClientRouter/>

<!-- Etc. -->
<link rel="webmention" href={`https://webmention.io/fullmetalbrackets.com/webmention`} />
<link rel="pingback" href={`https://webmention.io/fullmetalbrackets.com/xmlrpc`} />
<link rel="me" href={ GITHUB } />
<link rel="me" href={ MASTODON } />
<meta name="fediverse:creator" content="@adiaz@social.lol">
<link rel="search" type="application/opensearchdescription+xml" href="/opensearch.xml" title="Search fullmetalbrackets.com" />

<script
  is:inline
  async
  defer
  src="https://u.adiaz.fyi/script.js"
  data-website-id="d9921361-56b2-4c33-8377-4c73cb1add2d"
></script>
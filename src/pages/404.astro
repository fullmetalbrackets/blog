---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import Explore from "@components/Explore.astro";
import Popular from "@components/Popular.astro";
import { Image } from 'astro:assets';
import Lost from "@assets/404.png";
import BackToTop from "@components/BackToTop.astro";

const title = "Page not found";
const desc = "This page does not seem to exist.";
---

<BaseLayout title={title} description={desc} noindex>
  <style>
    h1 {
      font-family: var(--sub-font);
    }
    img {
      margin: 0 auto;
    }
    #popular {
      margin-top: 2em;
    }
    #go-back {
      cursor: pointer;
    }
    .endline {
      margin-top: 2em;
      margin-bottom: 1.5em;
    }
    .lost-aside {
      display: inline-flex;
      justify-content: space-between;
      font-size: 1.5em;
      margin: 0 auto 1em auto;
      padding: 0 auto;
      width: 100%;
    }
    .suggestions {
      margin-bottom: 2em
    }
  </style>
  <section>
    <h1>{title}</h1>
    <hr />
    <p>
      I think you took a wrong turn at Albuquerque. (Or hit a broken link, if so <a href="mailto:contact@fullmetalbrackets.com?subject=Broken%20link">bug me about it</a>.)
    </p>
    <Image
      src={Lost}
      alt="Bugs Bunny looking at a map because he took a wrong turn at Albuquerque."
      title="404 Page Not Found."
      loading="eager"
      decoding="async"
      inferSize={true}
    />
    <p class="suggestions">
      Explore the site below, see <a href="#popular">popular posts</a>, <a href="/blog/random">a random post</a>, <a href="javascript:javascript:history.go(-1)" id="go-back">go back</a> where you came from, or <a href="/">return home</a>. 
    </p>
    <Explore class="ul-404" />
    <div id="popular"/>
    <Popular class="pop-404" />
  </section>
  <hr class="endline" />
<BackToTop/>
</BaseLayout>

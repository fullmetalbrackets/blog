---
export const prerender = true;
 
import BaseLayout from '@layouts/BaseLayout.astro';
import CollectionPageSchema from '@components/CollectionPageSchema.astro';
import { SITE_URL } from '@consts';
import { getSortedNotes } from "@utils/collections";
import { YouTube } from 'astro-embed';
 
const title = 'Notes';
const desc = 'Syndicated feed from my microblog at ariel.lol';
 
const entries = await getSortedNotes();
---
 
<BaseLayout title={title} description={desc}>
  <CollectionPageSchema
    slot="head"
    name={title}
    description={desc}
    url={`${SITE_URL}/notes/`}
  />
  <section class="h-feed">
    <h1 class="p-name">{title}</h1>
    <hr />
    <p class="desc">
      Syndicated feed from my microblog at <a href="https://ariel.lol/">ariel.lol</a>
    </p>
 
    <ul class="notes-list">
      {entries.map(note => {
        const date = note.data.published ? new Date(note.data.published) : null;
 
        const ytMatch = note.data.content?.match(
          /youtube\.com\/watch\?v=([a-zA-Z0-9_-]+)/
        );
        const ytId = ytMatch?.[1] ?? null;
 
        const imageUrl = note.data.image?.url ?? null;
 
        const altMatch = note.data.content?.match(/<img[^>]*alt="([^"]*)"[^>]*>/);
        const imageAlt = altMatch?.[1] ?? '';
 
        const cleanContent = note.data.content
          ?.replace(/<a[^>]*youtube\.com\/watch[^>]*>.*?<\/a>/g, '')
          ?.replace(/<img[^>]*>/g, '')
          .trim();
 
        return (
          <li class="note-item h-entry">
            <div class="note-wrap">
              {ytId && <YouTube id={ytId} />}
              {!ytId && imageUrl && (
                <img src={imageUrl} alt={imageAlt} class="note-image" />
              )}
              <div
                class="note-body e-content"
                set:html={cleanContent}
              />
            </div>
            {date && (
              <div class="note-meta">
                <a
                  class="u-url dt-published"
                  href={note.data.url}
                  target="_blank"
                  rel="noopener noreferrer me"
                  aria-label={`Permalink for note from ${date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}, opens in new tab`}
                >
                  <time datetime={date.toISOString()}>
                    {date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                </a>
                <a
                  class="note-share"
                  href={`https://shareopenly.org/share/?url=${note.data.url}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Share this note, opens in new tab"
                >
                  share
                </a>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .feed-error {
    color: var(--warning);
    font-family: var(--sub-font);
    font-size: 0.75em;
  }

  .notes-list {
    list-style: none;
    padding: 0;
    margin: 0.5em auto 1em auto;
    max-width: 720px;
  }

  .note-item {
    padding: 1em 0;
  }

  .note-wrap {
    border-radius: 0.5em;
    overflow: hidden;
  }

  .note-meta a[target="_blank"]::after {
    content: '';
    display: inline-block;
    width: 0.75em;
    height: 0.75em;
    margin-top: 0.1em;
    margin-left: 0.1em;
    background-color: currentColor;
    mask-image: url('/assets/external.svg');
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    vertical-align: middle;
  }

  .note-image {
    width: 100%;
    height: auto;
    display: block;
    margin: 0;
  }

  .note-body {
    font-size: 0.875em;
    line-height: 1.65;
    color: var(--text);
    padding: 1em 1.5em;
    background: var(--blockquote);
    border-radius: 0 0 0.5em 0.5em;
  }

  .note-wrap:not(:has(lite-youtube)):not(:has(.note-image)) .note-body {
    border-radius: 0.5em;
  }

  .note-body :global(p) {
    margin: 0 0 0.5em;
  }

  .note-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .note-body :global(img) {
    margin: 0 auto 0.5em auto;
    width: 100%;
    height: auto;
  }

  .note-body > :has(.lyt-playbtn) {
    border-radius: 0;
  }

  .note-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 0.25em 0.5em;
  }

  .note-meta a {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    font-family: var(--sub-font);
    font-size: 0.75em;
    font-weight: 700;
    text-decoration: none;
  }

  .note-meta .u-url {
    color: var(--primary);
  }

  .note-meta .note-share {
    color: var(--link);
  }

  .note-meta a:hover {
    color: var(--hover);
  }

  .note-meta time {
    color: inherit;
  }

  .note-meta a[target="_blank"]::after {
    content: '';
    display: inline-block;
    width: 0.75em;
    height: 0.75em;
    margin-top: 0.1em;
    margin-left: 0.2em;
    background-color: currentColor;
    mask-image: url('/assets/external.svg');
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    vertical-align: middle;
  }
</style>

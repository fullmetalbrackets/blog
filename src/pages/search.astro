---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE_URL } from "@consts";
const title = "Search";
const desc = "Search blog and wiki."
---

<style scoped>
  section {
    padding: 0 0.5em;
  }
  .desc {
    font-size: 1em;
  }
  #search {
    min-height: 60dvh;
  }
  .search-title {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .search-section {
    margin: 2em auto;
  }
  @media screen and (max-width: 667px) {
    section {
      margin-top: 0;
    }
    h1 {
      margin-top: -0.75em;
    }
    .desc {
      margin-top: -0.1em;
      font-size: 18px;
    }
  }
</style>

<BaseLayout title={title} description={desc} noindex>
  <section class="search-section">
    <h1 class="search-title title">{title}</h1>
    <a class="u-url" href={`${SITE_URL}/search`} hidden>Permalink</a>
    <hr />
    <p class="desc">{desc}</p>
    <script is:inline src="/pagefind/pagefind-ui.js" type="text/javascript" crossorigin="anonymous"></script>
    <div id="search"></div>
    <script is:inline crossorigin="anonymous">
      window.addEventListener('DOMContentLoaded', () => {
        const search_ui = new PagefindUI({
          element: "#search",
          pageSize: 10,
          showImages: false,
          showSubResults: false,
          autofocus: true,
          translations: {
            placeholder: "Type your search…",
            search_label: "Search the site",
            zero_results: "No result found for \"[SEARCH_TERM]\".",
            many_results: "[COUNT] results found for \"[SEARCH_TERM]\":",
            one_result: "[COUNT] result found for \"[SEARCH_TERM]\":",
          },
          processTerm: function (term) {
            history.replaceState({}, "", `?q=${encodeURIComponent(term)}`);
            return term;
          },
        });
        const params = new URLSearchParams(window.location.search);
        if (params.has('q')) {
          search_ui.triggerSearch(params.get('q'));
        }
      });
    </script>
    <hr />
  </section>
</BaseLayout>
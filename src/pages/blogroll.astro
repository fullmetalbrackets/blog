---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import ItemListSchema from "@components/ItemListSchema.astro";
import { SITE_URL } from "@consts";
import { blogs } from "@data/blogroll";
import { pages } from "@data/pages";

const { title, description } = pages.find(p => p.href === "/blogroll")!;

const getFavicon = (url: string) =>
  `https://www.google.com/s2/favicons?domain=${new URL(url).hostname}&sz=32`;

const blogrollItems = blogs.map(blog => ({
  name: blog.name,
  url: blog.url,
  type: "WebSite",
}));

const lastUpdated = new Date('2026-05-08T12:00');
---

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Blogroll", url: `${SITE_URL}/blogroll` }
  ]} />
  <CollectionPageSchema
    slot="head"
    name={title}
    description={description}
    url={`${SITE_URL}/blogroll`}
  />
  <ItemListSchema slot="head" id={`${SITE_URL}/blogroll/#list`} items={blogrollItems} />
  <section class="h-feed" data-pagefind-body>
    <h1 class="p-name">{title}</h1>
    <a class="u-url" href={`${SITE_URL}/blogroll`} hidden>Permalink</a>
    <hr />
    <p class="desc">A list of <span class="total">{blogs.length}</span> super cool personal sites and blogs that I follow, and you should too. <i>(All links open in new tabs.)</i></p>
    <p class="flex">
      <span class="updated">
        Last updated
      </span>
      <FormattedDate date={lastUpdated} monthFormat="long" />
    </p>
    <ul>
      {blogs.map(blog => (
        <li class="h-entry">
          <div class="blog-link">
            <a href={blog.url} target="_blank" rel="noopener noreferrer"
              data-umami-event={`blogroll-${blog.id}`} class="u-bookmark-of left">
              <img
                src={getFavicon(blog.url)}
                alt={`${blog.name} favicon`}
                class="favicon"
                width="20"
                height="20"
                loading="lazy"
                decoding="async"
              />
              <span class="p-name name">{blog.name}</span>
            </a>
            <div class="right">
              <span class="url"><a href={blog.url} target="_blank" rel="alternate noopener noreferrer">{blog.url.replace('https://', '').replace(/\/$/, '')}</a></span>
              {blog.feed === '#' ? (
                <span class="rss no-feed" title="No RSS feed available" aria-label="No RSS feed">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256">
                    <rect width="256" height="256" rx="55" ry="55" fill="#888"/>
                    <rect width="246" height="246" rx="50" ry="50" x="5" y="5" fill="#aaa"/>
                    <rect width="236" height="236" rx="47" ry="47" x="10" y="10" fill="#999"/>
                    <circle cx="68" cy="189" r="24" fill="#FFF"/>
                    <path d="M160 213h-34a82 82 0 0 0 -82 -82v-34a116 116 0 0 1 116 116z" fill="#FFF"/>
                    <path d="M184 213A140 140 0 0 0 44 73 V 38a175 175 0 0 1 175 175z" fill="#FFF"/>
                  </svg>
                  <span class="tooltip">No feed &#9785;</span>
                </span>
              ) : (
                <a href={blog.feed} target="_blank" rel="alternate noopener noreferrer"
                  class="rss" aria-label={`${blog.name} RSS feed`}
                  data-umami-event={`blogroll-rss-${blog.id}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256">
                    <rect width="256" height="256" rx="55" ry="55" fill="#CC5D15"/>
                    <rect width="246" height="246" rx="50" ry="50" x="5" y="5" fill="#F49C52"/>
                    <rect width="236" height="236" rx="47" ry="47" x="10" y="10" fill="#E3702D"/>
                    <circle cx="68" cy="189" r="24" fill="#FFF"/>
                    <path d="M160 213h-34a82 82 0 0 0 -82 -82v-34a116 116 0 0 1 116 116z" fill="#FFF"/>
                    <path d="M184 213A140 140 0 0 0 44 73 V 38a175 175 0 0 1 175 175z" fill="#FFF"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>
  </section>
  <hr>
  <BackToTop />
</BaseLayout>

<style scoped>
  svg {
    margin: 0;
    padding: 0;
  }
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .desc {
    font-size: 1em;
  }
  .updated {
    display: flex;
    font-family: var(--sub-font);
    font-size: 0.875em;
    color: var(--emphasis);
    place-items: center;
    margin-right: 0.5em;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 1.5em auto 3em auto;
    max-width: 1000px;
  }
  li {
    border-bottom: 2px dotted var(--border);
    padding: 0.625em 0;
  }
  li:first-child {
    border-top: 2px dotted var(--border);
  }
  .blog-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1em;
  }
  .left {
    display: flex;
    align-items: center;
    gap: 0.625em;
    line-height: 1
  }
  .favicon {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: block;
    font-size: 0;
  }
  .name {
    font-weight: 700;
    color: var(--emphasis);
  }
  .right {
    display: flex;
    align-items: center;
    gap: 0.75em;
    flex-shrink: 0;
    line-height: 1
  }
  .url {
    font-family: var(--code-font);
    font-size: 0.75em;
    color: var(--link);
  }
  .rss {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .rss svg {
    width: 32px;
    height: 32px;
  }
  li a:hover .name {
    color: var(--hover);
    transition: all .2s ease-out;
  }
  li:hover .url {
    color: var(--hover);
    transition: all .2s ease-out;
  }
  .rss svg:hover {
    animation: wiggle 0.25s ease-in-out;
  }
  .rss svg:not(:hover) {
    animation: none;
  }
  .no-feed {
    position: relative;
    cursor: default;
    display: flex;
    align-items: center;
  }
  .no-feed .tooltip {
    position: absolute;
    right: 0;
    bottom: calc(100% + 6px);
    background: var(--blockquote);
    border: 1px solid var(--border);
    border-radius: 0.5em;
    padding: 0.25em 0.625em;
    font-size: 0.75em;
    font-family: var(--sub-font);
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
    pointer-events: none;
  }
  .no-feed:hover .tooltip {
    opacity: 1;
    visibility: visible;
  }
  .no-feed svg:hover {
    animation: none;
  }
  @media screen and (max-width: 667px) {
    .desc {
      margin-top: -0.1em;
      font-size: 18px;
    }
    p.flex {
      font-size: 0.875em;
    }
    ul {
      margin: 1.5em 0.5em 3em 0.5em;
    }
    .url {
      display: none;
    }
  }
</style>
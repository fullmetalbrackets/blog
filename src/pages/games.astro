---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import BackToTop from "@components/BackToTop.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import { SITE_URL } from "@consts";
import { getEntry } from 'astro:content';
import Switch2 from '@img/games/switch2.svg';
import Switch from '@img/games/switch.svg';
import Wii from '@img/games/wii.svg';
import GC from '@img/games/gc.svg';
import N3DS from '@img/games/3ds.svg';
import DS from '@img/games/ds.svg';
import GBA from '@img/games/gba.svg';
import PS5 from '@img/games/ps5.svg';
import PS4 from '@img/games/ps4.svg';
import PS3 from '@img/games/ps3.svg';
import PS2 from '@img/games/ps2.svg';
import PS1 from '@img/games/psx.svg';
import XB from '@img/games/xbox.svg';
import Steam from '@img/games/steam.svg';

const gamesEntry = await getEntry('games', 'games');
const gamesByPlatform = gamesEntry?.data.games;

type GameEntry = {
  moby: number;
  title: string;
  image?: ImageMetadata;
};

const platformIcons: Record<string, { component: any; class?: string }> = {
  'PlayStation 5': { component: PS5 },
  'PlayStation 4': { component: PS4 },
  'PlayStation 3': { component: PS3 },
  'PlayStation 2': { component: PS2 },
  'PlayStation': { component: PS1 },
  'Nintendo Switch 2': { component: Switch2, class: 'switch2-icon' },
  'Nintendo Switch': { component: Switch },
  'Wii': { component: Wii, class: 'wii-icon' },
  'GameCube': { component: GC },
  'Nintendo 3DS': { component: N3DS },
  'Nintendo DS': { component: DS },
  'GameBoy Advance': { component: GBA },
  'XBox 360': { component: XB },
  'Steam': { component: Steam },
};

const title = "Games";
const desc = "List of all video games I own by platform.";

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${SITE_URL}/games/#collection`,
  "name": "Games",
  "description": desc,
  "url": `${SITE_URL}/games/`,
  "inLanguage": "en-US",
  "author": {
    "@id": `${SITE_URL}/#person`
  }
};
---
<BaseLayout title={title} description={desc}>
  <CollectionPageSchema
    slot="head"
    name={title}
    description={desc}
    url={`${SITE_URL}/games/`}
  />
  <section>
  <h1>{title}</h1>
  <a class="u-url" href={`https://fullmetalbrackets.com/games`} hidden>Permalink</a>
  <hr />
  <p>{desc}</p>
  {gamesByPlatform && Object.entries(gamesByPlatform).map(([platform, games]) => {
    const typedGames = games as GameEntry[];
    const icon = platformIcons[platform];
    const IconComponent = icon?.component;
    return (
      <details>
        <summary>
          {IconComponent ? (
            <IconComponent 
              class={`platform-icon ${icon.class || ''}`}
            />
          ) : (
            <span>{platform}</span>
          )}
          <span class="count">{typedGames.length}</span>
        </summary>
        <div class="details-content">
          {platform === 'Steam' && <p class="platform-note">This is only games <b>I've actually played</b> since I have many games on Steam I've never even installed...</p>}
          {platform === 'Nintendo Switch 2' && <p class="platform-note">With the exception of <b>Mario Kart World</b>, these are all <em>Nintendo Switch 2 Edition</em> upgrades of Switch games I already owned.</p>}
          <ul>
            {typedGames.map(game => (
              <li>
                <span>{game.title}</span>
              </li>
            ))}
          </ul>
        </div>
      </details>
    );
  })}
</section>
<hr>
<BackToTop />

<style>
  section {
    margin-bottom: 2em;
  }

  details {
    margin-bottom: 0.5em;
    padding: 0;
  }
  
  summary {
    display: inline-flex;
    cursor: pointer;
    font-weight: bold;
    padding: 0.25em;
    align-items: center;
    gap: 0.5em;
    color: var(--primary);
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::before {
    content: '▶';
    display: inline-block;
    font-size: 0.75em;
    line-height: 1;
    transition: rotate 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    rotate: 0deg;
  }

  details[open] > summary::before {
    rotate: 90deg;
  }

  summary > * {
    display: inline-flex;
    vertical-align: middle;
  }

  summary svg {
    filter: var(--game-platform);
  }

  .platform-icon {
    width: 100px;
    height: auto;
    margin: 0;
    padding: 0;
  }
  
  .count {
    display: inline-flex;
    justify-content: center;
    place-items: center;
    min-width: 22px;
    height: 22px;
    padding: 0 1px 0 0;
    margin-left: 0.25em;
    background: var(--border);
    border-radius: 9999px;
    font-family: var(--sub-font);
    font-size: 0.5em;
  }
  
  .platform-note {
    padding: 4px 8px;
    background-color: var(--dropdown);
    border-left: 1px solid var(--primary);
    margin: 0.5em 0 0.5em 0.85em;
    font-family: var(--sub-font);
    font-style: italic;
    font-size: 0.75em;
  }
  
  ul {
    padding: 0 0 0 1em;
    margin: 0 0 1em 0;
  }
  
  li {
    display: flex;
    align-items: center;
    gap: 0;
    margin: 0;
    padding: 0 0 0 0.25em;
  }

  .switch2-icon {
    width: 36px;
    height: auto;
  }

  .wii-icon {
    width: 36px;
    height: auto;
  }

  @keyframes bounceOpen {
    0%   { transform: scaleY(0); opacity: 0; }
    60%  { transform: scaleY(1.06); opacity: 1; }
    80%  { transform: scaleY(0.97); }
    100% { transform: scaleY(1); }
  }

  @keyframes bounceClose {
    0%   { transform: scaleY(1); opacity: 1; }
    30%  { transform: scaleY(1.04); }
    100% { transform: scaleY(0); opacity: 0; }
  }

  details .details-content {
    transform-origin: top;
    overflow: hidden;
  }

  details[open] .details-content {
    animation: bounceOpen 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  details .details-content.closing {
    animation: bounceClose 0.25s ease-in forwards;
  }

  @media screen and (max-width: 667px) {
    summary {
      display: flex;
    }
    li span {
      font-size: 18px;
    }
  }
</style>

<script>
  document.querySelectorAll('details').forEach(details => {
    const summary = details.querySelector('summary');
    const content = details.querySelector('.details-content') as HTMLElement;

    summary?.addEventListener('click', e => {
      e.preventDefault();

      if (details.open) {
        // Play close animation, then shut
        content.classList.add('closing');
        content.addEventListener('animationend', () => {
          content.classList.remove('closing');
          details.removeAttribute('open');
        }, { once: true });
      } else {
        // Open first, then animate
        details.setAttribute('open', '');
      }
    });
  });
</script>
---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getSortedTags } from '@utils/collections';
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import { SITE_URL } from "@consts";

const tags = await getSortedTags();
const title = "Categories";
const desc = "Blog posts by category.";
---

<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  p {
    margin: 0 auto 1em auto;
    padding: 0;
  }
  .back {
    display: flex;
    justify-content: space-between;
  }
  ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style-type: none;
    margin: 0 0 2em 0;
    padding: 0;
  }
  li {
    margin: 0.25em;
  }
  .label a {
    color: #000
  }
  .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25em;
    height: 1rem;
    padding: 1px 0 0 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--main-font);
    font-size: 0.675em;
  }
  button a {
    display: flex;
    place-items: center;
    gap: 0.25em;
  }
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    ul {
      gap: 0.325em;
    }
  }
</style>

<BaseLayout title={title} description={desc}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Categories", url: `${SITE_URL}/categories/` }
  ]} />
  <section>
    <h1>{title}</h1>
    <a class="u-url" href={`${SITE_URL}/categories/`} hidden>Permalink</a>
    <hr />
    <p class="back">
      <a href="/blog/" rel="prefetch-intent">↩ All posts</a>
      <a href="/blog/years/" rel="prefetch-intent" data-umami-event="blog-years">Posts by year ↪</a>
    </p>
    <p>
      Click on categories below to see blog posts about that subject.
    </p>
    <ul>
      {tags.map(({ tag, count }) => (
        <li>
          <button>
            <a href={`/categories/${tag}/`} rel="prefetch-intent tag" data-umami-event={`categories-${tag}`}>
              <span class="label">
                {tag}
              </span>
            <span class="count">
              {count}
            </span>
            </a>
          </button>
        </li>
      ))}
    </ul>
    <hr />
  </section>
</BaseLayout>
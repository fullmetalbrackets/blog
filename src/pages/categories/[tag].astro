---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getPostsWithReadingTime } from '@utils/collections';
import FormattedDate from "@components/FormattedDate.astro";
import ReadingTime from "@components/ReadingTime.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import { SITE_URL } from "@consts";
import type { BlogTagProps } from '../../types';

export async function getStaticPaths() {
	const allPosts = await getPostsWithReadingTime();

	const tags = [...new Set(allPosts.flatMap(post =>
		post.data.tags.map(tag => tag.toLowerCase())
	))];

	return tags.map((tag) => ({
		params: { tag },
		props: {
			tag,
			posts: allPosts.filter(post =>
				post.data.tags.map(t => t.toLowerCase()).includes(tag)
			),
		},
	}));
}

type Props = BlogTagProps;
const { tag, posts } = Astro.props;
const tagTitle = tag.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
---


<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  hr {
    margin-bottom: 0.5em;
  }
  .back {
    justify-content: space-between;
    font-family: var(--sub-font);
    font-weight: 500;
    margin: 0 auto;
    padding: 0;
  }
  .back a {
    font-size: 24px;
    color: var(--link);
  }
  .back a:hover {
    color: var(--hover);
    transition: all .25s ease-out;
    margin: 0;
  }
  ul {
    list-style-type: none;
    margin: 0 auto 2em auto;
    padding: 0;
  }
  li {
    display: inline-block;
    margin: 0 auto 1em auto;
  }
  li:last-of-type {
    margin: 0 auto;
  }
  div {
    display: block;
    padding-bottom: 0.25em;
    border-bottom: 4px dotted transparent;
  }
  p {
    margin: 0 auto 0.125em auto;
    padding: 0 auto;
  }
  .years {
    margin: 1em auto;
  }
  .years a {
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.9em;
  }
  .back {
    display: flex;
    justify-content: space-between;
    margin-top: 1em;
  }
  button {
    margin: 0 0.175em;
    background: var(--info);
    cursor: pointer;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .info {
    place-items: center;
    margin-top: 0.1em;
    display: inline-flex;
    gap: 0.25em
  }
  .tag {
    margin: 0.125em 0 0 0;
    padding: 0;
  }
  .title {
    display: block;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .title a:hover {
    color: var(--hover);
  }
  .desc {
    margin-top: -0.25em;
  }
  li:hover div {
    border-bottom: 4px dotted var(--hover);
    cursor: pointer;
    transition: all .25s ease-out;
  }
  li:hover .title {
    color: var(--hover);
    transition: all .25s ease-out;
  }
  @media (hover: hover) {
    li:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    li:hover button {
      outline-offset: 1px;
    }
  }
</style>

<BaseLayout title={`Posts about ${tagTitle}`}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Categories", url: `${SITE_URL}/categories/` },
    { name: tagTitle, url: `${SITE_URL}/categories/${tag}/` }
  ]} />
  <section>
    <h1>Posts about <span class="tag">{`${tagTitle}`}</span></h1>
    <hr />
    <p class="back">
      <a href="/categories/" rel="prefetch-intent">↩ Categories</a>
      <a href="/blog/" rel="prefetch-intent">All posts ↪</a>
    </p>
    <p class="years">
      Alternately, see posts by year:&nbsp;
      <a href="/blog/years/2025/" data-umami-event="blog-2025">2025</a>&nbsp;
      <a href="/blog/years/2024/" data-umami-event="blog-2024">2024</a>&nbsp;
      <a href="/blog/years/2023/" data-umami-event="blog-2023">2023</a>&nbsp;
      <a href="/blog/years/2022/" data-umami-event="blog-2022">2022</a>&nbsp;
      <a href="/blog/years/2021/" data-umami-event="blog-2021">2021</a>
    </p>
    <ul>
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} rel="prefetch-intent" data-umami-event={`${tag}-${post.id}`}>
              <div>
                <span class="title">{post.data.title}</span>
                <p class="tag">
                  {post.data.tags.map((tag) => (
                    <button>{tag}</button>
                  ))}
                </p>
                <p class="info">
                  <FormattedDate date={post.data.pubDate} />&nbsp;
                  <span class="reading"><ReadingTime time={post.readingTime} /></span>
                </p>
                <p class="desc">{post.data.description}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
    <hr />
    <BackToTop />
  </section>
</BaseLayout>
---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import LeftArrow from '@icons/arrow-left.svg';
import { SITE_URL } from "@consts";

const allPosts = (await getCollection("wiki")).sort((a, b) => {
  const dateA = a.data.updatedDate || a.data.pubDate;
  const dateB = b.data.updatedDate || b.data.pubDate;
  return dateB.valueOf() - dateA.valueOf();
});

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  const tag = post.data.tag;
  tagCounts[tag] = (tagCounts[tag] ?? 0) + 1;
}
const tags = Object.keys(tagCounts).sort();

const title = "All Wiki Articles";
const description = "All wiki articles, searchable and filterable by tag.";
---

<style>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.875em;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .back-link:hover {
    color: var(--link);
  }

  .back-link svg {
    fill: currentColor;
    margin-right: 0.25em;
    margin-bottom: 0.1em;
    transition: transform 0.1s ease-in-out;
  }

  .back-link:hover svg {
    fill: currentColor;
    transition: transform 0.1s ease-in-out;
    transform: translateX(-4px);
  }

  .filter-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0 1.25rem;
  }

  .filter-label {
    font-size: 0.6em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--border);
    margin-right: 2px;
    font-family: var(--sub-font);
  }

  .filter-label + .filter-label {
    margin-left: 0.5rem;
  }

  .fbtn {
    background: var(--accent);
    border-radius: 0.25em;
    color: var(--emphasis);
    font-size: 0.6em;
    padding: 3px 10px;
    cursor: pointer;
    transition: all 0.25s;
    font-family: var(--sub-font);
  }

  .fbtn.on {
    background: var(--primary);
    color: var(--main);
  }

  .search-input {
    margin-left: auto;
    background: var(--accent);
    border: 1px solid var(--border);
    border-radius: 1em;
    color: var(--emphasis);
    font-size: 0.65em;
    padding: 4px 10px;
    outline: none;
    width: 160px;
    font-family: inherit;
    transition: border-color 0.25s;
  }

  .search-input:focus {
    border-color: var(--primary);
  }

  .search-input::placeholder {
    color: var(--border);
  }

  /* Article list */
  .all-list {
    list-style: none;
    margin: 1em 0;
    padding: 0;
  }

  .all-item {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 1rem;
    border-bottom: 4px dotted var(--border);
    padding: 0.5rem 0;
  }

  .all-item:last-child {
    border-bottom: none;
  }

  .all-item a {
    color: var(--emphasis);
    text-decoration: none;
    font-size: 1em;
    font-weight: 700;
  }

  .all-item a:hover {
    color: var(--hover);
  }

  .all-tag {
    font-size: 0.875em;
  }

  .all-date {
    font-size: 0.875em;
    white-space: nowrap;
    margin-top: 0.5em;
  }

  .empty-msg {
    color: var(--border);
    font-size: 0.75em;
    padding: 1rem 0;
  }

  @media screen and (max-width: 667px) {
    .all-item {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.25rem 0.75rem;
    }

    .all-item a {
        width: 100%;
    }

    .search-input {
        width: 100%;
        margin-left: 0;
    }

    .filter-bar {
        gap: 0.35rem;
    }
  }
</style>

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema
    slot="head"
    crumbs={[
      { name: "Home", url: `${SITE_URL}` },
      { name: "Wiki", url: `${SITE_URL}/wiki` },
      { name: "All Articles", url: `${SITE_URL}/wiki/articles` },
    ]}
  />

  <section>
    <a href="/wiki" class="back-link"><LeftArrow height={24} width={24} /> Back to Wiki</a>
    <h1>All Wiki Articles</h1>
    <hr />

    <div class="filter-bar" id="filter-bar">
      <span class="filter-label">sort</span>
      <button class="fbtn on" data-sort="date" id="s-date">date</button>
      <button class="fbtn" data-sort="az" id="s-az">a&#8211;z</button>

      <span class="filter-label">tag</span>
      <button class="fbtn on" data-tag="all" id="t-all">all</button>
      {tags.map((tag) => (
        <button class="fbtn" data-tag={tag} id={`t-${tag}`}>{tag}</button>
      ))}

      <input
        class="search-input"
        type="search"
        id="wiki-search"
        placeholder="filter articles&#8230;"
        autocomplete="off"
      />
    </div>

    <ul class="all-list" id="all-list">
      {
        allPosts.map((post) => (
          <li
            class="all-item"
            data-tag={post.data.tag}
            data-title={post.data.title.toLowerCase()}
            data-date={(post.data.updatedDate || post.data.pubDate).toISOString()}
            data-pubdate={post.data.pubDate.toISOString()}
          >
            <a href={`/wiki/${post.id}`} rel="prefetch-intent" data-umami-event={post.id}>
              {post.data.title}
            </a>
            <span class="all-tag">
              <button>{post.data.tag}</button>
            </span>
            <span class="all-date">
              <FormattedDate date={post.data.updatedDate || post.data.pubDate} monthFormat="numeric" />
            </span>
          </li>
        ))
      }
    </ul>
    <p class="empty-msg" id="empty-msg" style="display:none">No articles match.</p>

    <hr />
    <BackToTop />
  </section>
</BaseLayout>

<script>
  const list = document.getElementById("all-list") as HTMLUListElement;
  const emptyMsg = document.getElementById("empty-msg") as HTMLParagraphElement;
  const searchInput = document.getElementById("wiki-search") as HTMLInputElement;

  const SESSION_KEY = "wiki-filters";

  // Read saved state, falling back to defaults
  const saved = JSON.parse(sessionStorage.getItem(SESSION_KEY) ?? "{}");

  let sortBy: string = saved.sortBy ?? "date";
  let tagBy: string = saved.tagBy ?? "all";
  let query: string = saved.query ?? "";

  function saveState() {
    sessionStorage.setItem(SESSION_KEY, JSON.stringify({ sortBy, tagBy, query }));
  }

  // Apply saved state to UI on load
  function restoreUI() {
    // Sort buttons
    document.querySelectorAll<HTMLButtonElement>("[data-sort]").forEach((b) => {
      b.classList.toggle("on", b.dataset.sort === sortBy);
    });
    // Tag buttons
    document.querySelectorAll<HTMLButtonElement>(".fbtn[data-tag]").forEach((b) => {
      b.classList.toggle("on", b.dataset.tag === tagBy);
    });
    // Search input
    searchInput.value = query;
  }

  // ?tag= in URL overrides saved state
  const urlTag = new URLSearchParams(window.location.search).get("tag");
  if (urlTag) {
    tagBy = urlTag;
    saveState();
  }

  function getItems() {
    return Array.from(list.querySelectorAll<HTMLLIElement>(".all-item"));
  }

  function render() {
    const items = getItems();
    let visible = items.filter((el) => {
      if (tagBy !== "all" && el.dataset.tag !== tagBy) return false;
      if (query && !el.dataset.title?.includes(query)) return false;
      return true;
    });

    if (sortBy === "date") {
      visible.sort((a, b) =>
        (b.dataset.date ?? "").localeCompare(a.dataset.date ?? "")
      );
    } else {
      visible.sort((a, b) =>
        (a.dataset.title ?? "").localeCompare(b.dataset.title ?? "")
      );
    }

    const hidden = items.filter((el) => !visible.includes(el));
    visible.forEach((el) => { el.style.display = ""; list.appendChild(el); });
    hidden.forEach((el) => { el.style.display = "none"; list.appendChild(el); });

    emptyMsg.style.display = visible.length === 0 ? "" : "none";
  }

  document.querySelectorAll<HTMLButtonElement>("[data-sort]").forEach((btn) => {
    btn.addEventListener("click", () => {
      sortBy = btn.dataset.sort ?? "date";
      document.querySelectorAll<HTMLButtonElement>("[data-sort]")
        .forEach((b) => b.classList.remove("on"));
      btn.classList.add("on");
      saveState();
      render();
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".fbtn[data-tag]").forEach((btn) => {
    btn.addEventListener("click", () => {
      tagBy = btn.dataset.tag ?? "all";
      document.querySelectorAll<HTMLButtonElement>(".fbtn[data-tag]")
        .forEach((b) => b.classList.remove("on"));
      btn.classList.add("on");
      saveState();
      render();
    });
  });

  searchInput.addEventListener("input", (e) => {
    query = (e.target as HTMLInputElement).value.toLowerCase();
    saveState();
    render();
  });

  restoreUI();
  render();
</script>
---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import { SITE_URL } from '@consts';
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/BreadcrumbSchema.astro';
import FormattedDate from '@components/FormattedDate.astro';
import BackToTop from '@components/BackToTop.astro';
import { pages } from "@data/pages";

const entries = await getCollection('now');
const sorted = entries.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const [latest, ...previous] = sorted;
const { Content } = await render(latest);

const { title, description } = pages.find(p => p.href === "/now")!;
---

<BaseLayout title={title} description={description} entry={latest}>
  <link slot="head" rel="canonical" href={new URL('/now', Astro.site).toString()} />
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Now", url: `${SITE_URL}/now` }
  ]} />
  <Fragment slot="head" set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": `${SITE_URL}/now/#aboutpage`,
    "name": title,
    "description": description,
    "url": `${SITE_URL}/now`,
    "inLanguage": "en-US",
    "dateModified": latest.data.pubDate.toISOString(),
    "author": {
      "@id": `${SITE_URL}/#person`
    }
  })}</script>`} />
  <section data-pagefind-ignore>
    <h1>{title}</h1>
    <a class="u-url" href={`${SITE_URL}/now`} hidden>Permalink</a>
    <hr />
    <p class="desc">
      {description}
    </p>
    <span class="date">
      <span class="updated">Updated</span> <FormattedDate date={latest.data.pubDate} noDay />
    </span>
    <hr class="separator" />
    <p>
      {latest.data.image && (
        <Image src={latest.data.image} alt="" />
      )}
    </p>
    <Content />
      {previous.length > 0 && (
        <h2>Previous Entries</h2>
        <ul>
          {previous.map(prevEntry => (
            <li>
              <a href={`/now/${prevEntry.id}`}>
                {prevEntry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </a>
            </li>
          ))}
        </ul>
      )}
    <hr/>
    <BackToTop />
  </section>
</BaseLayout>

<style scoped>
  section {
    min-height: calc(100vh - 300px);
  }
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .date {
    display: flex;
    place-items: center;
  }
  .updated {
    color: var(--emphasis);
    font-family: var(--sub-font);
    font-weight: 800;
    font-size: 0.875em;
    margin-right: 0.5em;
  }
  .desc {
    margin-bottom: 1em;
  }
  .separator {
    display: grid;
    border-width: thick;
    border-color: var(--border);
    margin: 1em 0 0 0;
  }
  h2 {
    margin-top: 1em;
  }
  ul {
    margin: 0 auto 2em auto;
  }
  li a {
    font-family: var(--sub-font);
    font-weight: 800;
    font-size: 0.875em;
  }
  @media screen and (max-width: 667px) {
    .desc {
      font-size: 0.75em;
    }
    .updated {
      font-size: 16px;
    }
    li {
      font-size: 18px;
    }
  }
</style>
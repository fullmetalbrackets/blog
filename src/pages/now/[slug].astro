---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import { SITE_URL } from '@consts';
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/BreadcrumbSchema.astro';
import FormattedDate from '@components/FormattedDate.astro';
import BackToTop from '@components/BackToTop.astro';

export async function getStaticPaths() {
  const entries = await getCollection('now');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

const allEntries = await getCollection('now');
const sorted = allEntries.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const latest = sorted[0];

if (entry.id === latest.id) {
  return Astro.redirect('/now/', 301);
}

const others = sorted.filter(e => e.id !== entry.id);
const { Content } = await render(entry);
const title = "Now";
const desc = "What I've been up to lately and what's on my mind. Updated monthly-ish.";
---

<BaseLayout title={title} description={desc} entry={entry}>
  <link slot="head" rel="canonical" href={new URL('/now', Astro.site).toString()} />
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Now", url: `${SITE_URL}/now/` }
  ]} />
  <Fragment slot="head" set:html={`<script type="application/ld+json">${JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": `${SITE_URL}/now/${entry.id}/#aboutpage`,
    "name": title,
    "description": desc,
    "url": `${SITE_URL}/now/${entry.id}/`,
    "inLanguage": "en-US",
    "dateModified": entry.data.pubDate.toISOString(),
    "author": {
      "@id": `${SITE_URL}/#person`
    }
  })}</script>`} />
  <section data-pagefind-ignore>
    <h1>{title}</h1>
    <hr />
    <p class="desc">
      {desc}
    </p>
    <span class="date">
      <span class="posted">Posted</span> <FormattedDate date={entry.data.pubDate} noDay />
    </span>
    <hr class="separator" />
    <p>
      {entry.data.image && (
        <Image src={entry.data.image} alt="" />
      )}
    </p>
    <Content />
      {others.length > 0 && (
        <h2>Other Entries</h2>
        <ul>
          {others.map(otherEntry => (
            <li>
              <a href={`/now/${otherEntry.id}/`}>
                {otherEntry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
              </a>
            </li>
          ))}
        </ul>
      )}
    <hr/>
    <BackToTop />
  </section>
</BaseLayout>

<style scoped>
  section {
    min-height: calc(100vh - 300px);
  }
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .date {
    display: flex;
    place-items: center;
  }
  .posted {
    color: var(--emphasis);
    font-family: var(--sub-font);
    font-size: 0.875em;
    font-weight: 700;
    margin-right: 0.5em;
  }
  .desc {
    margin-bottom: 2em;
    line-height: 1.2;
  }
  .separator {
    display: grid;
    border-width: 4px;
    border-color: var(--border);
  }
  h2 {
    margin-top: 1em;
  }
  ul {
    margin-bottom: 2em;
  }
  li a {
    font-family: var(--sub-font);
    font-size: 0.875em;
    font-weight: 700;
  }
  @media screen and (max-width: 667px) {
    .desc {
      font-size: 0.75em;
    }
  }
</style>
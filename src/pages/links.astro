---
export const prerender = true

import BackToTop from "@components/BackToTop.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { getSortedLinks } from "@utils/collections";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import { SITE_URL } from "@consts";

const links = await getSortedLinks();
const title = "Links";
const desc = "Links to websites, self-hosted apps and other cool online things that I use.";
---

<style>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  p {
    margin-bottom: 2em;
  }
  ul {
    list-style-type: none;
    padding: unset;
    margin-bottom: 2em;
  }
  ul li {
    display: flex;
    flex-direction: column;
    margin: 0 0.25em 1em 0.25em;
  }
  .desc {
    font-size: 0.9em;
  }
  .info {
    display: inline-flex;
    place-items: center;
    margin: 0.125em 0;
  }
  .link-tag {
    font-family: var(--sub-font);
    background-color: var(--info);
    color: #000;
    border: 0;
    border-radius: 0.25em;
    padding: 4px 8px;
    font-weight: 700;
    font-size: 0.65em;
    display: inline-block;
    transition: all 0.2s ease;
    margin-right: 0.5em;
  }
  .title-link {
    color: var(--emphasis);
    font-weight: bold;
    line-height: 1.2;
  }
  .title-link:hover {
    color: var(--hover);
  }
  .edit a {
    color: #000;
  }
  .edit a:hover {
    color: #000;
    border-bottom: 0;
  }
  .edit {
    display: inline-block;
    background-color: var(--info);
    color: #000;
    border-radius: 0.5em;
    cursor: pointer;
    font-weight: 700;
    margin: 0 auto;
    padding: 6px 10px 4px 10px;
    text-decoration: none;
    font-size: 0.85em;
    font-family: 'M Plus Rounded 1c Med';
    line-height: 1.5;
  }
  .edit img {
    display: inline;
    filter: brightness(0) saturate(100%);
    height: 24px;
    width: auto;
    padding: 0 auto;
    margin: 2px 0.5em -5px 0;
    border-radius: 0;
    cursor: pointer;
  }
  aside {
    margin-top: -2em;
  }
  
  /* Hover effect: when title is hovered, animate the tag */
  @media (hover: hover) {
    li:has(.title-link:hover) .link-tag {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      outline-offset: 1px;
    }
  }
  
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    .desc {
      font-size: 18px;
    }
    .edit {
      font-size: 0.75em;
    }
    .info {
      margin: 0.125em 0;
    }
    .link-tag {
      font-size: 14px;
    }
  }
</style>
<BaseLayout title={title} description={desc}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Links", url: `${SITE_URL}/links` }
  ]} />
  <CollectionPageSchema
    name={title}
    description={desc}
    url={`${SITE_URL}/links`}
  />
  <section class="h-feed" data-pagefind-body>
    <h1 class="p-name">Links</h1>
    <a class="u-url" href={`${SITE_URL}/links`} hidden>Permalink</a>
    <hr />
    <p>
      {desc} I'm constantly adding to this as I find new things I consider worth sharing! <i>(All links are external and open in new tab.)</i>
    </p>
    <ul>
      {
        links.map((link) => (
          <li class="h-entry">
            <span>
              <a href={link.data.url} target="_blank" class="u-bookmark-of title-link" data-umami-event={`links-${link.data.title}`}>
                <span class="p-name">{link.data.title}</span>
              </a>
            </span>
            <span class="info"><span class="link-tag">{link.data.tag}</span><FormattedDate class="dt-published" date={link.data.pubDate} /></span>
            <span class="p-summary desc">{link.data.description}</span>
          </li>
        ))
      }
    </ul>
    <hr/>
    <BackToTop />
  </section>
</BaseLayout>
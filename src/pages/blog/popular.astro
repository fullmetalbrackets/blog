---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { getPostsWithReadingTime } from '@utils/collections';
import type { Post } from '@utils/collections';
import FormattedDate from '@components/FormattedDate.astro';
import ReadingTime from '@components/ReadingTime.astro';
import BackToTop from '@components/BackToTop.astro';
import BreadcrumbSchema from '@components/BreadcrumbSchema.astro';
import { SITE_URL } from '@consts';
import popularData from '@data/popular.json';

const allPosts = await getPostsWithReadingTime();

const popular = (popularData as string[])
  .map((slug) => allPosts.find((p) => p.id === slug))
  .filter((post): post is Post => post !== undefined);

const title = 'Popular Posts';
const description =
  'The most-read posts over the last 30 days, updated every Monday.';
---

<style>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .description {
    margin-bottom: 1em;
  }
  .meta {
    font-family: var(--sub-font);
    font-weight: 900;
    color: var(--primary);
  }
  .back {
    display: flex;
    justify-content: space-between;
    font-family: var(--sub-font);
    font-weight: 800;
    margin-bottom: 1em;
  }
  .all svg,
  .categories svg {
    display: inline-flex;
    width: 0.75em;
    height: 0.75em;
    vertical-align: middle;
    fill: currentColor;
    transition: all 0.1s ease-in-out;
    overflow: visible;
  }
  .all:hover svg {
    transition: all 0.1s ease-in-out;
    transform: translateX(-4px);
  }
  .categories:hover svg {
    transition: all 0.1s ease-in-out;
    transform: translateX(4px);
  }
  ul {
    list-style-type: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1000px;
  }
  li {
    display: inline-block;
    margin: 0 auto 1em auto;
  }
  li:last-of-type {
    margin: 0 auto;
  }
  div {
    display: block;
    padding-bottom: 0.25em;
    border-bottom: 4px dotted transparent;
  }
  p {
    margin: 0 auto;
    padding: 0 auto;
  }
  button {
    margin: 0 0.175em;
    background: var(--info);
    cursor: pointer;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .info {
    place-items: center;
    margin-top: 0.1em;
    display: inline-flex;
    gap: 0.25em;
  }
  .tag {
    margin: 0.125em 0 0 0;
    padding: 0;
  }
  .title {
    display: block;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .rank {
    font-family: var(--sub-font);
    font-size: 0.65em;
    font-weight: 900;
    color: var(--other);
    margin-right: 0.5em;
    vertical-align: 0.15em;
  }
  .desc {
    margin-top: -0.25em;
  }
  li:hover div {
    border-bottom: 4px dotted var(--hover);
    cursor: pointer;
    transition: all 0.25s ease-out;
  }
  li:hover .title {
    color: var(--hover);
    transition: all 0.25s ease-out;
  }
  .bottom-line {
    margin-top: 2em;
  }
  @media (hover: hover) {
    li:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    button {
      text-overflow: ellipsis;
      transition: all 0.1s ease-out;
      cursor: pointer;
    }
    button:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      cursor: pointer;
    }
    button:focus-visible {
      outline-offset: 1px;
    }
  }
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    .info {
      margin-top: 0.25em;
      margin-bottom: 0.25em;
    }
    .tag button {
      margin: 0 0.45em 0 0;
    }
  }
</style>

<BaseLayout
  title={title}
  description={description}
  ogImage={`${SITE_URL}/og/blog.png`}
>
  <BreadcrumbSchema
    slot="head"
    crumbs={[
      { name: 'Home', url: `${SITE_URL}` },
      { name: 'Blog', url: `${SITE_URL}/blog` },
      { name: 'Popular', url: `${SITE_URL}/blog/popular` },
    ]}
  />
  <section>
    <h1>{title}</h1>
    <hr />
    <p class="description">
      <span class="meta">{popular.length}</span> most-read posts over the last 30
      days, updated every Monday.
    </p>
    <p class="back">
      <a href="/blog" rel="prefetch-intent" class="all"
        ><svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1"
          ><title>arrow-left</title><path
            d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z"
          ></path></svg
        > All posts</a
      >
      <a href="/blog/updated" rel="prefetch-intent" class="categories"
        >Recently updated <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1"
          ><title>arrow-right</title><path
            d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z"
          ></path></svg
        ></a
      >
    </p>
    <ul>
      {
        popular.map((post, index) => (
          <li class="h-entry">
            <div>
              <a
                href={`/blog/${post.id}`}
                rel="prefetch-intent"
                data-umami-event={post.id}
              >
                <span class="p-name title">
                  <span class="rank">#{index + 1}</span>
                  {post.data.title}
                </span>
                <p class="tag">
                  {post.data.tags.map((tag: string) => (
                    <button>{tag}</button>
                  ))}
                </p>
                <p class="info">
                  <FormattedDate date={post.data.pubDate} />
                  &nbsp;
                  <span>
                    <ReadingTime time={post.readingTime} />
                  </span>
                </p>
                <p class="p-summary desc">{post.data.description}</p>
              </a>
            </div>
          </li>
        ))
      }
    </ul>
    <hr class="bottom-line" />
    <BackToTop />
  </section>
</BaseLayout>

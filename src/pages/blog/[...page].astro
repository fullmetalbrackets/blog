---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPostsWithReadingTime, getPostsByYearMap } from '@utils/collections';
import FormattedDate from "@components/FormattedDate.astro";
import ReadingTime from "@components/ReadingTime.astro";
import Link from "@components/Link.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import { SITE_TITLE, SITE_URL } from "@consts";
import type { PaginateFunction } from 'astro';

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const [posts, postsByYear] = await Promise.all([
    getPostsWithReadingTime(),
    getPostsByYearMap()
  ]);
  return paginate(posts, { pageSize: 5, props: { postsByYear } });
}

const { page, postsByYear } = Astro.props;
const title = `Blog - Page ${page.currentPage} | ${SITE_TITLE}`;
const desc = "Archive of blog posts.";
---

<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .total {
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.95em;
    color: var(--primary);
  }
  .rss {
    display: flex;
    place-items: center;
    margin-top: 1em;
    gap: 0.25em;
    font-family: var(--sub-font);
    color: var(--emphasis);
    font-weight: 900;
  }
  ul {
    list-style-type: none;
    margin: 0 auto;
    padding: 0;
  }
  li {
    display: inline-block;
    margin: 0 auto 1em auto;
  }
  li:last-of-type {
    margin: 0 auto;
  }
  div {
    display: block;
    padding-bottom: 0.25em;
    border-bottom: 4px dotted transparent;
  }
  p {
    margin: 0 auto;
    padding: 0 auto;
  }
  .years {
    margin: 1em auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5em;
  }
  .years a {
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.9em;
  }
  .count {
    display: inline-flex;
    place-items: center;
    justify-content: center;
    min-width: 1.25em;
    padding: 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--main-font);
    font-size: 0.675em;
    vertical-align: middle;
    line-height: 1.6;
  }
  button {
    margin: 0 0.175em;
    background: var(--info);
    cursor: pointer;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .info {
    place-items: center;
    margin-top: 0.1em;
    display: inline-flex;
    gap: 0.25em
  }
  .tag {
    margin: 0.125em 0 0 0;
    padding: 0;
  }
  .title {
    display: block;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .title a:hover {
    color: var(--hover);
  }
  .desc {
    margin-top: -0.25em;
  }
  li:hover div {
    border-bottom: 4px dotted var(--hover);
    cursor: pointer;
    transition: all .25s ease-out;
  }
  li:hover .title {
    color: var(--hover);
    transition: all .25s ease-out;
  }
  @media (hover: hover) {
    li:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    li:hover button {
      outline-offset: 1px;
    }
    button {
      text-overflow: ellipsis;
      transition: all .10s ease-out;
      cursor: pointer;
    }
    button:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px,4px);
      cursor: pointer;
    }
    button:focus-visible{
      outline-offset: 1px;
    }
  }
  .page-info-top {
    display: flex;
    font-weight: 900;
    margin: 1em auto -1.75em auto;
    justify-content: space-around;
    place-items: center;
    font-family: var(--sub-font);
    color: var(--primary);
  }
  .page-info {
    display: flex;
    font-weight: 700;
    margin: 1em auto -1.75em auto;
    justify-content: space-around;
    place-items: center;
    font-family: var(--sub-font);
    font-weight: 900;
    color: var(--primary);
  }
  .pagination {
    display: grid;
    justify-content: space-between;
    font-family: var(--sub-font);
    font-weight: 700;
    margin: 0 0 1em 0;
  }
  .prev {
    grid-column: 1;
    justify-content: start;
  }
  .next {
    grid-column: 3;
    justify-content: end;
  }
  .prev a svg, .next a svg {
    display: inline-flex;
    width: 0.75em;
    height: 0.75em;
    vertical-align: middle;
    fill: currentColor;
    overflow: visible;
    transition: all .1s ease-in-out;
  }
  .prev a:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(-4px);
  }
  .next a:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(4px);
  }
  .rss svg:hover {
    animation: wiggle 0.25s ease-in-out;
  }
  .rss svg:not(:hover) {
    animation: none;
  }
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    .info {
      display: block;
      margin-top: 0.25em;
      margin-bottom: 0.5em;
    }
    .tag button {
      margin: 0 0.25em 0.25em 0;
    }
    .posts-years {
      font-size: 18px;
    }
    .page-info-top {
      font-size: 0.85em;
      margin: 1.5em 0 -1.3em 0;
      padding: 0;
    }
    .page-info {
      font-size: 0.85em;
      margin: 1.5em 0 -1.25em 0;
      padding: 0.1em 0 0 0;
    }
    .pagination {
      font-size: 0.8em;
    }
    .desc, .rss {
      font-size: 0.75em;
    }
  }
</style>

<BaseLayout title={title} description={desc}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Blog", url: `${SITE_URL}/blog` }
  ]} />
  <CollectionPageSchema
    slot="head"
    name={title}
    description={desc}
    url={`${SITE_URL}/blog`}
  />
  <section class="h-feed">
    <h1 class="p-name">Blog</h1>
    <a class="u-url" href={`${SITE_URL}/blog`} hidden>Permalink</a>
    <hr />
    <p class="blurb">
      <span>
        List of all <span class="total">{page.total}</span> blog posts. Alternately, see posts <a href="/blog/updated" rel="prefetch-intent" data-umami-event="blog-updated">by most recently updated</a> or <a href="/categories" rel="prefetch-intent" data-umami-event="blog-category">by category</a>.
      </span>
      <nav class="years">
        <span class="posts-years">See posts by year:</span>
        <Link href="/blog/years/2026" rel="prefetch-intent" aria-label="2026" data-umami-event="blog-2026"><button>2026 <span class="count">{postsByYear['2026']?.length || 0}</span></button></Link>
        <Link href="/blog/years/2025" rel="prefetch-intent" aria-label="2025" data-umami-event="blog-2025"><button>2025 <span class="count">{postsByYear['2025']?.length || 0}</span></button></Link>
        <Link href="/blog/years/2024" rel="prefetch-intent" aria-label="2024" data-umami-event="blog-2024"><button>2024 <span class="count">{postsByYear['2024']?.length || 0}</span></button></Link>
        <Link href="/blog/years/2023" rel="prefetch-intent" aria-label="2023" data-umami-event="blog-2023"><button>2023 <span class="count">{postsByYear['2023']?.length || 0}</span></button></Link>
        <Link href="/blog/years/2022" rel="prefetch-intent" aria-label="2022" data-umami-event="blog-2022"><button>2022 <span class="count">{postsByYear['2022']?.length || 0}</span></button></Link>
        <Link href="/blog/years/2021" rel="prefetch-intent" aria-label="2021" data-umami-event="blog-2021"><button>2021 <span class="count">{postsByYear['2021']?.length || 0}</span></button></Link>
      </nav>
      <span class="rss">RSS Feed: 
        <a href="/rss.xml" rel="prefetch-intent">
          <svg xmlns="http://www.w3.org/2000/svg" version="1.1" style="vertical-align: text-bottom; width: 1.325em; height: 1.325em;" class="pr-1" id="RSSicon" viewBox="0 0 256 256">
            <title>RSS Feed</title>
            <defs>
              <linearGradient x1="0.085" y1="0.085" x2="0.915" y2="0.915" id="RSSg">
                <stop  offset="0.0" stop-color="#E3702D"/><stop  offset="0.1071" stop-color="#EA7D31"/>
                <stop  offset="0.3503" stop-color="#F69537"/><stop  offset="0.5" stop-color="#FB9E3A"/>
                <stop  offset="0.7016" stop-color="#EA7C31"/><stop  offset="0.8866" stop-color="#DE642B"/>
                <stop  offset="1.0" stop-color="#D95B29"/>
              </linearGradient>
            </defs>
            <rect width="256" height="256" rx="55" ry="55" x="0"  y="0"  fill="#CC5D15"/>
            <rect width="246" height="246" rx="50" ry="50" x="5"  y="5"  fill="#F49C52"/>
            <rect width="236" height="236" rx="47" ry="47" x="10" y="10" fill="url(#RSSg)"/>
            <circle cx="68" cy="189" r="24" fill="#FFF"/>
            <path d="M160 213h-34a82 82 0 0 0 -82 -82v-34a116 116 0 0 1 116 116z" fill="#FFF"/>
            <path d="M184 213A140 140 0 0 0 44 73 V 38a175 175 0 0 1 175 175z" fill="#FFF"/>
          </svg>
        </a>
      </span>
    </p>
    <div class="page-info-top">Page {page.currentPage} of {page.lastPage}</div>
    <nav class="pagination" aria-label="Blog pagination">
      <span class="prev">
        {page.url.prev ? (
          <a href={page.url.prev} rel="prefetch-intent prev"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-left</title><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" /></svg> Newer</a>
        ) : (
          <span></span>
        )}
      </span>
      <span class="next">
        {page.url.next ? (
          <a href={page.url.next} rel="prefetch-intent next">Older <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-right</title><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" /></svg></a>
        ) : (
          <span></span>
        )}
      </span>
    </nav>
    <ul>
      {
        page.data.map((post) => (
          <li class="h-entry">
            <div>
              <a class="u-url" href={`/blog/${post.id}`} rel="prefetch-intent" data-umami-event={post.id}>
                <span class="p-name title">{post.data.title}</span>
                <p class="tag">
                  {post.data.tags.map((tag) => (
                    <button>{tag}</button>
                  ))}
                </p>
                <p class="info">
                  <FormattedDate class="dt-published" date={post.data.pubDate} />&nbsp;
                  <span class="reading"><ReadingTime time={post.readingTime} /></span>
                </p>
                <p class="desc">{post.data.description}</p>
              </a>
            </div>
          </li>
        ))
      }
    </ul>
    
    <div class="page-info">Page {page.currentPage} of {page.lastPage}</div>
    <nav class="pagination" aria-label="Blog pagination">
      <span class="prev">
        {page.url.prev ? (
          <a href={page.url.prev} rel="prefetch-intent prev"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-left</title><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" /></svg> Newer</a>
        ) : (
          <span></span>
        )}
      </span>
      <span class="next">
        {page.url.next ? (
          <a href={page.url.next} rel="prefetch-next">Older <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-right</title><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" /></svg></a>
        ) : (
          <span></span>
        )}
      </span>
    </nav>
    <hr />
    <BackToTop />
  </section>
</BaseLayout>

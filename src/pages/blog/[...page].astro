---
export const prerender = true;

import BaseLayout from "@layouts/BaseLayout.astro";
import { getPostsWithReadingTime, getPostsByYearMap } from '@utils/collections';
import FormattedDate from "@components/FormattedDate.astro";
import ReadingTime from "@components/ReadingTime.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import ItemListSchema from "@components/ItemListSchema.astro";
import { SITE_TITLE, SITE_URL } from "@consts";
import type { PaginateFunction } from 'astro';
import { pages } from "@data/pages";

export async function getStaticPaths({ paginate }: { paginate: PaginateFunction }) {
  const [posts, postsByYear] = await Promise.all([
    getPostsWithReadingTime(),
    getPostsByYearMap()
  ]);
  return paginate(posts, { pageSize: 5, props: { postsByYear } });
}

const { page } = Astro.props;
const title = `Blog - Page ${page.currentPage} | ${SITE_TITLE}`;
const { description } = pages.find(p => p.href === "/blog")!;

const pageUrl = page.currentPage === 1
  ? `${SITE_URL}/blog`
  : `${SITE_URL}/blog/${page.currentPage}`;
const blogItems = page.data.map(post => ({
  name: post.data.title,
  url: `${SITE_URL}/blog/${post.id}`,
  type: "BlogPosting",
}));
---

<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .rss {
    display: flex;
    place-items: center;
    margin-top: 1em;
    gap: 0.25em;
    font-family: var(--sub-font);
    color: var(--emphasis);
    font-weight: 900;
  }
  ul {
    list-style-type: none;
    margin: 1em auto 0 auto;
    padding: 0;
    max-width: 1000px;
  }
  li {
    display: inline-block;
    margin: 0 auto 1em auto;
  }
  li:last-of-type {
    margin: 0 auto;
  }
  div {
    display: block;
    padding-bottom: 0.25em;
    border-bottom: 4px dotted transparent;
  }
  hr ~ p {
    margin: 0 auto 1em auto;
    padding: 0 auto;
  }
  hr ~ p a[target='_blank']::after {
    content: '';
    display: inline-block;
    width: 0.6em;
    height: 0.6em;
    margin-left: 0.2em;
    margin-bottom: 0.2em;
    background-color: currentColor;
    mask-image: url('/assets/new-tab.svg');
    mask-repeat: no-repeat;
    mask-position: center;
    mask-size: contain;
    vertical-align: middle;
  }
  p {
    margin: 0 auto;
    padding: 0;
  }
  .years {
    margin: 1em auto;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25em;
  }
  .years a {
    display: flex;
    font-size: 0.9em;
    vertical-align: middle;
    place-items: center;
  }
  .count {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25em;
    height: 1rem;
    padding: 1px 0 0 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--main-font);
    font-size: 0.675em;
  }
  button {
    margin: 0 0.175em;
    background: var(--info);
    cursor: pointer;
    gap: 0.5em;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .info {
    place-items: center;
    margin-top: 0.1em;
    display: inline-flex;
    gap: 0.25em
  }
  .tag {
    display: flex;
    margin: 0.25em 0;
    padding: 0;
  }
  .title {
    display: block;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .title a:hover {
    color: var(--hover);
  }
  .desc {
    margin-top: -0.25em;
  }
  li:hover div {
    border-bottom: 4px dotted var(--hover);
    cursor: pointer;
    transition: all .25s ease-out;
  }
  li:hover .title {
    color: var(--hover);
    transition: all .25s ease-out;
  }
  @media (hover: hover) {
    li:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    li:hover button {
      outline-offset: 1px;
    }
    button {
      text-overflow: ellipsis;
      transition: all .10s ease-out;
      cursor: pointer;
    }
    button:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px,4px);
      cursor: pointer;
    }
    button:focus-visible{
      outline-offset: 1px;
    }
    .years a:active button, .years a:focus button {
      box-shadow: none;
      transform: translate(0px, 0px);
      background-color: var(--hover);
    }
  }
  .page-info-top {
    display: flex;
    font-weight: 900;
    margin: 1em auto -1.75em auto;
    justify-content: space-around;
    place-items: center;
    font-family: var(--sub-font);
    color: var(--primary);
  }
  .page-info {
    display: flex;
    margin: 1em auto -1.75em auto;
    justify-content: space-around;
    place-items: center;
    font-family: var(--sub-font);
    font-weight: 800;
    color: var(--primary);
  }
  .pagination {
    display: grid;
    justify-content: space-between;
    font-family: var(--sub-font);
    font-weight: 800;
    margin-top: 1px;
  }
  .prev {
    grid-column: 1;
    justify-content: start;
    margin-top: 0.1em;
  }
  .next {
    grid-column: 3;
    justify-content: end;
    margin-top: 1px;
  }
  .prev a svg, .next a svg {
    display: inline-flex;
    width: 0.75em;
    height: 0.75em;
    vertical-align: middle;
    fill: currentColor;
    overflow: visible;
    transition: all .1s ease-in-out;
  }
  .prev a:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(-4px);
  }
  .next a:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(4px);
  }
  .rss svg:hover {
    animation: wiggle 0.25s ease-in-out;
  }
  .rss svg:not(:hover) {
    animation: none;
  }
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    .info {
      display: block;
      margin-top: 0.25em;
      margin-bottom: 0.5em;
    }
    .tag button {
      display: flex;
      margin: 0 0.45em 0 0;
    }
    .posts-years {
      font-size: 18px;
    }
    .page-info-top {
      font-size: 0.85em;
      margin: 1.5em 0 -1.3em 0;
      padding: 0;
    }
    .page-info {
      font-size: 0.85em;
      margin: 1.5em 0 -1.25em 0;
      padding: 0.1em 0 0 0;
    }
    .pagination {
      font-size: 0.8em;
    }
    .desc, .rss {
      font-size: 0.75em;
    }
  }
</style>

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Blog", url: `${SITE_URL}/blog` }
  ]} />
  <CollectionPageSchema
    slot="head"
    name={title}
    description={description}
    url={pageUrl}
  />
  <ItemListSchema slot="head" id={`${pageUrl}/#list`} items={blogItems} />
  <section class="h-feed">
    <h1 class="p-name">Blog</h1>
    <a class="u-url" href={`${SITE_URL}/blog`} hidden>Permalink</a>
    <hr />
    <p>
      The blog has <span class="total">{page.total}</span> posts. See posts <a href="/blog/updated" rel="prefetch-intent" data-umami-event="blog-updated">by recently updated</a>, <a href="/categories" rel="prefetch-intent" data-umami-event="blog-category">by category</a>, <a href="/blog/years" rel="prefetch-intent" data-umami-event="blog-years">by year</a> or <a href="/blog/random">go to a random post</a>.
    </p>
    <p>
      <a href="/rss.xml" target="_blank">RSS</a> and <a href="/feed.json" target="_blank">JSON</a> feeds are available.
    </p>
    <div class="page-info-top">Page {page.currentPage} of {page.lastPage}</div>
    <nav class="pagination" aria-label="Blog pagination">
      <span class="prev">
        {page.url.prev ? (
          <a href={page.url.prev} rel="prefetch-intent prev"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>Newer</title><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" /></svg> Newer</a>
        ) : (
          <span></span>
        )}
      </span>
      <span class="next">
        {page.url.next ? (
          <a href={page.url.next} rel="prefetch-intent next">Older <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>Older</title><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" /></svg></a>
        ) : (
          <span></span>
        )}
      </span>
    </nav>
    <ul>
      {
        page.data.map((post) => (
          <li class="h-entry">
            <div>
              <a class="u-url" href={`/blog/${post.id}`} rel="prefetch-intent" data-umami-event={post.id}>
                <span class="p-name title">{post.data.title}</span>
                <p class="tag">
                  {post.data.tags.map((tag) => (
                    <button>{tag}</button>
                  ))}
                </p>
                <p class="info">
                  <FormattedDate class="dt-published" date={post.data.pubDate} />&nbsp;
                  <span class="reading"><ReadingTime time={post.readingTime} /></span>
                </p>
                <p class="desc">{post.data.description}</p>
              </a>
            </div>
          </li>
        ))
      }
    </ul>
    
    <div class="page-info">Page {page.currentPage} of {page.lastPage}</div>
    <nav class="pagination" aria-label="Blog pagination">
      <span class="prev">
        {page.url.prev ? (
          <a href={page.url.prev} rel="prefetch-intent prev"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>Newer</title><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" /></svg> Newer</a>
        ) : (
          <span></span>
        )}
      </span>
      <span class="next">
        {page.url.next ? (
          <a href={page.url.next} rel="prefetch-next">Older <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>Older</title><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" /></svg></a>
        ) : (
          <span></span>
        )}
      </span>
    </nav>
    <hr />
    <BackToTop />
  </section>
</BaseLayout>

---
export const prerender = true

import BaseLayout from "@layouts/BaseLayout.astro";
import { getSortedPosts } from "@utils/collections";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from "@components/CollectionPageSchema.astro";
import { SITE_URL } from "@consts";

const title = 'Blog posts by year';
const desc = 'List of blog posts by year.'

const allPosts = await getSortedPosts();

const postsByYear = allPosts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  acc[year] = (acc[year] || 0) + 1;
  return acc;
}, {} as Record<number, number>);

const years = Object.keys(postsByYear)
  .map(Number)
  .sort((a, b) => b - a);

const totalYears = years.length;
---

<style>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .back {
    display: flex;
    justify-content: space-between;
    font-family: var(--sub-font);
    font-weight: 800;
    margin-top: 1em;
  }
  .all svg, .categories svg {
    display: inline-flex;
    width: 0.75em;
    height: 0.75em;
    vertical-align: middle;
    fill: currentColor;
    transition: all .1s ease-in-out;
    overflow: visible;
  }
  .all:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(-4px);
  }
  .categories:hover svg {
    transition: all .1s ease-in-out;
    transform: translateX(4px);
  }
  ul {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    list-style-type: none;
    margin: 2em auto 6em auto;
    padding: 0;
    gap: 1em;
  }
  .label a {
    color: #000
  }
  .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25em;
    height: 1rem;
    padding: 1px 0 0 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--main-font);
    font-size: 0.675em;
  }
  button {
    display: flex;
    place-items: center;
    gap: 0.25em;
  }
  @media (hover: hover) {
    button:active, button:focus {
      box-shadow: none;
      transform: translate(0px, 0px);
      background-color: var(--hover);
    }
  }
  @media screen and (max-width: 667px) {
    .back {
      margin-top: -0.2em;
    }
  }
</style>

<BaseLayout title={title} description={desc}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Blog", url: `${SITE_URL}/blog` },
    { name: "Posts by Year", url: `${SITE_URL}/blog/years` }
  ]} />
  <CollectionPageSchema
    slot="head"
    name={title}
    description={desc}
    url={`${SITE_URL}/blog/years`}
  />
  <section>
    <h1>{title}</h1>
    <a class="u-url" href={`${SITE_URL}/blog/years`} hidden>Permalink</a>
    <hr />
    <p class="back">
      <a href="/blog" rel="prefetch-intent" class="all"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-left</title><path d="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" /></svg> All posts</a>
      <a href="/categories" rel="prefetch-intent" class="categories">Categories <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><title>arrow-right</title><path d="M4,11V13H16L10.5,18.5L11.92,19.92L19.84,12L11.92,4.08L10.5,5.5L16,11H4Z" /></svg></a>
    </p>
    <p>
        Bloggin' for <span class="total">{totalYears} years</span>. Pick one below to see only blog posts written that year.
    </p>
    <ul>
        {years.map((year) => (
            <li>
                <button>
                    <span class="label">
                        <a href={`/blog/years/${year}`} rel="prefetch-intent" data-umami-events={`blog-${year}`}>{year}</a>
                    </span>
                    <span class="count">
                        {postsByYear[year]}
                    </span>
                </button>
            </li>
        ))}
    </ul>
  </section>
</BaseLayout>
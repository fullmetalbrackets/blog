---
import BaseLayout from "@layouts/BaseLayout.astro";
import FormattedDate from "@components/FormattedDate.astro";
import ReadingTime from "@components/ReadingTime.astro";
import Link from "@components/Link.astro";
import BackToTop from "@components/BackToTop.astro";
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import { getPostsWithReadingTime } from "@utils/collections";
import type { BlogYearProps } from '../../../types';
import { SITE_URL } from "@consts";

export async function getStaticPaths() {
  const allPosts = await getPostsWithReadingTime();

  const postsByYear = allPosts.reduce((acc, post) => {
    const year = post.data.pubDate.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(post);
    return acc;
  }, {} as Record<string, typeof allPosts>);

  return Object.entries(postsByYear).map(([year, posts]) => ({
    params: { year },
    props: { posts, postsByYear }
  }));
}

type Props = BlogYearProps;
const { posts, postsByYear } = Astro.props;
const { year } = Astro.params;
const postCount = posts.length
const title = `Blog - ${year}`;
const desc = `Blog posts written in ${year}.`;
---

<BaseLayout title={title} description={desc}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Blog", url: `${SITE_URL}/blog/` },
    { name: year, url: `${SITE_URL}/blog/years/${year}/` }
  ]} />
  <section class="h-feed">
    <h1 class="p-name">{title}</h1>
    <hr />
    <p class="back">
      <a href="/blog/" rel="prefetch-intent">↩ Back to Blog</a>
      <a href="/categories/" rel="prefetch-intent">Categories ↪</a>
    </p>
    <nav class="years">
      Showing <span class="total">{postCount}&nbsp;{postCount === 1 ? 'post' : 'posts'}</span> from <span class="total">{year}</span>. See more years:&nbsp;
      <Link href="/blog/years/2026/" rel="prefetch-intent" aria-label="2026" data-umami-event="blog-2026"><button>2026 <span class="count">{postsByYear['2026']?.length || 0}</span></button></Link>
      <Link href="/blog/years/2025/" rel="prefetch-intent" aria-label="2025" data-umami-event="blog-2025"><button>2025 <span class="count">{postsByYear['2025']?.length || 0}</span></button></Link>
      <Link href="/blog/years/2024/" rel="prefetch-intent" aria-label="2024" data-umami-event="blog-2024"><button>2024 <span class="count">{postsByYear['2024']?.length || 0}</span></button></Link>
      <Link href="/blog/years/2023/" rel="prefetch-intent" aria-label="2023" data-umami-event="blog-2023"><button>2023 <span class="count">{postsByYear['2023']?.length || 0}</span></button></Link>
      <Link href="/blog/years/2022/" rel="prefetch-intent" aria-label="2022" data-umami-event="blog-2022"><button>2022 <span class="count">{postsByYear['2022']?.length || 0}</span></button></Link>
      <Link href="/blog/years/2021/" rel="prefetch-intent" aria-label="2021" data-umami-event="blog-2021"><button>2021 <span class="count">{postsByYear['2021']?.length || 0}</span></button></Link>
    </nav>
    <ul>
      {
        posts.map((post) => (
          <li class="h-entry">
            <div>
              <a class="u-url" href={`/blog/${post.id}/`} rel="prefetch-intent" data-umami-event={post.id}>
                <span class="p-name title">{post.data.title}</span>
                <p class="tag">
                  {post.data.tags.map((tag) => (
                    <button>{tag}</button>
                  ))}
                </p>
                <p class="info">
                  <FormattedDate class="dt-published" date={post.data.pubDate} />&nbsp;
                  <span class="reading">
                    <ReadingTime time={post.readingTime} />
                  </span>
                </p>
                <p class="p-summary desc">{post.data.description}</p>
              </a>
            </div>
          </li>
        ))
      }
    </ul>
    <hr />
    <BackToTop />
  </section>
</BaseLayout>

<style scoped>
  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
  }
  .total {
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.95em;
    color: var(--emphasis)
  }
  button {
    display: inline-flex;
    place-items: center;
    gap: 0.25em;
  }
  .count {
    display: inline-flex;
    place-items: center;
    justify-content: center;
    min-width: 1.25em;
    padding: -5px 0 0 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--main-font);
    font-size: 0.675em;
  }
  ul {
    list-style-type: none;
    margin: 0 auto 2em auto;
    padding: 0;
  }
  li {
    display: inline-block;
    margin: 0 auto 1em auto;
  }
  li:last-of-type {
    margin: 0 auto;
  }
  div {
    display: block;
    padding-bottom: 0.25em;
    border-bottom: 4px dotted transparent;
  }
  p {
    margin: 0 auto 0.125em auto;
    padding: 0 auto;
  }
  .years {
    margin: 1em auto 2em;
  }
  .years a button {
    font-family: var(--sub-font);
    font-weight: 700;
    margin-right: 0.5em;
  }
  .years span.active button {
    font-family: var(--sub-font);
    background: var(--primary);
    margin-right: 0.5em;
    animation: none
  }
  .back {
    display: flex;
    justify-content: space-between;
  }
  button {
    margin: 0 0.175em;
    background: var(--info);
    cursor: pointer;
  }
  button:first-of-type {
    margin-left: 0;
  }
  .info {
    place-items: center;
    margin-top: 0.1em;
    display: inline-flex;
    gap: 0.25em
  }
  .tag {
    margin: 0.125em 0 0 0;
    padding: 0;
  }
  .title {
    display: block;
    font-weight: bold;
    line-height: 1.2;
    color: var(--emphasis);
  }
  .title a:hover {
    color: var(--hover);
  }
  .desc {
    margin-top: -0.25em;
  }
  li:hover div {
    border-bottom: 4px dotted var(--hover);
    cursor: pointer;
    transition: all .25s ease-out;
  }
  li:hover .title {
    color: var(--hover);
    transition: all .25s ease-out;
  }
  @media (hover: hover) {
    li:hover button {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
    }
    li:hover button {
      outline-offset: 1px;
    }
    button {
      text-overflow: ellipsis;
      transition: all .10s ease-out;
      cursor: pointer;
    }
    button:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px,4px);
      cursor: pointer;
    }
    button:focus-visible{
      outline-offset: 1px;
    }
  }
  @media (hover: hover) {	
    span.active a:hover button {
      box-shadow: none;
      transform: none;
    }
  }
  @media screen and (max-width: 667px) {
    section {
      line-height: 1.2;
    }
    .years {
      margin-bottom: 1em;
    }
    .info {
      display: block;
      margin-top: 0.25em;
      margin-bottom: 0.5em;
    }
    .tag button {
      margin: 0 0.25em 0.25em 0;
    }
  }
</style>

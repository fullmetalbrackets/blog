---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { getLifestream } from "@utils/collections";
import { Image } from 'astro:assets';
import FormattedDate from '@components/FormattedDate.astro';
import GameIcon from '@icons/game.svg';
import BookIcon from '@icons/book.svg';
import MovieIcon from '@icons/movie.svg';
import TVShowIcon from '@icons/tvshow.svg';
import BreadcrumbSchema from "@components/BreadcrumbSchema.astro";
import CollectionPageSchema from '@components/CollectionPageSchema.astro';
import BackToTop from "@components/BackToTop.astro";
import { SITE_URL } from "@consts";

const entries = await getLifestream();

const types = ['movie', 'tvshow', 'book', 'game'] as const;
type MediaType = typeof types[number];

const counts = Object.fromEntries(
  types.map(t => [t, entries.filter(e => e.data.type === t).length])
);

const typeName: Record<MediaType, string> = {
  game:   'Games',
  book:   'Books',
  movie:  'Movies',
  tvshow: 'TV Shows',
};

const vibes = {
  hated:       { emoji: '💩' },
  disliked:    { emoji: '😕' },
  liked:       { emoji: '👍🏼' },
  loved:       { emoji: '❤️' },
  masterpiece: { emoji: '🌟' },
} as const;

const years = [...new Set(
  entries.map(e => (e.data.updatedDate ?? e.data.pubDate).getFullYear())
)].sort((a, b) => b - a);

const title = "Lifestream";
const desc = "All the media I've played, read, and watched. And what I thought of it."
---

<BaseLayout title={title} description={desc}>
  <script is:inline slot="head">
    document.addEventListener('DOMContentLoaded', () => {
      const details = document.querySelector('.filter-details');
      // Restore
      for (const id of Object.keys(sessionStorage)) {
        const el = document.getElementById(id);
        if (el instanceof HTMLInputElement) {
          el.checked = sessionStorage.getItem(id) === 'true';
        }
      }
      if (details instanceof HTMLDetailsElement) {
        details.open = sessionStorage.getItem('filter-details-open') === 'true';
      }
      // Save filters
      document.addEventListener('change', (e) => {
        const el = e.target;
        if (el instanceof HTMLInputElement && el.classList.contains('filter-toggle')) {
          sessionStorage.setItem(el.id, el.checked.toString());
          if (el.checked) {
            const label = document.querySelector(`label[for="${el.id}"]`);
            label?.classList.add('is-popping');
            label?.addEventListener('animationend', () => label.classList.remove('is-popping'), { once: true });
          }
        }
      });
      // Save details open/closed
      details?.addEventListener('toggle', () => {
        sessionStorage.setItem('filter-details-open', details.open.toString());
      });
      // Reset filters
      document.getElementById('reset-filters')?.addEventListener('click', () => {
        const btn = document.getElementById('reset-filters');
        if (btn instanceof HTMLElement) {
          btn.classList.add('is-shaking');
          btn.addEventListener('animationend', () => btn.classList.remove('is-shaking'), { once: true });
        }
        document.querySelectorAll('.filter-toggle').forEach((el, i) => {
          if (el instanceof HTMLInputElement) {
            el.checked = true;
            sessionStorage.setItem(el.id, 'true');
            const label = document.querySelector(`label[for="${el.id}"]`);
            if (label instanceof HTMLElement) {
              label.style.animationDelay = `${i * 30}ms`;
              label.classList.add('is-popping');
              label.addEventListener('animationend', () => {
                label.classList.remove('is-popping');
                label.style.animationDelay = '';
              }, { once: true });
            }
          }
        });
      });
    });
  </script>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}` },
    { name: "Lifestream", url: `${SITE_URL}/lifestream` }
  ]} />
  <CollectionPageSchema
    slot="head"
    name={title}
    description={desc}
    url={`${SITE_URL}/lifestream`}
  />
  <section class="h-feed">
    <h1 class="p-name">{title}</h1>
    <a class="u-url" href="/lifestream" hidden>Permalink</a>
    <hr />
    <p class="desc">
      {desc}
    </p>

    {types.map(t => (
      <input
        type="checkbox"
        class="filter-toggle sr-only"
        id={`filter-${t}`}
        checked
      />
    ))}

    {years.map(y => (
      <input
        type="checkbox"
        class="filter-toggle sr-only"
        id={`filter-${y}`}
        checked
      />
    ))}
  <details class="filter-details">
    <summary class="filter-summary">Filters</summary>
    <div class="details-content">
      <div class="filters">
        {types.map(t => (
          <label for={`filter-${t}`} class="filter-btn">
            <span class="btn-icon">
              {t === 'game'   && <GameIcon   width={20} height={20} />}
              {t === 'book'   && <BookIcon   width={20} height={20} />}
              {t === 'movie'  && <MovieIcon  width={20} height={20} />}
              {t === 'tvshow' && <TVShowIcon width={20} height={20} />}
            </span>
            {typeName[t]}
            <span class="filter-count">{counts[t]}</span>
          </label>
        ))}
      </div>
      <div class="filters year-filters">
        {years.map(y => (
          <label for={`filter-${y}`} class="filter-btn year-btn">
            {y}
          </label>
        ))}
      </div>
    <button id="reset-filters" class="filter-btn reset-btn">Reset</button>
    <hr class="border">
    </div>
  </details>
    <div class="ls-grid">
      {entries.map((entry, i) => (
        <a class="card h-entry"
          href={`/lifestream/${entry.id}?from=lifestream`}
          data-type={entry.data.type}
          data-year={(entry.data.updatedDate ?? entry.data.pubDate).getFullYear()}
          rel="prefetch-intent"
        >
          <span class="p-name sr-only">{entry.data.title}</span>
          <Image
            class="u-photo"
            src={entry.data.image}
            alt={entry.data.title}
            widths={[200, 400]}
            sizes="(max-width: 480px) 100vw, (max-width: 768px) 50vw, (max-width: 1024px) 33vw, 25vw"
            loading={i < 8 ? 'eager' : 'lazy'}
            decoding={i < 8 ? 'sync' : 'async'}
          />
          <span class="card-badge">
            {entry.data.type === 'game'   && <GameIcon   width={24} height={24} />}
            {entry.data.type === 'book'   && <BookIcon   width={24} height={24} />}
            {entry.data.type === 'movie'  && <MovieIcon  width={24} height={24} />}
            {entry.data.type === 'tvshow' && <TVShowIcon width={24} height={24} />}
          </span>
          <span class="card-vibe">{vibes[entry.data.rating].emoji}</span>
          <div class="card-overlay">
            <span class="date"><FormattedDate class="dt-published" date={entry.data.updatedDate ?? entry.data.pubDate} monthFormat="numeric" /></span>
          </div>
        </a>
      ))}
    </div>
    <ul class="sources">
      <li>
        Movie and TV Show posters are sourced from <a href="https://plex.tv" target="_blank" rel="noopener noreferrer">Plex</a> and <a href="https://www.themoviedb.org/" target="_blank" rel="noopener noreferrer">TMDB</a>
      </li>
      <li>
        Game covers are sourced from <a href="https://www.igdb.com/" target="_blank" rel="noopener noreferrer">IGDB</a>, <a href="https://mobygames.com/" target="_blank" rel="noopener noreferrer">MobyGames</a> and random Google finds.
      </li>
      <li>
        Book covers are sourced from <a href="https://www.goodreads.com/" target="_blank" rel="noopener noreferrer">Goodreads</a>
      </li>
    </ul>
  </section>
  <hr>
  <BackToTop />
</BaseLayout>

<style>
  section {
    margin-bottom: 2.5em;
  }

  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
    margin: 0;
  }

  hr {
    margin-bottom: 1.25em;
  }

  p {
    margin: 0 0 1em 0;
  }

  .desc {
    font-size: 1em;
    margin-bottom: -0.5em;
  }

  details {
    margin: 0.5em auto 0 auto;
  }

  .sources {
    font-size: 0.75em;
    display: grid;
    margin: 1.5em 0 -1.5em 0;
  }

  /* filters */
  .filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1em;
    max-width: 75ch;
    margin: 0 auto 2em auto;
  }

  .filter-toggle {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-family: var(--sub-font);
    font-weight: 800;
    font-size: 0.75em;
    padding: 4px 8px;
    border-radius: 0.25em;
    cursor: pointer;
    user-select: none;
    background-color: var(--accent);
    color: var(--text);
    opacity: 0.5;
    transition: all 0.1s ease-out;
  }

  .btn-icon {
    display: inline-flex;
    align-items: center;
  }

  /* inactive button icon: muted */
  .filter-btn .btn-icon :global(svg) {
    filter: var(--accent);
  }

  /* active (checked) state */
  #filter-game:checked   ~ details .filters label[for="filter-game"],
  #filter-book:checked   ~ details .filters label[for="filter-book"],
  #filter-movie:checked  ~ details .filters label[for="filter-movie"],
  #filter-tvshow:checked ~ details .filters label[for="filter-tvshow"] {
    background-color: var(--info);
    color: #000;
    opacity: 1;
  }

  #filter-game:checked   ~ details .filters label[for="filter-game"]   .btn-icon :global(svg),
  #filter-book:checked   ~ details .filters label[for="filter-book"]   .btn-icon :global(svg),
  #filter-movie:checked  ~ details .filters label[for="filter-movie"]  .btn-icon :global(svg),
  #filter-tvshow:checked ~ details .filters label[for="filter-tvshow"] .btn-icon :global(svg) {
    filter: brightness(0);
  }

  #filter-2026:checked ~ details .filters label[for="filter-2026"],
  #filter-2025:checked ~ details .filters label[for="filter-2025"],
  #filter-2024:checked ~ details .filters label[for="filter-2024"],
  #filter-2023:checked ~ details .filters label[for="filter-2023"],
  #filter-2022:checked ~ details .filters label[for="filter-2022"],
  #filter-2021:checked ~ details .filters label[for="filter-2021"] {
    background-color: var(--info);
    color: #000;
    opacity: 1;
  }

  .filter-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1rem;
    height: 1rem;
    padding: 1px 0 0 0;
    margin: 0 auto;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 9999px;
    font-family: var(--sub-font);
    font-size: 0.75em;
  }

  /* grid */
  .ls-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
    max-width: 75ch;
    margin: 0 auto;
  }

  @media (max-width: 1024px) { .ls-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px)  { .ls-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 400px)  { .ls-grid { grid-template-columns: 1fr; } }

  .card { display: none; }

  #filter-game:checked   ~ .ls-grid .card[data-type="game"],
  #filter-book:checked   ~ .ls-grid .card[data-type="book"],
  #filter-movie:checked  ~ .ls-grid .card[data-type="movie"],
  #filter-tvshow:checked ~ .ls-grid .card[data-type="tvshow"] {
    display: block;
  }

  .card {
    position: relative;
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--accent);
  }

  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s ease-in-out, opacity 0.25s ease-in-out;
    margin: 0;
    max-width: 100%;
  }

  .card-badge {
    position: absolute;
    top: 0.3rem;
    left: 0.3rem;
    background: rgba(0, 0, 0, 0.65);
    border-radius: 0.2em;
    padding: 0.2em 0.25em;
    backdrop-filter: blur(4px);
    line-height: 1;
    display: flex;
    align-items: center;
  }

  /* badge icon: always white since it's over the image */
  .card-badge :global(svg) {
    filter: brightness(0) invert(1);
    display: block;
  }

  .card-vibe {
    position: absolute;
    bottom: 0.3rem;
    right: 0.3rem;
    font-size: 0.55em;
    border-radius: 0.2em;
    padding: 0.15em 0.35em;
    backdrop-filter: blur(4px);
    line-height: 1;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 0.5rem 0.4rem;
    opacity: 0;
    transition: opacity all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .card-overlay :global(time) {
    color: #fff;
    font-size: 0.45em;
  }

  .card-overlay :global(svg) {
    filter: brightness(0) invert(1);
    width: 16px;
    height: 16px;
  }

  .date {
    background: rgba(0, 0, 0, 0.65);
    border-radius: 0.2em;
    padding: 0.05em 0.325em 0 0.325em;
  }

  /* active year button */
  #filter-2026:checked ~ .filters label[for="filter-2026"],
  #filter-2025:checked ~ .filters label[for="filter-2025"],
  #filter-2024:checked ~ .filters label[for="filter-2024"],
  #filter-2023:checked ~ .filters label[for="filter-2023"],
  #filter-2022:checked ~ .filters label[for="filter-2022"],
  #filter-2021:checked ~ .filters label[for="filter-2021"] {
    background-color: var(--info);
    color: #000;
    opacity: 1;
  }

  .year-filters {
    margin-top: -1em;
    margin-bottom: 1.5em;
  }

  .year-btn {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.05em;
  }

  #filter-2026:not(:checked) ~ .ls-grid .card[data-year="2026"],
  #filter-2025:not(:checked) ~ .ls-grid .card[data-year="2025"],
  #filter-2024:not(:checked) ~ .ls-grid .card[data-year="2024"],
  #filter-2023:not(:checked) ~ .ls-grid .card[data-year="2023"],
  #filter-2022:not(:checked) ~ .ls-grid .card[data-year="2022"],
  #filter-2021:not(:checked) ~ .ls-grid .card[data-year="2021"] {
    display: none;
  }

  .reset-btn {
    display: block;
    margin: -0.6em auto 0.5em auto;
    border: none;
    background-color: var(--primary);
    color: #000;
    opacity: 1;
  }

  @keyframes reset-shake {
    0%   { transform: translate(4px, 4px) rotate(0deg); }
    20%  { transform: translate(4px, 4px) rotate(-6deg); }
    40%  { transform: translate(4px, 4px) rotate(6deg); }
    60%  { transform: translate(4px, 4px) rotate(-4deg); }
    80%  { transform: translate(4px, 4px) rotate(4deg); }
    100% { transform: translate(4px, 4px) rotate(0deg); }
  }

  .reset-btn.is-shaking {
    animation: reset-shake 0.35s ease-in-out;
  }

  @keyframes filter-pop {
    0%   { transform: scale(1); }
    25%  { transform: scale(1.125); }
    75%  { transform: scale(0.95); }
    100% { transform: scale(1); }
  }

  .filter-btn.is-popping {
    animation: filter-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .filter-summary {
    display: inline-flex;
    cursor: pointer;
    font-weight: bold;
    font-family: var(--sub-font);
    padding: 0.25em;
    align-items: center;
    gap: 0.5em;
    color: var(--primary);
    list-style: none;
  }

  .filter-summary::-webkit-details-marker {
    display: none;
  }

  .filter-summary::before {
    content: '▶';
    display: inline-block;
    font-size: 0.75em;
    line-height: 1;
    transition: rotate 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    rotate: 0deg;
  }

  .filter-details {
    margin-bottom: 1em;
  }
  
  .filter-details[open] {
    margin-bottom: 0;
  }

  .filter-details[open] > .filter-summary::before {
    rotate: 90deg;
  }

  @keyframes bounceOpen {
    0%   { transform: scaleY(0); opacity: 0; }
    60%  { transform: scaleY(1.06); opacity: 1; }
    80%  { transform: scaleY(0.97); }
    100% { transform: scaleY(1); }
  }

  @keyframes bounceClose {
    0%   { transform: scaleY(1); opacity: 1; }
    30%  { transform: scaleY(1.04); }
    100% { transform: scaleY(0); opacity: 0; }
  }

  .filter-details .details-content {
    transform-origin: top;
    overflow: hidden;
  }

  .filter-details[open] .details-content {
    animation: bounceOpen 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .filter-details .details-content.closing {
    animation: bounceClose 0.25s ease-in forwards;
  }

  @media (hover: hover) {
    #filter-game:checked   ~ details .filters label[for="filter-game"]:hover,
    #filter-book:checked   ~ details .filters label[for="filter-book"]:hover,
    #filter-movie:checked  ~ details .filters label[for="filter-movie"]:hover,
    #filter-tvshow:checked ~ details .filters label[for="filter-tvshow"]:hover,
    #filter-2026:checked   ~ details .filters label[for="filter-2026"]:hover,
    #filter-2025:checked   ~ details .filters label[for="filter-2025"]:hover,
    #filter-2024:checked   ~ details .filters label[for="filter-2024"]:hover,
    #filter-2023:checked   ~ details .filters label[for="filter-2023"]:hover,
    #filter-2022:checked   ~ details .filters label[for="filter-2022"]:hover,
    #filter-2021:checked   ~ details .filters label[for="filter-2021"]:hover {
      background: var(--hover);
    }
    .filter-btn:hover {
      background: var(--hover);
    }
    .card:hover {
      transform: scale(1.035);
    }
    .card:hover .card-overlay {
      opacity: 1;
    }
    .reset-btn:hover {
      box-shadow: -4px -4px 0 #000;
      transform: translate(4px, 4px);
      background-color: var(--secondary);
      color: #000;
    }
  }

  @media (max-width: 667px) {
    .desc, p {
      font-size: 18px;
    }
    .filters {
      margin: 1em auto;
      gap: 0.5em;
    }
    .year-filters {
      margin-top: -0.5em;
    }
      @keyframes filter-pop {
      0%   { transform: scale(1); }
      25%  { transform: scale(1.05); }
      75%  { transform: scale(0.9); }
      100% { transform: scale(1); }
    }
  }
</style>

<script>
  const details = document.querySelector<HTMLDetailsElement>('.filter-details');
  const summary = details?.querySelector('.filter-summary');
  const content = details?.querySelector<HTMLElement>('.details-content');

  summary?.addEventListener('click', e => {
    e.preventDefault();

    if (details?.open) {
      content?.classList.add('closing');
      content?.addEventListener('animationend', () => {
        content.classList.remove('closing');
        details.removeAttribute('open');
      }, { once: true });
    } else {
      details?.setAttribute('open', '');
    }
  });
</script>
---
import BaseLayout from "@layouts/BaseLayout.astro";
import Calendar from "@icons/calendar.svg";
import BackToTop from "@components/BackToTop.astro";
import { Image } from 'astro:assets';

const title = "TV Shows - Older"
const desc = "A history of TV shows watched in my household on Plex in 2024 and 2025, scraped from Tautulli."

let plexData;
let error: string | null = null;

try {
  plexData = await import('../../../data/older-watched_tvshows.json');
} catch (e) {
  error = 'Something went wrong! No Plex data available.';
}

const historyItems = plexData?.response?.data?.data || [];
const lastUpdated = plexData?.lastUpdated;
const totalItems = plexData?.totalItems || historyItems.length;

const images = import.meta.glob('../../../data/_images/*.{jpg,jpeg,png,webp,avif}');

async function getImage(posterPath: string) {
  if (!posterPath) return null;
  
  // Log for debugging
  console.log('Looking for:', posterPath);
  
  // Try direct match first
  if (images[posterPath]) {
    return await images[posterPath]();
  }
  
  // Try with relative path prefix
  const withPrefix = `../../../data/_images/${posterPath}`;
  if (images[withPrefix]) {
    return await images[withPrefix]();
  }
  
  // Try just the filename
  const filename = posterPath.split('/').pop();
  const withFilename = `../../../data/_images/${filename}`;
  if (images[withFilename]) {
    return await images[withFilename]();
  }
  
  console.warn('Image not found:', posterPath);
  return null;
}

const itemsWithImages = await Promise.all(
  historyItems.map(async (item) => ({
    ...item,
    imageModule: item.poster ? await getImage(item.poster) : null
  }))
);

function formatDate(timestamp) {
  return new Date(timestamp * 1000).toLocaleDateString('en-US', {
    month: '2-digit',
    day: '2-digit',
    year: 'numeric'
  });
}
---

<style scoped>
  section {
    margin-bottom: 2em;
  }
  
  @media screen and (max-width: 667px) {
    section {
      font-size: 0.925em;
      margin-bottom: 1em;
      line-height: 1.2;
    }
  }

  h1 {
    font-family: var(--sub-font);
    font-weight: 900;
    margin: 0;
    padding: 0;
  }

  .plex-header {
    margin-bottom: 2rem;
  }

  .info {
    font-family: var(--sub-font);
    font-size: 0.85em;
  }

  .last-updated {
    color: var(--primary);
    font-family: var(--sub-font);
    font-weight: 700;
  }

  .stats span {
    color: var(--emphasis);
    font-weight: 700;
  }

  .error {
    padding: 1.5rem;
    background: #fee;
    border: 1px solid #fcc;
    border-radius: 8px;
    color: #c00;
  }

  .poster-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 1024px) { .poster-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px)  { .poster-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 400px)  { .poster-grid { grid-template-columns: 1fr; } }

  .poster-card {
    position: relative;
    border-radius: 0.25em;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--accent);
    margin: 0;
    padding: 0;
  }

  .poster-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    margin: 0;
    max-width: 100%;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  @media (hover: hover) {
    .poster-card:hover img {
      transform: scale(1.04);
      opacity: 0.7;
    }
    .poster-card:hover .watch-date {
      opacity: 1;
    }
  }

  .poster-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: var(--accent);
  }

  .watch-date {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 0.5rem 0.4rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 55%);
    opacity: 0;
    transition: opacity 0.25s ease;
    color: #fff;
    font-family: var(--sub-font);
    font-size: 0.45em;
    font-weight: 700;
    margin: 0;
    border-radius: 0;
  }

  .watch-date svg {
    filter: brightness(0) invert(1);
    margin-right: 0.3em;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 667px) {
    .poster-grid {
      grid-template-columns: repeat(auto-fill, minmax(155px, 1fr));
      gap: 1rem;
    }

    .poster-placeholder {
      font-size: 2rem;
    }

    .watch-date {
      font-size: 0.7rem;
      padding: 0.3rem 0.5rem;
    }
  }
</style>

<BaseLayout title={title} description={desc}>
  <section>
    <h1>{title}</h1>
    <hr>
    <p>
      {desc}
    </p>
    <p>
      See <a href="/lifestream/older/movies/">movies seen during this time period</a>, or see <a href="/lifestream/">Lifestream</a> for the latest media (including <i>books</i> and <i>video games</i>) that I have consumed.
    </p>
    <p>
      <span class="primary b sub-font">21</span> shows watched in <span class="primary b sub-font">2025</span><br>
      <span class="primary b sub-font">5</span> shows watched in <span class="primary b sub-font">2024</span>
    </p>
    <div class="plex-header">
      {lastUpdated && (
        <p class="info">
          <span class="stats"><span>{totalItems}</span> shows watched. </span>Last updated: <span class=" last-updated">{new Date(lastUpdated).toLocaleDateString('en-US', {
            month: 'long',
            day: 'numeric',
            year: 'numeric',
          })}</span>
        </p>
      )}
    </div>

    {error ? (
      <div class="error">
        <p>{error}</p>
      </div>
    ) : (
      <div class="poster-grid">
        {itemsWithImages.map((item, i) => (
          <div class="poster-card">
            {item.imageModule ? (
              <Image
                src={item.imageModule.default}
                alt={item.title}
                width={300}
                height={450}
                loading={i < 8 ? 'eager' : 'lazy'}
                decoding={i < 8 ? 'sync' : 'async'}
                quality={80}
              />
            ) : (
              <div class="poster-placeholder">📺</div>
            )}
            <div class="watch-date">
              <Calendar width={16} height={16} />
              {formatDate(item.stopped)}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
  <hr>
  <BackToTop />
</BaseLayout>
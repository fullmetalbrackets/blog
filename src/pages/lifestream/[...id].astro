---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import FormattedDate from '@components/FormattedDate.astro';
import BreadcrumbSchema from '@components/BreadcrumbSchema.astro';
import GameIcon   from '@icons/game.svg';
import BookIcon   from '@icons/book.svg';
import MovieIcon  from '@icons/movie.svg';
import TVShowIcon from '@icons/tvshow.svg';
import LeftArrow from '@icons/arrow-left.svg';
import Comments from "@components/Comments.astro";
import { SITE_URL } from "@consts";
import { schemaTypeMap } from '@utils/media';

export async function getStaticPaths() {
  const entries = await getCollection('lifestream');

  const sorted = entries.sort((a, b) => {
    const aDate = a.data.updatedDate ?? a.data.pubDate;
    const bDate = b.data.updatedDate ?? b.data.pubDate;
    return bDate.valueOf() - aDate.valueOf();
  });

  return sorted.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      prev: sorted[i + 1] ?? null,  // older
      next: sorted[i - 1] ?? null,  // newer
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;
const from = undefined;

const vibes = {
  hated:       { label: 'Hated',       emoji: '💩', color: '#e05252' },
  disliked:    { label: 'Disliked',    emoji: '😕', color: '#e09552' },
  liked:       { label: 'Liked',       emoji: '👍🏼', color: '#8fb8e0' },
  loved:       { label: 'Loved',       emoji: '❤️', color: '#7ecb85' },
  masterpiece: { label: 'Masterpiece', emoji: '🌟', color: '#ffd700' },
} as const;

const vibe = vibes[data.rating];

const typeName: Record<string, string> = {
  game:   'Game',
  book:   'Book',
  movie:  'Movie',
  tvshow: 'TV Show',
};

const ratingMap: Record<string, number> = {
  hated:       1,
  disliked:    2,
  liked:       3,
  loved:       4,
  masterpiece: 5,
};

const entryUrl = `${SITE_URL}/lifestream/${entry.id}`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "@id": `${entryUrl}#review`,
  "name": `${data.title} — ${typeName[data.type]}`,
  "url": entryUrl,
  "inLanguage": "en-US",
  "datePublished": (data.updatedDate ?? data.pubDate).toISOString(),
  "author": {
    "@id": `${SITE_URL}/#person`
  },
  "reviewBody": entry.body?.trim() ?? undefined,
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": ratingMap[data.rating],
    "bestRating": 5,
    "worstRating": 1
  },
  "itemReviewed": {
    "@type": schemaTypeMap[data.type],
    "name": data.title,
    ...(data.image && { "image": data.image.src })
  }
};
---

<BaseLayout title={data.title} description={`${typeName[data.type]} — ${vibe.label}`} disableHeadingLinks={true}>
  <BreadcrumbSchema slot="head" crumbs={[
    { name: "Home", url: `${SITE_URL}/` },
    { name: "Lifestream", url: `${SITE_URL}/lifestream` },
    { name: data.title, url: entryUrl }
  ]} />
  <Fragment slot="head" set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  <div class="entry-page">
    <a class="u-url" href={`${SITE_URL}/lifestream/${entry.id}`} hidden>Permalink</a>

    <a href="/lifestream" class="back" rel="prefetch-intent">
      <LeftArrow height={24} width={24} class="ring-arrow" />
      Back to Lifestream
    </a>

    <script>
      const searchParams = new URLSearchParams(window.location.search);
      const from = searchParams.get('from');
      
      document.querySelector('.back')?.addEventListener('click', (e) => {
        if (from === 'lifestream') {
          e.preventDefault();
          history.back();
        }
      });
    </script>

    <div class="entry h-entry">

      <div class="cover-col">
        <div class="cover-wrap">
          <Image
            src={data.image}
            alt={data.title}
            widths={[280, 560]}
            sizes="(max-width: 667px) 160px, 280px"
          />
        </div>
        <span class="type-label">
          {data.type === 'game'   && <GameIcon   width={24} height={24} />}
          {data.type === 'book'   && <BookIcon   width={24} height={24} />}
          {data.type === 'movie'  && <MovieIcon  width={24} height={24} />}
          {data.type === 'tvshow' && <TVShowIcon width={24} height={24} />}
          {typeName[data.type]}
        </span>
      </div>

      <div class="info-col">
        <h1>{data.title}</h1>

        <p class="vibe" style={`color: ${vibe.color}`}>
          {vibe.emoji} {vibe.label}
        </p>

        <dl class="meta">
          <dt>
            {data.type === 'movie' || data.type === 'tvshow' ? 'Watched on' :
             data.type === 'book' ? 'Read on' :
             data.type === 'game' ? 'Played on' : 'Posted'}
          </dt>
          <dd>
            <FormattedDate
              date={data.updatedDate ?? data.pubDate}
              monthFormat="numeric"
            />
          </dd>
          {data.platform && (
            <>
              <dt>Platform</dt>
              <dd>{data.platform}</dd>
            </>
          )}
          {data.season && (
            <>
              <dt>Season</dt>
              <dd>{data.season}</dd>
            </>
          )}
        </dl>

        {/* markdown body — personal note */}
        <div class="note">
          <Content />
        </div>
      </div>

    </div>
    <nav class="entry-nav">
      {next ? (
        <a href={`/lifestream/${next.id}`} class="entry-nav-link next">
          <span class="nav-label"><svg class="c_c c_d c_e c_f c_cd" role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false"><path d="M14 7.5H3.439l4.29-4.387-.714-.699L1.55 8l5.465 5.586.714-.7L3.44 8.5h10.56v-1z"></path></svg> Newer</span>
          <span class="nav-title">{next.data.title}</span>
        </a>
      ) : <span />}
      {prev && (
        <a href={`/lifestream/${prev.id}`} class="entry-nav-link prev">
          <span class="nav-label older">Older <svg class="c_c c_d c_e c_f c_cd" role="presentation" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true" focusable="false"><path d="M14 7.5H3.439l4.29-4.387-.714-.699L1.55 8l5.465 5.586.714-.7L3.44 8.5h10.56v-1z"></path></svg></span>
          <span class="nav-title">{prev.data.title}</span>
        </a>
      )}
    </nav>
  </div>
  <div class="comments">
      <Comments />
  </div>
</BaseLayout>


<style is:global slot="head">
  .heading-link { display: none; }
  .note ul {
    font-size: 0.75em;
    font-family: var(--sub-font);
    font-weight: 800;
    color: var(--emphasis);
    margin: 0 0 0 1em;
    padding: 0;
  }
  @media (max-width: 667px) {
    .note ul {
      font-size: 18px;
    }
  }
</style>
<style>
  .entry-page {
    padding: 2.35rem 0 3rem 0;
  }

  .back {
    display: inline-flex;
    place-items: center;
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.875em;
    text-decoration: none;
    margin: 1em auto;
    transition: none;
  }

  .back svg {
    fill: var(--link);
    margin-right: 0.25em;
    transition: transform 0.1s ease-in-out;
  }

  .back:hover svg {
    fill: var(--hover);
    transition: transform 0.1s ease-in-out;
    transform: translateX(-4px);
  }

  /* two-col layout */
  .entry {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .entry-nav {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 4px dotted var(--border);
  }

  .entry-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    text-decoration: none;
    max-width: 45%;
  }

  .entry-nav-link.prev {
    text-align: right;
    margin-left: auto;
  }

  .nav-label {
    display: inline-flex;
    align-items: center;
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.55em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--primary);
  }

  .older {
    justify-content: end;
  }

  .entry-nav-link:hover .nav-label {
    color: var(--hover);
  }

  .nav-title {
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.65em;
    color: var(--emphasis);
    line-height: 1.2;
  }

  .entry-nav-link:hover .nav-title {
    color: var(--link);
  }

  .nav-label svg {
      width: 14px;
      height: 14px;
      fill: currentColor;
      flex-shrink: 0;
  }

  .next .nav-label svg {
    transition: transform 0.1s ease-in-out;
    margin-right: 0.3em;
  }

  .prev .nav-label svg {
    transition: transform 0.1s ease-in-out;
    margin-left: 0.3em;
    transform: rotate(180deg);
  }

  .next:hover .nav-label svg {
    transform: translateX(-4px);
  }

  .prev:hover .nav-label svg {
    transform: rotate(180deg) translateX(-4px);
  }

  .comments {
    margin: -1em auto 2em auto;
  }

  @media (max-width: 667px) {
    .entry-page {
      padding-top: 0.3rem;
      margin-right: 0.5em;
      margin-left: 0.5em;      
    }

    .entry {
      grid-template-columns: 1fr;
    }

    .cover-wrap {
      width: 100%;
    }

    .cover-col {
      flex-direction: column;
      margin-bottom: -0.5em;
    }

    .note {
      font-size: 18px;
    }

    .note h2 {
      font-size: 24px;
    }

    .note ul {
      font-size: 18px;
    }

    dt {
      margin-right: 0;
    }
  }

  /* cover */
  .cover-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .cover-wrap {
    border-radius: 0.25em;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    background: var(--accent);
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    margin: 0;
    max-width: 100%;
  }

  .type-label {
    display: inline-flex;
    place-items: center;
    align-items: center;
    gap: 0.3em;
    font-family: var(--sub-font);
    font-weight: 700;
    font-size: 0.8em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--primary);
  }

  .type-label :global(svg) {
    filter: var(--controller);
    flex-shrink: 0;
    filter: var(--lifestream);
  }

  /* info column */
  .info-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-col h1 {
    font-size: 1.5em;
    line-height: 1.15;
    color: var(--emphasis);
    margin: 0;
  }

  .vibe {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--sub-font);
    font-weight: 900;
    font-size: 0.75em;
    margin: 0;
  }

  /* metadata */
  .meta {
    display: grid;
    grid-template-columns: auto 1fr;
    place-items: start;
    gap: 0.3em 1em;
    margin: 0;
    padding: 0;
    font-size: 0.75em;
    border-top: 4px dotted var(--border);
    border-bottom: 4px dotted var(--border);
    padding: 0.6em 0;
  }

  dt {
    font-family: var(--sub-font);
    font-weight: 800;
    color: var(--emphasis);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    place-items: center;
    align-items: center;
    margin-right: 2em;
  }

  dd {
    margin: 0;
    color: var(--secondary);
    display: flex;
    align-items: center;
    font-weight: 700;
  }

  /* FormattedDate inside dd */
  dd :global(time) {
    font-size: 1em;
    color: var(--date);
  }

  /* note / markdown body */
  .note {
    line-height: 1.7;
    color: var(--text);
    padding-top: 0.5rem;
  }

  .note :global(p) {
    margin: 0 0 0.75em;
  }

  .note :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
